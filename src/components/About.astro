---
const info = [
  { label: '屋号',    value: 'AltShift（オルトシフト）' },
  { label: '代表者',  value: 'ディーチャー（本名：坂口 大輝 / Daiki Sakaguchi）' },
  { label: '所在地',  value: '福岡市' },
  { label: '設立',    value: '2025年' },
  { label: '事業内容', value: '外部CAIOサービス・AIシステム開発・Web制作・SEO/GEO対策・LINE自動化' },
  { label: 'メール',   value: 'contact@altshift.jp' },
]
---

<section id="about" class="bg-slate-50 py-24 px-6 scroll-mt-16">
  <div class="max-w-5xl mx-auto">

    <div class="mb-14 reveal">
      <h2 class="font-sans font-bold text-2xl text-slate-900 mb-2">会社概要</h2>
      <div class="w-10 h-0.5 bg-slate-300"></div>
    </div>

    <div class="reveal bg-white rounded-xl border border-slate-100 overflow-hidden">
      {info.map((row, i) => (
        <dl class={`flex flex-col sm:flex-row ${i !== info.length - 1 ? 'border-b border-slate-100' : ''}`}>
          <dt class="w-full sm:w-36 px-8 py-5 text-xs font-medium tracking-wide text-slate-500 bg-slate-50/60 flex-shrink-0">
            {row.label}
          </dt>
          <dd class="flex-1 px-8 py-5 text-sm text-slate-800">
            {row.value}
          </dd>
        </dl>
      ))}
    </div>

  </div>
</section>
