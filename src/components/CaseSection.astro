---
const cases = [
  {
    title: '三栄リフォーム × AltShift',
    desc: 'Web制作 + SEO/GEO対策。AI時代の検索対応サイトを高速実装。',
    tags: ['Web制作', 'SEO/GEO'],
    url: 'https://sanei-reform.vercel.app',
  },
  {
    title: 'BAR Kar\'s × AltShift',
    desc: 'Web制作 + LINE自動化。営業時間外の問い合わせ対応を自動化。',
    tags: ['Web制作', 'LINE自動化'],
    url: '#',
  },
]
---

<section id="case" class="relative overflow-hidden section-padding" style="background:var(--color-bg-subtle);">
  <p class="absolute top-0 left-4 ghost-text" aria-hidden="true">CASE</p>

  <div class="relative max-w-6xl mx-auto">
    <div class="mb-14 reveal">
      <p class="section-label mb-2">— 実績一覧</p>
      <h2 class="heading-lg">CASE</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {cases.map(c => (
        <div class="reveal card overflow-hidden">
          <div class="w-full h-44 flex items-center justify-center" style="background:var(--color-bg-subtle);">
            <span class="text-xs tracking-widest uppercase" style="color:var(--color-ink-muted);">Image</span>
          </div>
          <div class="p-6">
            <div class="flex flex-wrap gap-2 mb-3">
              {c.tags.map(tag => (
                <span class="tag-sm">{tag}</span>
              ))}
            </div>
            <h3 class="heading-sm mb-2">{c.title}</h3>
            <p class="body-sm mb-4">{c.desc}</p>
            {c.url !== '#' && (
              <a href={c.url} target="_blank" rel="noopener noreferrer"
                 class="text-xs font-semibold hover:underline" style="color:var(--color-accent);">
                サイトを見る
              </a>
            )}
          </div>
        </div>
      ))}

      <!-- プレースホルダーカード -->
      <div class="reveal flex flex-col items-center justify-center p-8 min-h-[300px]" style="background:var(--color-bg); border:1px dashed var(--color-border); border-radius:8px;">
        <p class="section-label mb-2">Coming Soon</p>
        <p class="text-sm" style="color:var(--color-ink-muted);">近日公開</p>
      </div>
    </div>

    <div class="mt-10 text-center reveal">
      <a href="/case" class="btn-outline">
        実績一覧を見る
      </a>
    </div>
  </div>
</section>
