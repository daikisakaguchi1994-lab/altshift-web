---
---

<section id="contact" class="py-24 px-6 scroll-mt-16">
  <div class="max-w-5xl mx-auto">

    <div class="mb-14 reveal">
      <h2 class="font-sans font-bold text-2xl text-slate-900 mb-2">お問い合わせ</h2>
      <div class="w-10 h-0.5 bg-slate-300"></div>
    </div>

    <div class="reveal max-w-xl">
      <p class="text-sm text-slate-600 leading-relaxed mb-10">
        ご質問・ご相談はお気軽にどうぞ。<br />
        通常2営業日以内にご返信します。
      </p>

      <form
        name="contact"
        method="POST"
        action="#"
        class="flex flex-col gap-6"
      >
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-2" for="name">お名前</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full border border-slate-200 rounded px-4 py-3 text-sm text-slate-800 focus:outline-none focus:border-slate-400 transition"
            placeholder="山田 太郎"
          />
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-2" for="email">メールアドレス</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full border border-slate-200 rounded px-4 py-3 text-sm text-slate-800 focus:outline-none focus:border-slate-400 transition"
            placeholder="example@mail.com"
          />
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-2" for="message">お問い合わせ内容</label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            class="w-full border border-slate-200 rounded px-4 py-3 text-sm text-slate-800 focus:outline-none focus:border-slate-400 transition resize-none"
            placeholder="お気軽にご相談ください。"
          ></textarea>
        </div>
        <div>
          <button
            type="submit"
            class="bg-slate-900 text-white text-sm font-medium px-8 py-3.5 rounded hover:bg-slate-700 transition flex items-center gap-2"
          >
            送信する →
          </button>
        </div>
      </form>
    </div>

  </div>
</section>
