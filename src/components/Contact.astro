---
---

<section id="contact" class="section-padding scroll-mt-16" style="background:var(--color-bg);">
  <div class="max-w-5xl mx-auto">

    <div class="mb-14 reveal">
      <p class="section-label mb-2">— お問い合わせ</p>
      <h2 class="heading-lg mb-3">お問い合わせ</h2>
    </div>

    <div class="reveal max-w-xl">
      <p class="body-sm mb-10">
        ご質問・ご相談はお気軽にどうぞ。<br />
        通常2営業日以内にご返信します。
      </p>

      <form
        name="contact"
        method="POST"
        action="#"
        class="flex flex-col gap-6"
      >
        <div>
          <label class="block text-xs font-medium mb-2" style="color:var(--color-ink-muted);" for="name">お名前</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full text-sm transition"
            style="border:1px solid var(--color-border); border-radius:8px; padding:12px 16px; color:var(--color-ink); background:var(--color-bg); outline:none;"
            placeholder="山田 太郎"
          />
        </div>
        <div>
          <label class="block text-xs font-medium mb-2" style="color:var(--color-ink-muted);" for="email">メールアドレス</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full text-sm transition"
            style="border:1px solid var(--color-border); border-radius:8px; padding:12px 16px; color:var(--color-ink); background:var(--color-bg); outline:none;"
            placeholder="example@mail.com"
          />
        </div>
        <div>
          <label class="block text-xs font-medium mb-2" style="color:var(--color-ink-muted);" for="message">お問い合わせ内容</label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            class="w-full text-sm transition resize-none"
            style="border:1px solid var(--color-border); border-radius:8px; padding:12px 16px; color:var(--color-ink); background:var(--color-bg); outline:none;"
            placeholder="お気軽にご相談ください。"
          ></textarea>
        </div>
        <div>
          <button type="submit" class="btn-primary">
            送信する
          </button>
        </div>
      </form>
    </div>

  </div>
</section>
