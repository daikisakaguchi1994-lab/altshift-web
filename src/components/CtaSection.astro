---
---

<section class="max-w-6xl mx-auto px-6" style="padding-top:96px; padding-bottom:96px;">
  <div class="grid grid-cols-1 md:grid-cols-2 overflow-hidden" style="border:1px solid var(--color-border); border-radius:12px;">

    <!-- 左：資料ダウンロード（プライマリー） -->
    <a href="/download"
       class="group flex flex-col justify-between p-10 md:p-12 transition-opacity hover:opacity-90"
       style="background:var(--color-primary);">
      <div>
        <p class="text-xs font-medium tracking-widest uppercase mb-4" style="color:rgba(255,255,255,0.6);">DOWNLOAD</p>
        <h3 class="font-bold text-white text-2xl md:text-3xl mb-4 leading-tight" style="font-family:'Inter','Noto Sans JP',sans-serif; letter-spacing:-0.03em;">
          資料ダウンロード
        </h3>
        <p class="text-sm leading-relaxed" style="color:rgba(255,255,255,0.75);">
          AltShiftのサービス概要・料金プランをまとめた資料をご用意しています。
        </p>
      </div>
      <div class="mt-8">
        <span class="inline-flex items-center gap-2 text-sm font-medium text-white rounded px-5 py-2.5 group-hover:bg-white/10 transition-colors" style="border:1px solid rgba(255,255,255,0.4);">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          ダウンロードする
        </span>
      </div>
    </a>

    <!-- 右：お問い合わせ（ダーク） -->
    <a href="/contact"
       class="group flex flex-col justify-between p-10 md:p-12 transition-opacity hover:opacity-90"
       style="background:var(--color-ink);">
      <div>
        <p class="text-xs font-medium tracking-widest uppercase mb-4" style="color:rgba(255,255,255,0.4);">CONTACT</p>
        <h3 class="font-bold text-white text-2xl md:text-3xl mb-4 leading-tight" style="font-family:'Inter','Noto Sans JP',sans-serif; letter-spacing:-0.03em;">
          お問い合わせ
        </h3>
        <p class="text-sm leading-relaxed" style="color:rgba(255,255,255,0.5);">
          ご相談・ご質問はお気軽にどうぞ。通常2営業日以内にご返信します。
        </p>
      </div>
      <div class="mt-8">
        <span class="inline-flex items-center gap-2 text-sm font-medium text-white rounded px-5 py-2.5 group-hover:bg-white/10 transition-colors" style="border:1px solid rgba(255,255,255,0.2);">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
          </svg>
          問い合わせる
        </span>
      </div>
    </a>

  </div>
</section>
