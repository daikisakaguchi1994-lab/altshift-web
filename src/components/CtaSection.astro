---
---

<section class="max-w-6xl mx-auto px-6 py-24">
  <div class="grid grid-cols-1 md:grid-cols-2 rounded-xl overflow-hidden border border-gray-200">

    <!-- 左：資料ダウンロード（青） -->
    <a href="/download"
       class="group flex flex-col justify-between p-10 md:p-12 bg-blue-600 hover:bg-blue-700 transition-colors">
      <div>
        <p class="text-xs font-medium text-blue-200 tracking-widest uppercase mb-4">DOWNLOAD</p>
        <h3 class="font-bold text-white text-2xl md:text-3xl mb-4 leading-tight">
          資料ダウンロード
        </h3>
        <p class="text-sm text-blue-100 leading-relaxed">
          AltShiftのサービス概要・料金プランをまとめた資料をご用意しています。
        </p>
      </div>
      <div class="mt-8">
        <span class="inline-flex items-center gap-2 text-sm font-medium text-white border border-white/40 rounded px-5 py-2.5 group-hover:bg-white/10 transition-colors">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          ダウンロードする
        </span>
      </div>
    </a>

    <!-- 右：お問い合わせ（黒） -->
    <a href="/contact"
       class="group flex flex-col justify-between p-10 md:p-12 bg-gray-900 hover:bg-gray-800 transition-colors">
      <div>
        <p class="text-xs font-medium text-gray-500 tracking-widest uppercase mb-4">CONTACT</p>
        <h3 class="font-bold text-white text-2xl md:text-3xl mb-4 leading-tight">
          お問い合わせ
        </h3>
        <p class="text-sm text-gray-400 leading-relaxed">
          ご相談・ご質問はお気軽にどうぞ。通常2営業日以内にご返信します。
        </p>
      </div>
      <div class="mt-8">
        <span class="inline-flex items-center gap-2 text-sm font-medium text-white border border-white/20 rounded px-5 py-2.5 group-hover:bg-white/10 transition-colors">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
          </svg>
          問い合わせる
        </span>
      </div>
    </a>

  </div>
</section>
