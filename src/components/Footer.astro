---
---

<!-- Cream section (Tomoro-style insights/footer) -->
<footer>
  <!-- Dark footer -->
  <div class="footer-dark">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 pt-16 pb-10">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6 md:gap-10">

        <!-- Brand -->
        <div class="md:col-span-1">
          <p style="font-family:'Inter',sans-serif; font-weight:800; font-size:22px; letter-spacing:-0.03em; color:#FFFFFF; margin-bottom:16px;">
            altshift<span class="logo-ai" style="color:var(--color-accent);">.ai</span>
          </p>
          <p class="footer-muted mb-1">福岡県福岡市</p>
          <a href="mailto:contact@altshift.jp" class="footer-muted block mb-4">contact@altshift.jp</a>
          <p class="text-xs" style="color:var(--color-ink-dim);">
            AIを、経営の武器に。
          </p>
        </div>

        <!-- Services -->
        <div>
          <p class="text-xs font-semibold mb-5" style="color:var(--color-ink-muted); letter-spacing:0.1em; text-transform:uppercase;">サービス</p>
          <ul class="flex flex-col gap-3">
            <li><a href="/service/line-automation" class="footer-muted">単発AI自動化</a></li>
            <li><a href="/#process" class="footer-muted">AI内製化パッケージ</a></li>
            <li><a href="/service/ai-training" class="footer-muted">AI活用研修</a></li>
            <li><a href="#" class="footer-muted">AI顧問</a></li>
          </ul>
        </div>

        <!-- Links -->
        <div>
          <p class="text-xs font-semibold mb-5" style="color:var(--color-ink-muted); letter-spacing:0.1em; text-transform:uppercase;">リンク</p>
          <ul class="flex flex-col gap-3">
            <li><a href="/pricing" class="footer-muted">料金プラン</a></li>
            <li><a href="/case" class="footer-muted">導入事例</a></li>
            <li><a href="/company" class="footer-muted">会社情報</a></li>
            <li><a href="/contact" class="footer-muted">お問い合わせ</a></li>
          </ul>
        </div>

        <!-- Contact -->
        <div>
          <p class="text-xs font-semibold mb-5" style="color:var(--color-ink-muted); letter-spacing:0.1em; text-transform:uppercase;">お問い合わせ</p>
          <div class="flex flex-col gap-3">
            <a href="/contact" class="btn-primary justify-center" style="font-size:13px; padding:12px 20px; min-height:44px;">
              お問い合わせ
            </a>
            <a href="https://lin.ee/ySjX76bl" target="_blank" rel="noopener noreferrer" class="btn-line justify-center" style="font-size:13px; padding:12px 20px; min-height:44px;">
              <svg width="14" height="14" viewBox="0 0 48 48" fill="white">
                <path d="M24 4C12.95 4 4 11.86 4 21.5c0 5.5 2.87 10.4 7.36 13.6L9 40l6.5-2.8A22.4 22.4 0 0024 39c11.05 0 20-7.86 20-17.5S35.05 4 24 4z"/>
              </svg>
              LINE
            </a>
          </div>
        </div>
      </div>
    </div>

    <div style="border-top:1px solid rgba(255,255,255,0.06);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 py-5 flex items-center justify-between flex-wrap gap-4">
        <p class="text-xs" style="color:var(--color-ink-dim);">&copy; 2026 AltShift. All rights reserved.</p>
        <div class="flex gap-6">
          <a href="/company#legal" class="text-xs footer-muted">特定商取引法</a>
        </div>
      </div>
    </div>
  </div>
</footer>
