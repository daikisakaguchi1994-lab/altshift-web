---
---

<header id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="font-serif text-lg font-light" id="nav-logo">
      AltShift<span id="nav-dot" class="text-blue-500">.</span>
    </a>
    <nav class="hidden md:flex items-center gap-8">
      <a href="#business" class="nav-link text-sm transition">事業内容</a>
      <a href="#about" class="nav-link text-sm transition">会社概要</a>
      <a href="#contact" class="nav-link text-sm transition">お問い合わせ</a>
    </nav>
    <button id="menu-btn" class="md:hidden" aria-label="メニュー">
      <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>
  <div id="mobile-menu" class="hidden md:hidden border-t px-6 pb-5 pt-4" id="mobile-nav-bg">
    <nav class="flex flex-col gap-4">
      <a href="#business" class="text-sm">事業内容</a>
      <a href="#about" class="text-sm">会社概要</a>
      <a href="#contact" class="text-sm">お問い合わせ</a>
    </nav>
  </div>
</header>

<script>
  const nav = document.getElementById('nav')!
  const logo = document.getElementById('nav-logo')!
  const links = document.querySelectorAll<HTMLElement>('.nav-link')
  const mobileMenu = document.getElementById('mobile-menu')!

  const setScrolled = (scrolled: boolean) => {
    if (scrolled) {
      nav.classList.add('bg-white/96', 'backdrop-blur-md', 'border-b', 'border-slate-100')
      logo.classList.remove('text-white')
      logo.classList.add('text-slate-900')
      links.forEach(l => { l.classList.remove('text-white/70'); l.classList.add('text-slate-600', 'hover:text-slate-900') })
      mobileMenu.classList.add('bg-white', 'border-slate-100')
    } else {
      nav.classList.remove('bg-white/96', 'backdrop-blur-md', 'border-b', 'border-slate-100')
      logo.classList.add('text-white')
      logo.classList.remove('text-slate-900')
      links.forEach(l => { l.classList.add('text-white/70'); l.classList.remove('text-slate-600', 'hover:text-slate-900') })
      mobileMenu.classList.remove('bg-white', 'border-slate-100')
    }
  }

  setScrolled(false)
  window.addEventListener('scroll', () => setScrolled(window.scrollY > 50))

  document.getElementById('menu-btn')!.addEventListener('click', () => {
    mobileMenu.classList.toggle('hidden')
  })
</script>
