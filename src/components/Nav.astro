---
---

<header id="site-nav" class="sticky top-0 z-50 bg-white transition-shadow duration-300">
  <div class="border-b border-gray-100">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">

      <!-- ロゴ -->
      <a href="/" class="flex items-center gap-3">
        <svg width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="logoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" style="stop-color:#1B5EBE"/>
              <stop offset="100%" style="stop-color:#4A90D9"/>
            </linearGradient>
            <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" style="stop-color:#C8A15A"/>
              <stop offset="100%" style="stop-color:#E8C97A"/>
            </linearGradient>
          </defs>
          <rect width="38" height="38" rx="10" fill="url(#logoGrad)"/>
          <path d="M19 8 L28 30 H25 L22.5 23 H15.5 L13 30 H10 L19 8Z M16.5 20.5 H21.5 L19 13.5 L16.5 20.5Z" fill="white"/>
          <rect x="8" y="33" width="22" height="2" rx="1" fill="url(#goldGrad)"/>
        </svg>
        <span style="font-family:'Inter',sans-serif; font-weight:800; font-size:18px; letter-spacing:-0.03em; color:#1A1A1A;">
          Alt<span style="background:linear-gradient(135deg,#1B5EBE,#4A90D9); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">Shift</span><span style="color:#C8A15A;">.</span>
        </span>
      </a>

      <!-- 中央ナビ -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="/service"  style="font-family:'Inter','Noto Sans JP',sans-serif; font-weight:500; font-size:14px; letter-spacing:0.01em; color:#1A1A1A;" class="hover:opacity-60 transition-opacity">事業内容</a>
        <a href="/case"     style="font-family:'Inter','Noto Sans JP',sans-serif; font-weight:500; font-size:14px; letter-spacing:0.01em; color:#1A1A1A;" class="hover:opacity-60 transition-opacity">実績一覧</a>
        <a href="/news"     style="font-family:'Inter','Noto Sans JP',sans-serif; font-weight:500; font-size:14px; letter-spacing:0.01em; color:#1A1A1A;" class="hover:opacity-60 transition-opacity">お知らせ</a>
        <a href="/company"  style="font-family:'Inter','Noto Sans JP',sans-serif; font-weight:500; font-size:14px; letter-spacing:0.01em; color:#1A1A1A;" class="hover:opacity-60 transition-opacity">会社情報</a>
      </nav>

      <!-- 右：2ボタン（資料DL=アウトライン、LINE=メイン） -->
      <div class="hidden md:flex items-center gap-3">
        <a href="/download"
           class="inline-flex items-center gap-1.5 text-sm transition-colors hover:bg-blue-50"
           style="border:1.5px solid #1B5EBE; color:#1B5EBE; font-weight:600; letter-spacing:0.01em; padding:9px 16px; border-radius:6px;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          資料ダウンロード
        </a>
        <a href="https://lin.ee/VOiIxYB"
           target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-1.5 text-sm text-white transition-opacity hover:opacity-90"
           style="background-color:#06C755; font-weight:600; letter-spacing:0.01em; padding:10px 18px; border-radius:6px;">
          <svg width="14" height="14" viewBox="0 0 48 48" fill="white">
            <path d="M24 4C12.95 4 4 11.86 4 21.5c0 5.5 2.87 10.4 7.36 13.6L9 40l6.5-2.8A22.4 22.4 0 0024 39c11.05 0 20-7.86 20-17.5S35.05 4 24 4z"/>
          </svg>
          LINEで無料相談
        </a>
      </div>

      <!-- ハンバーガー -->
      <button id="menu-btn" class="md:hidden p-2 text-gray-700" aria-label="メニューを開く" aria-expanded="false" aria-controls="mobile-menu">
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- モバイルメニュー -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-b border-gray-100 px-6 py-5" aria-hidden="true">
    <nav class="flex flex-col gap-4 mb-5">
      <a href="/service"  class="text-sm text-gray-700" style="font-weight:500;">事業内容</a>
      <a href="/case"     class="text-sm text-gray-700" style="font-weight:500;">実績一覧</a>
      <a href="/news"     class="text-sm text-gray-700" style="font-weight:500;">お知らせ</a>
      <a href="/company"  class="text-sm text-gray-700" style="font-weight:500;">会社情報</a>
      <a href="/download" class="text-sm text-gray-700" style="font-weight:500;">資料ダウンロード</a>
    </nav>
    <a href="https://lin.ee/VOiIxYB"
       target="_blank" rel="noopener noreferrer"
       class="flex items-center justify-center gap-2 text-sm font-semibold py-3 text-white"
       style="background-color:#06C755; border-radius:6px; letter-spacing:0.01em;">
      <svg width="14" height="14" viewBox="0 0 48 48" fill="white">
        <path d="M24 4C12.95 4 4 11.86 4 21.5c0 5.5 2.87 10.4 7.36 13.6L9 40l6.5-2.8A22.4 22.4 0 0024 39c11.05 0 20-7.86 20-17.5S35.05 4 24 4z"/>
      </svg>
      LINEで無料相談
    </a>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn')!
  const menu = document.getElementById('mobile-menu')!
  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden')
    menu.classList.toggle('hidden')
    menu.setAttribute('aria-hidden', isOpen ? 'true' : 'false')
    btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true')
  })
  const nav = document.getElementById('site-nav')!
  window.addEventListener('scroll', () => {
    nav.classList.toggle('shadow-sm', window.scrollY > 10)
  })
</script>
