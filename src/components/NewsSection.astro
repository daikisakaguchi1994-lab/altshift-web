---
const articles = [
  {
    date: '2026/4/15',
    category: 'お知らせ',
    categoryColor: 'blue',
    title: 'AltShift公式サイトをオープンしました',
    body: 'AIという道具を、中小企業の味方に。AltShiftの公式サイトが本日オープンいたしました。',
  },
  {
    date: '2026/4/10',
    category: 'サービス',
    categoryColor: 'green',
    title: '外部CAIOサービスの提供を開始しました',
    body: '週1〜2回の伴走型AI化支援サービスを正式に開始いたしました。',
  },
  {
    date: '2026/3/30',
    category: '実績',
    categoryColor: 'purple',
    title: '三栄リフォーム様のWeb制作・LINE自動化が完了しました',
    body: '福岡市内のリフォーム会社様のデジタル化を支援いたしました。',
  },
]

const badgeStyles: Record<string, string> = {
  blue:   `background:rgba(27,94,190,0.06); color:var(--color-primary); border:1px solid rgba(27,94,190,0.2);`,
  green:  `background:rgba(6,199,85,0.06); color:#059669; border:1px solid rgba(6,199,85,0.2);`,
  purple: `background:rgba(139,92,246,0.06); color:#7C3AED; border:1px solid rgba(139,92,246,0.2);`,
}
---

<section class="relative overflow-hidden section-padding" style="background:var(--color-bg); border-top:1px solid var(--color-border);">
  <p class="absolute top-0 left-4 ghost-text" aria-hidden="true">NEWS</p>

  <div class="relative max-w-6xl mx-auto">
    <div class="mb-12 reveal">
      <p class="section-label mb-2">— お知らせ</p>
      <h2 class="heading-lg">NEWS</h2>
    </div>

    <div class="max-w-3xl flex flex-col mb-10">
      {articles.map((a) => (
        <article class="reveal py-6" style="border-bottom:1px solid var(--color-border);">
          <div class="flex flex-wrap items-center gap-3 mb-2">
            <time class="text-xs" style="color:var(--color-ink-muted);">{a.date}</time>
            <span class="text-xs font-medium px-3 py-1 rounded" style={badgeStyles[a.categoryColor]}>
              {a.category}
            </span>
          </div>
          <p class="font-medium text-sm mb-1" style="color:var(--color-ink);">{a.title}</p>
          <p class="text-xs leading-relaxed" style="color:var(--color-ink-muted);">{a.body}</p>
        </article>
      ))}
    </div>

    <div class="reveal">
      <a href="/news" class="btn-outline">
        すべてのお知らせを見る
      </a>
    </div>
  </div>
</section>
