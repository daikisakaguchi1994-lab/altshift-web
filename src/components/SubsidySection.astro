---
---

<section id="subsidies" class="section-padding" style="background:var(--color-bg-subtle);">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <p class="section-label mb-4" style="text-transform:uppercase; letter-spacing:0.1em; color:var(--color-accent);">Subsidy Support</p>
      <h2 class="heading-lg mb-4">
        補助金を活用できる<br />場合があります。
      </h2>
      <p class="body-md max-w-3xl mx-auto">
        ものづくり補助金・省力化投資補助金など、貴社に最適な制度の活用をサポート。
        AltShiftは適合診断と情報提供を、申請実務は提携行政書士が責任を持って対応します。
      </p>
    </div>

    <!-- 福岡県補助金ハイライトカード -->
    <div class="reveal t-card p-6 mb-10" style="border-color:var(--color-primary); border-width:2px; background:var(--color-primary-light);">
      <div class="flex flex-col md:flex-row items-start md:items-center gap-4">
        <div class="flex items-center gap-3 flex-shrink-0">
          <span style="display:inline-flex; align-items:center; gap:4px; background:var(--color-primary); color:#FFFFFF; font-weight:700; font-size:12px; padding:4px 10px; border-radius:4px;">★ 最優先</span>
          <span style="display:inline-flex; align-items:center; gap:4px; background:var(--color-accent); color:#FFFFFF; font-weight:700; font-size:12px; padding:4px 10px; border-radius:4px;">福岡限定</span>
        </div>
        <div class="flex-1">
          <h3 class="heading-sm mb-1">福岡県中小企業生産性向上・賃上げ緊急支援補助金</h3>
          <p class="body-sm" style="color:var(--color-ink);">
            補助率最大<strong style="color:var(--color-primary);">3/4</strong>・上限<strong>2,250万円</strong>
            — 他の国庫補助金（1/2〜2/3）を上回る、福岡県事業者だけが使える制度です。
          </p>
        </div>
      </div>
      <p class="text-sm mt-3" style="color:var(--color-ink-sub);">
        福岡発AltShiftだから提案できる、補助率最大3/4の福岡県補助金。他県の事業者は利用できません。
      </p>
    </div>

    <!-- 主要4補助金テーブル -->
    <div class="reveal" style="background:#FFFFFF; border-radius:12px; border:1px solid var(--color-border); padding:24px; margin-bottom:40px; overflow-x:auto;">
      <table style="width:100%; font-size:14px; border-collapse:collapse;">
        <thead>
          <tr style="border-bottom:2px solid var(--color-border);">
            <th style="text-align:left; padding:0 16px 12px 0; font-weight:600; color:var(--color-ink);">補助金名</th>
            <th style="text-align:left; padding:0 16px 12px 0; font-weight:600; color:var(--color-ink);">補助上限</th>
            <th style="text-align:left; padding:0 16px 12px 0; font-weight:600; color:var(--color-ink);">補助率</th>
            <th style="text-align:left; padding:0 0 12px 0; font-weight:600; color:var(--color-ink);">対応分野</th>
          </tr>
        </thead>
        <tbody>
          <tr style="border-bottom:1px solid var(--color-border); background:var(--color-primary-light);">
            <td style="padding:12px 16px 12px 0;">
              <span style="font-weight:700; color:var(--color-primary);">福岡県中小企業生産性向上補助金</span>
              <span style="display:inline-block; margin-left:6px; background:var(--color-accent); color:#FFFFFF; font-size:11px; font-weight:700; padding:2px 6px; border-radius:3px;">福岡限定</span>
            </td>
            <td style="padding:12px 16px 12px 0;">最大2,250万円</td>
            <td style="padding:12px 16px 12px 0;"><strong style="color:var(--color-primary);">最大3/4</strong></td>
            <td style="padding:12px 0; color:var(--color-ink-sub);">AI導入・DX推進全般</td>
          </tr>
          <tr style="border-bottom:1px solid var(--color-border);">
            <td style="padding:12px 16px 12px 0; font-weight:700; color:var(--color-primary);">ものづくり補助金 第23次</td>
            <td style="padding:12px 16px 12px 0;">最大4,000万円</td>
            <td style="padding:12px 16px 12px 0;">1/2〜2/3</td>
            <td style="padding:12px 0; color:var(--color-ink-sub);">カスタムAIシステム開発</td>
          </tr>
          <tr style="border-bottom:1px solid var(--color-border);">
            <td style="padding:12px 16px 12px 0; font-weight:700; color:var(--color-primary);">省力化投資補助金〈一般型〉</td>
            <td style="padding:12px 16px 12px 0;">最大1億円</td>
            <td style="padding:12px 16px 12px 0;">1/3〜2/3</td>
            <td style="padding:12px 0; color:var(--color-ink-sub);">業務効率化・自動化</td>
          </tr>
          <tr>
            <td style="padding:12px 16px 12px 0; font-weight:700; color:var(--color-primary);">新事業進出補助金 第4回</td>
            <td style="padding:12px 16px 12px 0;">最大7,000万円</td>
            <td style="padding:12px 16px 12px 0;">1/2</td>
            <td style="padding:12px 0; color:var(--color-ink-sub);">新サービス・新事業のAI実装</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- 業種別活用ティーザー -->
    <div class="mb-16">
      <h3 class="heading-md text-center mb-8 reveal">業種別 補助金 × AI活用イメージ</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger">
        <!-- 美容クリニック -->
        <div class="reveal t-card p-6">
          <div class="flex items-center gap-3 mb-4">
            <div style="width:40px; height:40px; border-radius:10px; background:var(--color-primary-light); display:flex; align-items:center; justify-content:center;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M8 2v4"/><path d="M16 2v4"/><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M12 10v6"/><path d="M9 13h6"/>
              </svg>
            </div>
            <h4 class="heading-sm">美容クリニック・美容皮膚科</h4>
          </div>
          <p class="body-sm mb-3">AI画像比較（before/after）、キャンセル率予測、CRM/LTV分析で患者体験と経営効率を同時に向上。</p>
          <div style="display:flex; flex-wrap:wrap; gap:6px; margin-bottom:12px;">
            <span class="tag-outline">省力化投資補助金</span>
            <span class="tag-outline">推定負担 200〜300万円</span>
          </div>
          <a href="/contact" class="neon-link">
            詳しくご相談
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>

        <!-- 歯科 -->
        <div class="reveal t-card p-6">
          <div class="flex items-center gap-3 mb-4">
            <div style="width:40px; height:40px; border-radius:10px; background:var(--color-primary-light); display:flex; align-items:center; justify-content:center;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <h4 class="heading-sm">歯科（自由診療強化型）</h4>
          </div>
          <p class="body-sm mb-3">Web問診→AI判別、矯正・インプラント教育動画配信、自費契約クロージング支援で自由診療比率を強化。</p>
          <div style="display:flex; flex-wrap:wrap; gap:6px; margin-bottom:12px;">
            <span class="tag-outline">省力化投資補助金</span>
            <span class="tag-outline">推定負担 200〜300万円</span>
          </div>
          <a href="/contact" class="neon-link">
            詳しくご相談
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>

        <!-- 建設・リフォーム -->
        <div class="reveal t-card p-6">
          <div class="flex items-center gap-3 mb-4">
            <div style="width:40px; height:40px; border-radius:10px; background:var(--color-primary-light); display:flex; align-items:center; justify-content:center;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
            </div>
            <h4 class="heading-sm">建設・リフォーム業（中堅）</h4>
          </div>
          <p class="body-sm mb-3">AI見積生成、施工管理自動化、顧客対応LINE BOTで属人化を解消し、受注キャパシティを拡大。</p>
          <div style="display:flex; flex-wrap:wrap; gap:6px; margin-bottom:12px;">
            <span class="tag-outline">ものづくり補助金</span>
            <span class="tag-outline">推定負担 300〜500万円</span>
          </div>
          <a href="/contact" class="neon-link">
            詳しくご相談
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- 三層モデル可視化 -->
    <div class="mb-12">
      <h3 class="heading-md text-center mb-8 reveal">役割分担の明確化（三層モデル）</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 stagger">
        <div class="reveal" style="background:var(--color-primary-light); border:1px solid rgba(27,94,190,0.3); border-radius:12px; padding:24px;">
          <p style="font-size:12px; font-weight:700; color:var(--color-primary); letter-spacing:0.1em; margin-bottom:8px;">LAYER 1</p>
          <h4 class="heading-sm mb-2">情報提供</h4>
          <p class="body-sm mb-3">補助金一覧、要件解説、活用事例の提供</p>
          <p style="font-size:13px; font-weight:600; color:var(--color-primary);">AltShift が担当</p>
        </div>
        <div class="reveal" style="background:var(--color-primary-light); border:1px solid rgba(27,94,190,0.3); border-radius:12px; padding:24px;">
          <p style="font-size:12px; font-weight:700; color:var(--color-primary); letter-spacing:0.1em; margin-bottom:8px;">LAYER 2</p>
          <h4 class="heading-sm mb-2">適合診断</h4>
          <p class="body-sm mb-3">貴社に最適な補助金を判定する意思決定支援</p>
          <p style="font-size:13px; font-weight:600; color:var(--color-primary);">AltShift が担当</p>
        </div>
        <div class="reveal" style="background:var(--color-bg-subtle); border:1px solid rgba(14,158,150,0.3); border-radius:12px; padding:24px;">
          <p style="font-size:12px; font-weight:700; color:var(--color-accent); letter-spacing:0.1em; margin-bottom:8px;">LAYER 3</p>
          <h4 class="heading-sm mb-2">申請実務</h4>
          <p class="body-sm mb-3">書類作成・代理提出（行政書士法独占業務）</p>
          <p style="font-size:13px; font-weight:600; color:var(--color-text);">提携行政書士が担当</p>
        </div>
      </div>
    </div>

    <!-- 注意事項 -->
    <aside class="reveal" style="border-left:4px solid var(--color-accent); background:#FFFFFF; padding:24px; margin-bottom:40px; border-radius:0 12px 12px 0;">
      <p class="heading-sm mb-3">本サービスについて</p>
      <ul class="body-sm" style="color:var(--color-ink-sub); display:flex; flex-direction:column; gap:8px;">
        <li>・AltShift は申請書類の作成・代理提出を行いません</li>
        <li>・申請実務は提携する行政書士・中小企業診断士が担当します（改正行政書士法第19条遵守）</li>
        <li>・採択を保証するものではありません</li>
        <li>・補助金は精算払い（後払い）です</li>
        <li>・診断ツールは意思決定支援を目的とした情報提供です</li>
        <li>・福岡県中小企業生産性向上補助金の活用には、福岡県中小企業DX推進センターによる伴走支援が前提となります。AltShiftは同センターとの連携を準備中であり、補助金活用までの一貫サポートを目指しています</li>
        <li>・2026年5月時点の情報。最新の公募要領は各補助金公式サイトでご確認ください</li>
      </ul>
    </aside>

    <!-- 段階的誘導CTA -->
    <div class="reveal flex flex-wrap gap-4 justify-center">
      <a href="/contact" class="btn-primary">
        無料相談（30分）を予約する
      </a>
      <a href="/contact?type=subsidy-doc" class="btn-secondary-ghost">
        詳細資料を請求する
      </a>
    </div>
  </div>
</section>
