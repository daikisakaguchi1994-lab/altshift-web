---
import '../styles/global.css'

export interface Props {
  title?: string
  description?: string
  schemaData?: object
}

const {
  title = 'AltShift | 福岡の中小企業向けAI導入支援・外部CAIOサービス',
  description = '福岡を拠点に、リフォーム・建設業などの中小企業向けにAI導入支援を提供。外部CAIOとして週1〜2回企業に入り込み、AI戦略の策定から実装まで一貫してサポートします。',
  schemaData,
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, 'https://altshift.jp').href
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    {schemaData && (
      <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(schemaData)}</script>`} />
    )}

    <!-- LocalBusiness Schema -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "AltShift",
      "description": "福岡拠点の中小企業向けAI導入支援・外部CAIOサービス",
      "url": "https://altshift.jp",
      "email": "contact@altshift.jp",
      "address": {"@type": "PostalAddress", "addressLocality": "福岡市", "addressRegion": "福岡県", "addressCountry": "JP"},
      "founder": {"@type": "Person", "name": "ディーチャー（坂口 大輝）", "jobTitle": "代表 / External CAIO"},
      "priceRange": "¥¥",
      "openingHours": "Mo-Fr 10:00-18:00"
    }
    </script>
  </head>
  <body>
    <slot />

    <!-- モバイル固定CTA（LINE） -->
    <a href="https://lin.ee/VOiIxYB"
       target="_blank"
       rel="noopener noreferrer"
       class="md:hidden fixed bottom-0 left-0 right-0 z-50 flex items-center justify-center gap-2 py-4 text-white font-medium text-sm"
       style="background-color: #1B5EBE;">
      <svg width="16" height="16" viewBox="0 0 48 48" fill="white">
        <path d="M24 4C12.95 4 4 11.86 4 21.5c0 5.5 2.87 10.4 7.36 13.6L9 40l6.5-2.8A22.4 22.4 0 0024 39c11.05 0 20-7.86 20-17.5S35.05 4 24 4z"/>
      </svg>
      LINEで無料相談（無料）
    </a>

    <script>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
