---
import '../styles/global.css'

export interface Props {
  title?: string
  description?: string
  ogImage?: string
  schemaData?: object
}

const {
  title = 'AltShift｜福岡の中小企業向けAIコンサルティング・AI導入支援',
  description = '福岡発、中小企業専門のAIコンサルティング。AI導入戦略からシステム開発・Web制作・LINE自動化まで一貫支援。月額3万円〜。無料相談受付中。',
  ogImage = '/images/og-default.png',
  schemaData,
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, 'https://altshift.jp').href
const ogImageURL = new URL(ogImage, 'https://altshift.jp').href
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:site_name" content="AltShift" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <link rel="alternate" hreflang="ja" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (t === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        } else {
          localStorage.removeItem('theme');
          document.documentElement.removeAttribute('data-theme');
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    {schemaData && (
      <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(schemaData)}</script>`} />
    )}

    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "AltShift",
      "alternateName": "オルトシフト",
      "url": "https://altshift.jp",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://altshift.jp/blog?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
    </script>

    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": ["LocalBusiness", "ProfessionalService"],
      "name": "AltShift（オルトシフト）",
      "alternateName": "AltShift",
      "description": "福岡発、中小企業専門のAIコンサルティング。AI導入戦略からシステム開発・Web制作・LINE自動化まで一貫支援。",
      "url": "https://altshift.jp",
      "email": "contact@altshift.jp",
      "image": "https://altshift.jp/images/og-default.png",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "福岡市",
        "addressRegion": "福岡県",
        "addressCountry": "JP"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 33.5904,
        "longitude": 130.4017
      },
      "areaServed": [
        {"@type": "City", "name": "福岡市"},
        {"@type": "State", "name": "福岡県"},
        {"@type": "Country", "name": "日本"}
      ],
      "founder": {
        "@type": "Person",
        "name": "坂口 大輝",
        "jobTitle": "代表 / AI Consultant",
        "url": "https://altshift.jp/company"
      },
      "knowsAbout": ["AI導入支援", "AIコンサルティング", "生成AI活用", "DXコンサルティング", "Webマーケティング", "LINE自動化", "SEO対策", "GEO対策"],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "AIコンサルティングサービス",
        "itemListElement": [
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "AI導入コンサルティング", "description": "経営課題の分析からAIロードマップ策定まで最短2週間"}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "カスタムAIシステム開発", "description": "業務効率化・コスト削減を実現するAIシステムを12週間以内に本番稼働"}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Web制作 × SEO/GEO", "description": "Google・AI検索に選ばれるWebサイト制作"}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "LINE自動化", "description": "24時間365日自動応答で機会損失ゼロ"}}
        ]
      },
      "priceRange": "月額3万円〜8万円",
      "openingHours": "Mo-Fr 10:00-18:00",
      "sameAs": ["https://lin.ee/VOiIxYB"]
    }
    </script>
  </head>
  <body>
    <slot />

    <!-- Mobile fixed CTA -->
    <a href="/contact"
       class="md:hidden fixed bottom-0 left-0 right-0 z-50 flex items-center justify-center gap-2 py-4 text-white font-semibold text-sm"
       style="background-color: #1456FB;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      無料相談する
    </a>

    <script>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

      // Counter animation
      document.querySelectorAll('[data-count]').forEach(el => {
        const io = new IntersectionObserver(([entry]) => {
          if (!entry.isIntersecting) return;
          io.unobserve(el);
          const target = parseInt(el.getAttribute('data-count') || '0');
          const suffix = el.getAttribute('data-suffix') || '';
          const duration = 1500;
          const start = performance.now();
          function tick(now: number) {
            const progress = Math.min((now - start) / duration, 1);
            const ease = 1 - Math.pow(1 - progress, 3);
            el.textContent = Math.round(target * ease) + suffix;
            if (progress < 1) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
        }, { threshold: 0.5 });
        io.observe(el);
      });
    </script>
  </body>
</html>
