---
import Layout from '../../layouts/Layout.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }))
}

const { post } = Astro.props
const { Content } = await render(post)

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  dateModified: (post.data.updated || post.data.date).toISOString(),
  author: { '@type': 'Person', name: '坂口 大輝', jobTitle: 'AI Consultant', url: 'https://altshift.jp/company' },
  publisher: { '@type': 'Organization', name: 'AltShift', url: 'https://altshift.jp' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `https://altshift.jp/blog/${post.id}` },
}
---

<Layout
  title={`${post.data.title} | AltShift ブログ`}
  description={post.data.description}
  schemaData={schemaData}
>
  <Nav />
  <main>
    <section class="section-padding" style="background:var(--color-bg); padding-top:140px;">
      <article class="max-w-3xl mx-auto px-6 lg:px-8">
        <div class="mb-12 reveal">
          <a href="/blog" class="text-xs font-semibold mb-6 inline-block" style="color:var(--color-blue); letter-spacing:0.05em;">← ブログ一覧</a>
          <div class="flex flex-wrap gap-2 mb-4">
            {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
          <h1 class="heading-hero" style="font-size:clamp(24px,3.5vw,40px); line-height:1.4;">{post.data.title}</h1>
          <div class="flex items-center gap-4 mt-6">
            <p class="text-sm" style="color:var(--color-ink-sub);">
              {post.data.date.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
            <span style="color:var(--color-border-card);">|</span>
            <p class="text-sm" style="color:var(--color-ink-sub);">坂口 大輝</p>
          </div>
        </div>

        <div class="prose reveal">
          <Content />
        </div>

        <!-- CTA -->
        <div class="mt-16 reveal t-card p-8 text-center">
          <h3 class="heading-md mb-3">AI導入のご相談は無料です</h3>
          <p class="body-sm mb-6">記事に関するご質問や、貴社のAI導入についてお気軽にご相談ください。</p>
          <a href="/contact" class="btn-neon">無料で相談する</a>
        </div>
      </article>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  .prose { color: var(--color-ink-sub); line-height: 1.9; font-size: 16px; }
  .prose h2 { color: var(--color-ink); font-weight: 700; font-size: 24px; margin-top: 48px; margin-bottom: 16px; letter-spacing: -0.02em; }
  .prose h3 { color: var(--color-ink); font-weight: 600; font-size: 19px; margin-top: 36px; margin-bottom: 12px; }
  .prose p { margin-bottom: 20px; }
  .prose ul, .prose ol { margin-bottom: 20px; padding-left: 24px; }
  .prose li { margin-bottom: 8px; }
  .prose strong { color: var(--color-ink); font-weight: 600; }
  .prose a { color: var(--color-blue); text-decoration: underline; }
  .prose table { width: 100%; border-collapse: collapse; margin-bottom: 24px; font-size: 14px; }
  .prose th, .prose td { padding: 10px 14px; text-align: left; border-bottom: 1px solid var(--color-border); }
  .prose th { color: var(--color-ink); font-weight: 600; background: var(--color-bg-card); }
  .prose blockquote { border-left: 3px solid var(--color-blue); padding-left: 16px; margin: 24px 0; font-style: italic; color: var(--color-ink-dim); }
</style>
