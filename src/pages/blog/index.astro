---
import Layout from '../../layouts/Layout.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
---

<Layout
  title="ブログ | AI導入・SEO/GEO・LINE自動化の最新情報 | AltShift"
  description="中小企業のAI導入、SEO/GEO対策、LINE自動化に関する最新情報・ノウハウ・事例を発信。福岡のAIコンサルティング AltShift。"
>
  <Nav />
  <main>
    <section class="section-padding" style="background:var(--color-bg); padding-top:140px;">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="mb-14 reveal">
          <div class="accent-line mb-6"></div>
          <h1 class="heading-hero" style="font-size:clamp(28px,4vw,48px);">ブログ</h1>
          <p class="body-lg mt-4">AI導入・SEO/GEO・LINE自動化の最新情報とノウハウ</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 stagger">
          {posts.map(post => (
            <a href={`/blog/${post.id}`} class="reveal t-card overflow-hidden" style="text-decoration:none;">
              <div style="aspect-ratio:16/9; background:var(--color-bg-elevated); display:flex; align-items:center; justify-content:center; position:relative;">
                {post.data.image
                  ? <img src={post.data.image} alt={post.data.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
                  : <div style="width:100px;height:100px;border-radius:50%;background:radial-gradient(circle, rgba(20,86,251,0.2) 0%, transparent 70%);filter:blur(20px);"></div>
                }
                <div class="flex gap-2" style="position:absolute; top:12px; left:12px;">
                  {post.data.tags.slice(0, 2).map(tag => <span class="tag">{tag}</span>)}
                </div>
              </div>
              <div class="p-6">
                <p class="text-xs mb-2" style="color:var(--color-blue); font-weight:600;">
                  {post.data.date.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
                </p>
                <h2 class="heading-sm mb-2" style="line-height:1.5;">{post.data.title}</h2>
                <p class="body-sm" style="display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
                  {post.data.description}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
