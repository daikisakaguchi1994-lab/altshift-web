---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

const gradLabel = "font-family:'Inter',sans-serif; font-weight:700; font-size:12px; letter-spacing:0.2em; text-transform:uppercase; background:linear-gradient(135deg,#1B5EBE,#4A90D9); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;"
const gradDeco  = "font-family:'Inter',sans-serif; font-weight:900; font-size:clamp(60px,10vw,120px); letter-spacing:-0.05em; opacity:0.04; background:linear-gradient(135deg,#1B5EBE,#4A90D9); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; line-height:1; pointer-events:none; user-select:none;"

const cases = [
  {
    title: '三栄リフォーム × AltShift',
    desc: 'リフォーム会社向けにAI時代の検索対応Webサイトを高速実装。SEO/GEO対策により、ChatGPTやGoogleでの露出を強化。',
    tags: ['Web制作', 'SEO/GEO'],
    url: 'https://sanei-reform.vercel.app',
    period: '2026年3月',
  },
  {
    title: "BAR Kar's × AltShift",
    desc: '中洲のアフターバー。デジタルメニューとLINE自動応答を導入し、営業時間外の問い合わせ対応を自動化。',
    tags: ['Web制作', 'LINE自動化'],
    url: null,
    period: '2026年3月',
  },
]
---

<Layout title="実績一覧 | AltShift" description="AltShiftの実績一覧。Web制作・AI導入支援の事例をご紹介します。">
  <Nav />
  <main>
    <section class="relative overflow-hidden" style="background:#FFFFFF; padding:96px 24px;">
      <p class="absolute top-4 left-6 select-none pointer-events-none" style={gradDeco}>CASE</p>

      <div class="relative max-w-6xl mx-auto">
        <div class="mb-14 reveal">
          <p style={gradLabel} class="mb-2">— 実績一覧</p>
          <h1 style="font-size:clamp(28px,4vw,40px); color:#1A1A1A;">CASE</h1>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {cases.map(c => (
            <div class="reveal bg-white overflow-hidden hover:shadow-md transition-shadow"
                 style="border-top:3px solid #1B5EBE; border-left:1px solid #E5E5E5; border-right:1px solid #E5E5E5; border-bottom:1px solid #E5E5E5; border-radius:8px;">
              <div class="w-full h-44 flex items-center justify-center"
                   style="background:#F4F4F4; border-bottom:1px solid #E5E5E5;">
                <span style="font-size:12px; color:#6B6B6B; letter-spacing:0.1em; text-transform:uppercase;">Image</span>
              </div>
              <div class="p-6">
                <div class="flex flex-wrap gap-2 mb-3">
                  {c.tags.map(tag => (
                    <span style="font-size:11px; font-weight:500; padding:4px 10px; border:1px solid rgba(27,94,190,0.2); color:#1B5EBE; background:rgba(27,94,190,0.06); border-radius:4px;">
                      {tag}
                    </span>
                  ))}
                </div>
                <p style="font-size:12px; color:#6B6B6B; margin-bottom:4px;">{c.period}</p>
                <h3 style="font-size:15px; font-weight:700; color:#1A1A1A; margin-bottom:8px; letter-spacing:-0.01em;">{c.title}</h3>
                <p style="font-size:14px; color:#6B6B6B; line-height:1.8; font-weight:300; margin-bottom:16px;">{c.desc}</p>
                {c.url && (
                  <a href={c.url} target="_blank" rel="noopener noreferrer"
                     style="font-size:13px; font-weight:600; color:#1B5EBE; text-decoration:none;" class="hover:underline">
                    サイトを見る →
                  </a>
                )}
              </div>
            </div>
          ))}

          <div class="reveal bg-white flex flex-col items-center justify-center p-8"
               style="border:1px dashed #E5E5E5; border-radius:8px; min-height:300px;">
            <p style="font-size:12px; font-weight:600; color:#6B6B6B; letter-spacing:0.15em; text-transform:uppercase; margin-bottom:8px;">Coming Soon</p>
            <p style="font-size:14px; color:#6B6B6B; font-weight:300;">近日公開</p>
          </div>
        </div>

        <div class="mt-14 reveal bg-white flex flex-col md:flex-row items-center justify-between gap-6 p-8"
             style="border:1px solid #E5E5E5; border-radius:8px;">
          <div>
            <p style={gradLabel} class="mb-1">ご相談はお気軽に</p>
            <p style="font-weight:700; font-size:18px; color:#1A1A1A; margin-bottom:4px;">お客様の課題に合わせてご提案します</p>
            <p style="font-size:14px; color:#6B6B6B; font-weight:300;">まずは話を聞かせてください。</p>
          </div>
          <a href="https://lin.ee/VOiIxYB"
             target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 text-sm text-white transition-opacity hover:opacity-90 whitespace-nowrap flex-shrink-0"
             style="background:#1B5EBE; font-weight:600; letter-spacing:0.05em; padding:12px 24px; border-radius:4px;">
            お問い合わせ →
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
