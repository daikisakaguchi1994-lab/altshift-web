---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

const cases = [
  {
    company: '三栄リフォーム',
    title: '三栄リフォーム × AltShift',
    tags: ['Web制作', 'SEO/GEO', 'LINE自動化'],
    desc: 'AI時代の検索対応Webサイトを実装。SEO/GEO対策により、ChatGPTやGoogleでの露出を強化。',
    result: 'AI検索・Googleマップ双方で上位露出',
    image: '/images/cases/sanei-reform.jpg',
    slug: '/case/sanei-reform',
    url: 'https://sanei-reform.vercel.app',
    period: '2026年3月',
  },
  {
    company: "BAR Kar's",
    title: "BAR Kar's × AltShift",
    tags: ['Web制作', 'LINE自動化', 'デジタルメニュー'],
    desc: '中洲のアフターバー。デジタルメニューとLINE自動応答を導入し、営業時間外の問い合わせ対応を自動化。',
    result: '営業時間外の問い合わせ対応を完全自動化',
    image: '/images/cases/bar-kars.jpg',
    slug: '/case/bar-kars',
    url: null,
    period: '2026年3月',
  },
  {
    company: '株式会社伸明',
    title: '株式会社伸明 × AltShift',
    tags: ['GEO最適化', 'SEO対策', 'HP制作'],
    desc: 'Googleマップへの上位表示およびSEO対策を一貫支援。検索・地図双方からの集客基盤を構築。',
    result: 'Googleマップ上位表示・オーガニック流入増加',
    image: '/images/cases/shinmei.jpg',
    slug: '/case/shinmei',
    url: null,
    period: '2026年4月',
  },
  {
    company: '株式会社BEGINS',
    title: '株式会社BEGINS × AltShift',
    tags: ['コールセンター自動化', '応募者管理', 'HR-Tech'],
    desc: 'コールセンター集計の完全自動化・求人応募者管理・面接日程の自動設定。採用〜オペレーション領域をAI化。',
    result: '採用業務工数50%削減・集計作業完全自動化',
    image: '/images/cases/begins.jpg',
    slug: '/case/begins',
    url: null,
    period: '2026年4月',
  },
]
---

<Layout title="AI導入事例 | 福岡の中小企業向けAIコンサルティング AltShift" description="福岡の中小企業によるAI導入事例。採用業務工数50%削減、コールセンター自動化、SEO/GEO対策の実績を紹介。">
  <Nav />
  <main>
    <section class="section-padding" style="background:var(--color-bg); padding-top:140px;">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="mb-14 reveal">
          <div class="accent-line mb-6"></div>
          <h1 class="heading-hero" style="font-size:clamp(28px,4vw,48px);">導入事例</h1>
          <p class="body-lg mt-4">実践的なAI導入で、ビジネスを変革した企業たち。</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 stagger">
          {cases.map(c => (
            <a href={c.slug} class="reveal t-card overflow-hidden block" style="text-decoration:none; color:inherit; transition:transform 0.2s, border-color 0.2s;" onmouseover="this.style.transform='translateY(-4px)';this.style.borderColor='rgba(216,255,0,0.3)'" onmouseout="this.style.transform='';this.style.borderColor=''">
              <div class="media-slot" style="aspect-ratio:16/9; position:relative;">
                <img src={c.image} alt={c.company} loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
                <div class="neon-glow-circle" style="bottom:15%; right:25%;"></div>
              </div>
              <div class="p-6">
                <div class="flex items-center justify-between mb-3">
                  <div class="flex flex-wrap gap-2">
                    {c.tags.map(tag => <span class="tag">{tag}</span>)}
                  </div>
                  <p class="text-xs flex-shrink-0 ml-2" style="color:var(--color-ink-dim);">{c.period}</p>
                </div>
                <h3 class="heading-sm mb-2">{c.title}</h3>
                <p class="body-sm mb-3">{c.desc}</p>
                <div class="flex items-start gap-2 mb-4">
                  <div style="width:6px; height:6px; border-radius:50%; background:var(--color-neon); flex-shrink:0; margin-top:6px;"></div>
                  <p class="text-xs" style="color:var(--color-ink-muted);">{c.result}</p>
                </div>
                <span class="neon-link" style="font-size:13px;">詳しく見る <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
              </div>
            </a>
          ))}
        </div>

        <!-- CTA -->
        <div class="mt-16 reveal t-card flex flex-col md:flex-row items-center justify-between gap-6 p-8">
          <div>
            <h3 class="heading-md mb-2">お客様の課題に合わせてご提案します</h3>
            <p class="body-sm">まずは話を聞かせてください。</p>
          </div>
          <a href="/contact" class="btn-neon whitespace-nowrap flex-shrink-0">
            お問い合わせ
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
