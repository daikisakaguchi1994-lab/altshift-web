---
import Layout from '../../layouts/Layout.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'

// Disclosure toggle: set PUBLIC_TYD_DISCLOSURE=true to show real company name
const disclosed = import.meta.env.PUBLIC_TYD_DISCLOSURE === 'true'
const companyName = disclosed ? 'TYDロジスティクス株式会社' : '大手物流企業A社'
const companyShort = disclosed ? 'TYDロジスティクス' : '物流企業A社'
const heroTitle = disclosed ? 'TYDロジスティクス × AltShift' : '物流企業A社 × AltShift'
const publishDate = '2026年5月'

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `${heroTitle} — 物流現場のAI業務自動化事例`,
  description: '物流現場の属人化を解消。LINE Bot＋配車システムで業務をAI化した導入事例。',
  author: { '@type': 'Organization', name: 'AltShift', url: 'https://altshift.jp' },
  publisher: { '@type': 'Organization', name: 'AltShift', url: 'https://altshift.jp' },
  datePublished: '2026-05-01',
}
---

<Layout
  title={`${heroTitle} | 物流AI化事例 | AltShift 福岡`}
  description={`${companyShort}の物流業務をAIで自動化。LINE Bot＋配車システムで属人化を解消し、業務工数を大幅削減。省力化投資補助金活用の事例。`}
  schemaData={schemaData}
>
  <Nav />
  <main>

    <!-- ========== HERO ========== -->
    <section class="relative overflow-hidden" style="min-height:70vh; display:flex; align-items:center;">
      <div class="hero-bg">
        <div class="orb orb-neon"></div>
        <div class="orb orb-blue"></div>
        <div class="hero-grid"></div>
      </div>

      <div style="position:relative; z-index:10; max-width:1000px; margin:0 auto; padding:160px 48px 80px; width:100%;">
        <a href="/case" class="text-xs font-semibold mb-6 inline-block reveal" style="color:var(--color-brand);">← 事例一覧</a>

        <div class="reveal">
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="tag">物流</span>
            <span class="tag">AI業務自動化</span>
            <span class="tag">LINE自動化</span>
          </div>
          <h1 class="heading-hero" style="font-size:clamp(26px,4vw,48px);">{heroTitle}</h1>
          <p class="body-lg mt-4" style="max-width:640px;">
            物流現場の属人化を解消。LINE Bot＋配車システムで業務をAI化。
          </p>
          <p class="text-xs mt-4" style="color:var(--color-ink-dim);">公開日：{publishDate}</p>
        </div>
      </div>
    </section>

    <!-- ========== KEY NUMBERS (Tomoro式) ========== -->
    <section style="background:var(--color-bg); border-top:1px solid var(--color-border); border-bottom:1px solid var(--color-border);">
      <div class="max-w-5xl mx-auto px-6 lg:px-8 py-20">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center stagger">
          <div class="reveal">
            <p class="font-bold" style="font-size:clamp(48px,7vw,80px); color:var(--color-primary); line-height:1; letter-spacing:-0.03em;">●●<span class="text-2xl">週間</span></p>
            <p class="text-sm mt-2" style="color:var(--color-ink-dim);">本番投入までの期間</p>
          </div>
          <div class="reveal">
            <p class="font-bold" style="font-size:clamp(48px,7vw,80px); color:var(--color-primary); line-height:1; letter-spacing:-0.03em;">●●<span class="text-2xl">%</span></p>
            <p class="text-sm mt-2" style="color:var(--color-ink-dim);">業務工数削減率</p>
          </div>
          <div class="reveal">
            <p class="font-bold" style="font-size:clamp(48px,7vw,80px); color:var(--color-primary); line-height:1; letter-spacing:-0.03em;">24<span class="text-2xl">時間</span></p>
            <p class="text-sm mt-2" style="color:var(--color-ink-dim);">稼働継続時間</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== BEFORE / AFTER ========== -->
    <section class="section-padding" style="background:var(--color-bg);">
      <div class="max-w-5xl mx-auto px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

          <!-- Before -->
          <div class="reveal t-card p-8">
            <div class="flex items-center gap-3 mb-6">
              <div style="width:10px; height:10px; border-radius:50%; background:rgba(255,59,48,0.8);"></div>
              <h2 class="heading-md" style="color:rgba(255,59,48,0.9);">課題 — Before</h2>
            </div>
            <ul class="flex flex-col gap-4">
              {[
                '配車業務の属人化（特定スタッフに依存）',
                '受発注のLINE個別対応で営業時間外の取りこぼし',
                '与信判断・契約処理のExcel管理によるミス',
                '累積する事務作業による現場の疲弊',
              ].map(item => (
                <li class="flex items-start gap-3 body-sm">
                  <span style="color:rgba(255,59,48,0.8); flex-shrink:0; font-size:14px;">✕</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- After -->
          <div class="reveal t-card p-8" style="border-color:rgba(27,94,190,0.2); background:rgba(27,94,190,0.03);">
            <div class="flex items-center gap-3 mb-6">
              <div style="width:10px; height:10px; border-radius:50%; background:var(--color-primary);"></div>
              <h2 class="heading-md" style="color:var(--color-primary);">ソリューション — After</h2>
            </div>
            <ul class="flex flex-col gap-4">
              {[
                'LINE Botによる24時間自動応答・配車受付',
                'Google Sheets連携による配車情報の自動集約',
                'Claude APIによる与信判断アシスト',
                '自動見積・請求書生成パイプライン',
              ].map(item => (
                <li class="flex items-start gap-3 body-sm">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" style="flex-shrink:0; margin-top:3px;">
                    <path d="M8 12l3 3 5-5" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- ========== FEATURES (8 cards) ========== -->
    <section class="section-padding" style="background:var(--color-bg); border-top:1px solid var(--color-border);">
      <div class="max-w-5xl mx-auto px-6 lg:px-8">
        <h2 class="heading-lg text-center mb-16 reveal">実装機能</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 stagger">
          {[
            { num: '01', title: 'パートナー管理' },
            { num: '02', title: '双方向請求書PDF生成' },
            { num: '03', title: 'LINEブロードキャスト配車指示' },
            { num: '04', title: 'ドライバー情報管理' },
            { num: '05', title: '事故対応ロジック' },
            { num: '06', title: '外注発注管理' },
            { num: '07', title: '税計算自動化' },
            { num: '08', title: '月次レポート自動生成' },
          ].map(f => (
            <div class="reveal t-card p-5 text-center">
              <p class="text-xs font-bold mb-2" style="color:var(--color-primary); letter-spacing:0.05em;">{f.num}</p>
              <h3 class="text-sm font-bold" style="color:var(--color-ink);">{f.title}</h3>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== TECH STACK ========== -->
    <section class="section-padding" style="background:var(--color-bg);">
      <div class="max-w-4xl mx-auto px-6 lg:px-8">
        <h2 class="heading-lg text-center mb-12 reveal">技術スタック</h2>
        <div class="reveal t-card p-8">
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-6">
            {[
              { name: 'Vercel', sub: 'Hosting', icon: `<svg viewBox="0 0 24 24" width="28" height="28"><path d="M12 2L2 22h20L12 2z" fill="currentColor"/></svg>` },
              { name: 'Next.js', sub: 'TypeScript', icon: `<svg viewBox="0 0 24 24" width="28" height="28"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M8 8v8m0 0l8-8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>` },
              { name: 'LINE Bot SDK', sub: 'Messaging API', icon: `<svg viewBox="0 0 24 24" width="28" height="28"><path d="M12 2C6.48 2 2 5.82 2 10.5c0 2.93 1.95 5.5 4.86 7.04-.19.7-.68 2.6-.78 3-.13.52.19.51.4.37.17-.1 2.64-1.8 3.72-2.53.57.08 1.16.12 1.8.12 5.52 0 10-3.82 10-8.5S17.52 2 12 2z" fill="currentColor" opacity="0.85"/></svg>` },
              { name: 'Google Sheets', sub: 'API v4', icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><line x1="3" y1="9" x2="21" y2="9" stroke="currentColor" stroke-width="1"/><line x1="3" y1="15" x2="21" y2="15" stroke="currentColor" stroke-width="1"/><line x1="9" y1="3" x2="9" y2="21" stroke="currentColor" stroke-width="1"/></svg>` },
              { name: 'Claude API', sub: 'Anthropic', icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none"><path d="M16.5 3.5L20.5 12L16.5 20.5H13L17 12L13 3.5H16.5ZM7.5 3.5L11.5 12L7.5 20.5H11L15 12L11 3.5H7.5Z" fill="currentColor" opacity="0.9"/></svg>` },
            ].map(t => (
              <div class="flex flex-col items-center text-center gap-2">
                <div style="color:var(--color-primary);" set:html={t.icon} />
                <p class="text-sm font-bold" style="color:var(--color-ink);">{t.name}</p>
                <p class="text-xs" style="color:var(--color-ink-dim);">{t.sub}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ========== TIMELINE & COST ========== -->
    <section class="section-padding" style="background:var(--color-bg); border-top:1px solid var(--color-border);">
      <div class="max-w-3xl mx-auto px-6 lg:px-8">
        <h2 class="heading-lg text-center mb-12 reveal">実装期間とコスト</h2>
        <div class="reveal t-card p-8">
          <div class="flex flex-col gap-5">
            <div class="flex items-center justify-between py-3" style="border-bottom:1px solid var(--color-border);">
              <p class="text-sm font-semibold" style="color:var(--color-ink);">開発期間</p>
              <p class="text-lg font-bold" style="color:var(--color-primary);">●●週間</p>
            </div>
            <div class="flex items-center justify-between py-3" style="border-bottom:1px solid var(--color-border);">
              <p class="text-sm font-semibold" style="color:var(--color-ink);">開発体制</p>
              <p class="text-sm font-bold" style="color:var(--color-ink);">AltShift代表 + Claude Code活用</p>
            </div>
            <div class="flex items-center justify-between py-3" style="border-bottom:1px solid var(--color-border);">
              <p class="text-sm font-semibold" style="color:var(--color-ink);">初期費用</p>
              <p class="text-sm font-bold" style="color:var(--color-ink);">●●万円</p>
            </div>
            <div class="flex items-center justify-between py-3">
              <p class="text-sm font-semibold" style="color:var(--color-ink);">月額保守</p>
              <p class="text-sm font-bold" style="color:var(--color-ink);">●●万円/月</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== SUBSIDY (conditional) ========== -->
    <section class="section-padding" style="background:var(--color-bg);" id="subsidy-section">
      <div class="max-w-3xl mx-auto px-6 lg:px-8">
        <h2 class="heading-lg text-center mb-12 reveal">補助金活用情報</h2>
        <div class="reveal t-card p-8" style="border-color:rgba(27,94,190,0.2); background:rgba(27,94,190,0.03);">
          <div class="flex flex-col gap-4">
            <div class="flex items-center justify-between py-3" style="border-bottom:1px solid var(--color-border);">
              <p class="text-sm font-semibold" style="color:var(--color-ink);">利用補助金</p>
              <p class="text-sm font-bold" style="color:var(--color-primary);">●●補助金</p>
            </div>
            <div class="flex items-center justify-between py-3" style="border-bottom:1px solid var(--color-border);">
              <p class="text-sm font-semibold" style="color:var(--color-ink);">補助率</p>
              <p class="text-sm font-bold" style="color:var(--color-primary);">●●</p>
            </div>
            <div class="flex items-center justify-between py-3">
              <p class="text-sm font-semibold" style="color:var(--color-ink);">実質負担額</p>
              <p class="text-lg font-bold" style="color:var(--color-primary);">●●万円</p>
            </div>
          </div>
          <p class="text-xs mt-4" style="color:var(--color-ink-dim);">※補助金未活用の場合、このセクションは非表示になります。後日情報が確定次第更新します。</p>
        </div>
      </div>
    </section>

    <!-- ========== LEARNINGS ========== -->
    <section class="section-padding" style="background:var(--color-bg); border-top:1px solid var(--color-border);">
      <div class="max-w-3xl mx-auto px-6 lg:px-8">
        <h2 class="heading-lg text-center mb-12 reveal">学び・今後の展開</h2>
        <div class="flex flex-col gap-5 stagger">
          {[
            { title: '物流現場のAI化で得た知見', desc: '物流業界は「紙・電話・LINE個別チャット」が根強く残る領域。現場の業務フローを丁寧にヒアリングし、既存の運用を壊さずにAIを挿入するアプローチが有効でした。' },
            { title: '横展開可能なFDEプレイブックの確立', desc: '本プロジェクトで確立した「LINE Bot × Google Sheets × Claude API」のアーキテクチャは、物流以外の業種（建設・製造・卸売など）にも応用可能な汎用パターンとなりました。' },
            { title: '他物流企業への展開可能性', desc: '配車・受発注・請求の自動化ニーズは物流業界全体に共通。本事例をベースに、同業界の横展開を進めています。' },
          ].map(l => (
            <div class="reveal t-card p-6">
              <h3 class="heading-sm mb-2">{l.title}</h3>
              <p class="body-sm">{l.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== RELATED & CTA ========== -->
    <section class="section-padding" style="background:var(--color-bg);">
      <div class="max-w-3xl mx-auto px-6 lg:px-8">

        <!-- Related links -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8 stagger">
          <a href="/service/ai-automation" class="reveal t-card p-5 block" style="text-decoration:none; color:inherit; transition:transform 0.2s, border-color 0.2s;" onmouseover="this.style.transform='translateY(-2px)';this.style.borderColor='rgba(27,94,190,0.3)'" onmouseout="this.style.transform='';this.style.borderColor=''">
            <p class="text-xs font-semibold mb-1" style="color:var(--color-primary);">サービス詳細</p>
            <p class="heading-sm">AI業務自動化</p>
            <p class="text-xs mt-1" style="color:var(--color-ink-dim);">補助金活用で実質負担1/2〜2/3 →</p>
          </a>
          <a href="/simulator" class="reveal t-card p-5 block" style="text-decoration:none; color:inherit; transition:transform 0.2s, border-color 0.2s;" onmouseover="this.style.transform='translateY(-2px)';this.style.borderColor='rgba(27,94,190,0.3)'" onmouseout="this.style.transform='';this.style.borderColor=''">
            <p class="text-xs font-semibold mb-1" style="color:var(--color-primary);">ツール</p>
            <p class="heading-sm">補助金シミュレーター</p>
            <p class="text-xs mt-1" style="color:var(--color-ink-dim);">実質負担額を30秒で診断 →</p>
          </a>
        </div>

        <!-- CTA -->
        <div class="reveal t-card p-10 text-center" style="border-color:rgba(27,94,190,0.2); background:rgba(27,94,190,0.03);">
          <h2 class="heading-md mb-4">物流業務のAI化、<br class="hidden md:inline" />御社でも実現しませんか？</h2>
          <p class="body-sm mb-8" style="max-width:480px; margin:0 auto;">現場の業務フローをヒアリングし、AI化の優先度と想定ROIを無料で診断します。</p>
          <a href="/contact" class="btn-primary">
            無料で相談する
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>

      </div>
    </section>

  </main>
  <Footer />
</Layout>
