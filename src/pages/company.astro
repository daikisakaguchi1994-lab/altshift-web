---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

const gradLabel = "font-family:'Inter',sans-serif; font-weight:700; font-size:12px; letter-spacing:0.2em; text-transform:uppercase; background:linear-gradient(135deg,#1B5EBE,#4A90D9); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;"
const gradDeco  = "font-family:'Inter',sans-serif; font-weight:900; font-size:clamp(60px,10vw,120px); letter-spacing:-0.05em; opacity:0.04; background:linear-gradient(135deg,#1B5EBE,#4A90D9); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; line-height:1; pointer-events:none; user-select:none;"

const info = [
  { label: '屋号',     value: 'AltShift（オルトシフト）' },
  { label: '代表者',   value: 'ディーチャー（本名：坂口 大輝 / Daiki Sakaguchi）' },
  { label: '事業形態', value: '個人事業主' },
  { label: '所在地',   value: '福岡県福岡市（詳細は請求があれば開示）' },
  { label: '設立',     value: '2025年' },
  { label: '事業内容', value: '外部CAIOサービス・AIシステム開発・Web制作・SEO/GEO対策・LINE自動化' },
  { label: 'メール',   value: 'contact@altshift.jp' },
]
---

<Layout title="会社情報 | AltShift" description="AltShiftの会社情報・代表者プロフィール。">
  <Nav />
  <main>
    <section class="relative overflow-hidden" style="background:#FFFFFF; padding:96px 24px;">
      <p class="absolute top-4 left-6 select-none pointer-events-none" style={gradDeco}>COMPANY</p>

      <div class="relative max-w-6xl mx-auto">
        <div class="mb-14 reveal">
          <p style={gradLabel} class="mb-2">— 会社情報</p>
          <h1 style="font-size:clamp(28px,4vw,40px); color:#1A1A1A;">COMPANY</h1>
        </div>

        <!-- AltShiftについて（ミッション） -->
        <div class="reveal mb-16 max-w-3xl">
          <h2 style="font-size:28px; font-weight:800; color:#1A1A1A; margin-bottom:8px; letter-spacing:-0.03em;">AltShiftについて</h2>
          <div style="height:3px; background:#C8A15A; border-radius:2px; margin-bottom:32px; animation:lineGrow 0.8s ease forwards;"></div>

          <div style="border-left:3px solid #C8A15A; padding-left:20px; margin-bottom:28px;">
            <p style="font-family:'Inter','Noto Sans JP',sans-serif; font-weight:900; font-size:20px; line-height:1.5; background:linear-gradient(135deg,#1B5EBE 0%,#4A90D9 70%,#C8A15A 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">
              AIで、福岡をアジアのリーダーへ。
            </p>
          </div>

          <p style="color:#1A1A1A; line-height:1.9; font-size:16px; margin-bottom:16px; font-weight:400;">
            AIという道具は、仕事を奪うのではなく、人に新しい役割を与える。
            企業に生まれた「余白」は、人材育成の時間となり、新事業の種となり、地域経済の活力へと変わっていく。
          </p>
          <p style="color:#1A1A1A; line-height:1.9; font-size:16px; margin-bottom:16px; font-weight:400;">
            一社一社の変革が積み重なったとき、福岡はアジアのAI先進都市になる。
            その確信を持って、私たちは最先端の知識と実装力で、福岡の企業の最前線に立ち続けます。
          </p>
          <p style="color:#1B5EBE; font-weight:700; font-size:16px;">
            ただ伴走するのではなく、一緒に未来をつくる。共に、進化し続けましょう。
          </p>
        </div>

        <!-- 会社概要テーブル -->
        <div class="reveal mb-16">
          <p style="font-size:11px; font-weight:600; color:#6B6B6B; letter-spacing:0.15em; text-transform:uppercase; margin-bottom:24px;">Company Info</p>
          <div style="border:1px solid #E5E5E5; border-radius:8px; overflow:hidden; max-width:640px;">
            {info.map((row, i) => (
              <dl class="flex flex-col sm:flex-row" style={i !== info.length - 1 ? 'border-bottom:1px solid #E5E5E5;' : ''}>
                <dt style="width:140px; padding:14px 24px; font-size:12px; font-weight:600; color:#6B6B6B; background:#F4F4F4; flex-shrink:0;">{row.label}</dt>
                <dd style="flex:1; padding:14px 24px; font-size:14px; color:#1A1A1A;">{row.value}</dd>
              </dl>
            ))}
          </div>
        </div>

        <!-- 代表プロフィール -->
        <div class="reveal">
          <p style="font-size:11px; font-weight:600; color:#6B6B6B; letter-spacing:0.15em; text-transform:uppercase; margin-bottom:32px;">Representative</p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-10 items-start max-w-3xl">
            <div class="md:col-span-1">
              <div class="w-full h-64 overflow-hidden" style="border-radius:8px;">
                <img
                  src="/images/daiki_profile.jpg"
                  alt="ディーチャー（坂口 大輝）AltShift代表"
                  style="width:100%; height:100%; object-fit:cover; object-position:center top; border-radius:8px;"
                />
              </div>
            </div>
            <div class="md:col-span-2 pt-2">
              <p style="font-weight:800; color:#1A1A1A; font-size:18px; margin-bottom:4px; letter-spacing:-0.02em;">ディーチャー（坂口 大輝）</p>
              <p style="font-size:12px; color:#9CA3AF; font-weight:300; margin-bottom:20px;">AltShift 代表 / External CAIO</p>
              <p style="font-size:15px; color:#1A1A1A; line-height:1.9; font-weight:400; margin-bottom:16px;">
                AI活用のスペシャリスト。中小企業のデジタル変革を支援し、AIという道具を誰もが使いこなせる世界を目指しています。
              </p>
              <p style="font-size:15px; color:#1A1A1A; line-height:1.9; font-weight:400;">
                外部CAIOという働き方で、週1〜2回企業に入り込み、AI戦略の策定から実装まで伴走します。プログラマーではなく経営者の視点でAIを使いこなすことが、私の強みです。
              </p>
            </div>
          </div>
        </div>

      </div>
    </section>
  </main>
  <Footer />
</Layout>
