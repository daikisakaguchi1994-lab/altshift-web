---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

const info = [
  { label: '屋号', value: 'AltShift（オルトシフト）' },
  { label: '代表者', value: '坂口 大輝（Daiki Sakaguchi）' },
  { label: '事業形態', value: '個人事業主' },
  { label: '所在地', value: '福岡県福岡市（詳細は請求があれば開示）' },
  { label: '設立', value: '2025年' },
  { label: '事業内容', value: 'AI導入コンサルティング・AIシステム開発・Web制作・SEO/GEO対策・LINE自動化' },
  { label: 'メール', value: 'contact@altshift.jp' },
]

const law = [
  { label: '販売事業者', value: '坂口 大輝（屋号：AltShift）' },
  { label: '運営責任者', value: '坂口 大輝' },
  { label: '所在地', value: '福岡県福岡市（詳細は請求があれば遅滞なく開示）' },
  { label: '連絡先メール', value: 'contact@altshift.jp' },
  { label: '電話番号', value: '請求があれば遅滞なく開示' },
  { label: '取扱商品', value: 'AI導入コンサルティング / AIシステム開発 / Web制作 / LINE自動化' },
  { label: '販売価格', value: '各サービスごとにお見積もり' },
  { label: '支払方法', value: '銀行振込' },
  { label: '支払時期', value: '請求書発行月の翌月末まで' },
  { label: '提供時期', value: '契約後、個別に取り決め' },
  { label: '返品・キャンセル', value: 'サービスの性質上、返品は不可。キャンセルは契約時の条件に従います。' },
]
---

<Layout title="会社情報 | 福岡のAIコンサルティング AltShift" description="AltShift（オルトシフト）の会社情報。福岡市を拠点に中小企業のAI導入を戦略から実装まで一貫支援。代表 坂口大輝。">
  <Nav />
  <main>
    <section class="section-padding" style="background:var(--color-bg); padding-top:140px;">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">

        <!-- Header -->
        <div class="mb-16 reveal">
          <div class="accent-line mb-6"></div>
          <h1 class="heading-hero" style="font-size:clamp(28px,4vw,48px);">会社情報</h1>
        </div>

        <!-- Mission -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 mb-20 reveal">
          <div>
            <h2 class="heading-lg" style="line-height:1.4;">
              私たちは、企業の課題を<br/>
              AIの力で解決します。
            </h2>
          </div>
          <div>
            <p class="body-md mb-4">
              AIは仕事を奪うのではなく、人に新しい役割を与える。
              企業に生まれた「余白」は、人材育成の時間となり、新事業の種となる。
            </p>
            <p class="body-md" style="color:var(--color-neon); font-weight:600;">
              ただ伴走するのではなく、一緒に未来をつくる。
            </p>
          </div>
        </div>

        <!-- Founder -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 mb-20 reveal">
          <!-- PHOTO SLOT -->
          <div class="lg:col-span-1">
            <div class="media-slot" style="aspect-ratio:3/4;">
              <img src="/images/daiki_profile.jpg" alt="坂口 大輝" style="width:100%;height:100%;object-fit:cover;object-position:center top;" />
            </div>
          </div>
          <div class="lg:col-span-2 flex flex-col justify-center">
            <p class="text-xs font-semibold mb-3" style="color:var(--color-neon); letter-spacing:0.1em; text-transform:uppercase;">Founder</p>
            <h2 class="heading-lg mb-2">坂口 大輝</h2>
            <p class="body-sm mb-6">AltShift 代表 / AI Consultant</p>
            <p class="body-md mb-4">
              AI活用のスペシャリスト。中小企業のデジタル変革を支援し、AIを誰もが使いこなせる世界を目指しています。
            </p>
            <p class="body-md">
              外部AI顧問として企業に入り込み、AI戦略の策定から実装まで伴走。経営者の視点でAIを使いこなすことが強みです。
            </p>
          </div>
        </div>

        <!-- Company Info -->
        <div class="mb-20 reveal">
          <h3 class="heading-md mb-8">会社概要</h3>
          <div class="t-card overflow-hidden" style="max-width:640px;">
            {info.map((row, i) => (
              <dl class="flex flex-col sm:flex-row" style={i !== info.length - 1 ? `border-bottom:1px solid var(--color-border);` : ''}>
                <dt class="text-xs font-semibold flex-shrink-0 sm:w-[140px]" style="padding:12px 16px; color:var(--color-ink-muted); background:var(--color-bg-card);">{row.label}</dt>
                <dd class="text-sm flex-1" style="padding:12px 16px; color:var(--color-ink);">{row.value}</dd>
              </dl>
            ))}
          </div>
        </div>

        <!-- Legal -->
        <div class="reveal" id="legal">
          <div class="section-divider mb-16"></div>
          <h3 class="heading-md mb-8">特定商取引法に基づく表記</h3>
          <div class="t-card overflow-hidden" style="max-width:720px;">
            {law.map((row, i) => (
              <dl class="flex flex-col sm:flex-row" style={i !== law.length - 1 ? `border-bottom:1px solid var(--color-border);` : ''}>
                <dt class="text-xs font-medium flex-shrink-0 sm:w-[140px]" style="padding:12px 16px; color:var(--color-ink-muted); background:var(--color-bg-card);">{row.label}</dt>
                <dd class="text-sm flex-1 leading-relaxed" style="padding:12px 16px; color:var(--color-ink);">{row.value}</dd>
              </dl>
            ))}
          </div>
        </div>

      </div>
    </section>
  </main>
  <Footer />
</Layout>
