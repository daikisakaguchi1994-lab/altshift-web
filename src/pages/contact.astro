---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
---

<Layout title="お問い合わせ | 福岡のAIコンサルティング AltShift" description="AltShiftへのお問い合わせ・無料AI導入相談。福岡を拠点に全国対応。最短翌営業日にご連絡します。">
  <Nav />
  <main>
    <section class="section-padding" style="background:var(--color-bg); padding-top:140px;">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="mb-14 reveal">
          <div class="accent-line mb-6"></div>
          <h1 class="heading-hero" style="font-size:clamp(28px,4vw,48px);">お問い合わせ</h1>
          <p class="body-lg mt-4">AI導入のご相談は、初回30分無料です。最短翌営業日にご連絡します。</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

          <!-- Form -->
          <div class="lg:col-span-3 reveal">
            <form id="contact-form" class="flex flex-col gap-5">
              {[
                { id: 'name', label: 'お名前', type: 'text', required: true, placeholder: '山田 太郎' },
                { id: 'company', label: '会社名', type: 'text', required: false, placeholder: '株式会社〇〇' },
                { id: 'email', label: 'メールアドレス', type: 'email', required: true, placeholder: 'example@mail.com' },
                { id: 'tel', label: '電話番号', type: 'tel', required: false, placeholder: '090-0000-0000' },
              ].map(f => (
                <div>
                  <label style="display:block; font-size:12px; font-weight:500; color:var(--color-ink-muted); margin-bottom:6px;" for={f.id}>
                    {f.label} {f.required ? <span style="color:#DC2626;">*</span> : <span style="font-weight:300;">（任意）</span>}
                  </label>
                  <input type={f.type} id={f.id} name={f.id} required={f.required}
                         style="width:100%; border:1px solid var(--color-border-card); border-radius:8px; padding:12px 16px; font-size:14px; background:var(--color-bg-card); color:var(--color-ink); transition:all 0.2s;"
                         placeholder={f.placeholder} />
                </div>
              ))}

              <div>
                <label style="display:block; font-size:12px; font-weight:500; color:var(--color-ink-muted); margin-bottom:6px;" for="inquiry-type">
                  ご相談内容 <span style="color:#DC2626;">*</span>
                </label>
                <select id="inquiry-type" name="inquiry-type" required
                        style="width:100%; border:1px solid var(--color-border-card); border-radius:8px; padding:12px 16px; font-size:14px; background:var(--color-bg-card); color:var(--color-ink); transition:all 0.2s; appearance:none; background-image:url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%226B6B6B%22 stroke-width=%222%22%3E%3Cpolyline points=%226 9 12 15 18 9%22/%3E%3C/svg%3E'); background-repeat:no-repeat; background-position:right 16px center;">
                  <option value="" disabled selected>選択してください</option>
                  <option value="ai-consulting">AI導入のご相談</option>
                  <option value="ai-system">カスタムAIシステム開発</option>
                  <option value="subsidy">補助金活用のご相談</option>
                  <option value="subsidy-doc">補助金詳細資料の希望</option>
                  <option value="other">その他</option>
                </select>
              </div>

              <div>
                <label style="display:block; font-size:12px; font-weight:500; color:var(--color-ink-muted); margin-bottom:6px;" for="message">
                  お問い合わせ内容 <span style="color:#DC2626;">*</span>
                </label>
                <textarea id="message" name="message" required rows="5"
                          style="width:100%; border:1px solid var(--color-border-card); border-radius:8px; padding:12px 16px; font-size:14px; background:var(--color-bg-card); color:var(--color-ink); resize:none; transition:all 0.2s;"
                          placeholder="お気軽にご相談ください。"></textarea>
              </div>

              <!-- Honeypot -->
              <div style="position:absolute; left:-9999px;">
                <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
              </div>

              <div>
                <button type="submit" id="submit-btn" class="btn-primary" style="padding:14px 32px;">
                  <span id="btn-text">送信する</span>
                  <span id="btn-loading" style="display:none;">送信中...</span>
                  <svg id="btn-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                  </svg>
                </button>
              </div>

              <!-- Error message -->
              <div id="form-error" style="display:none; padding:12px 16px; border-radius:8px; background:rgba(255,59,48,0.1); border:1px solid rgba(255,59,48,0.2); color:#FF3B30; font-size:14px;">
                送信に失敗しました。お手数ですが <a href="mailto:contact@altshift.jp" style="color:#1456FB; text-decoration:underline;">contact@altshift.jp</a> まで直接ご連絡ください。
              </div>
            </form>

            <!-- Success message -->
            <div id="form-success" style="display:none;" class="t-card p-8 text-center">
              <div style="width:64px; height:64px; border-radius:50%; background:rgba(27,94,190,0.1); display:flex; align-items:center; justify-content:center; margin:0 auto 20px;">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
              <h3 class="heading-md mb-3">お問い合わせありがとうございます</h3>
              <p class="body-md mb-2">内容を確認の上、最短翌営業日にご連絡いたします。</p>
              <p class="body-sm" style="color:var(--color-ink-dim);">確認メールをお送りしました。届かない場合は迷惑メールフォルダをご確認ください。</p>
            </div>
          </div>

          <!-- Sidebar -->
          <div class="lg:col-span-2 reveal flex flex-col gap-6">
            <div class="t-card p-6">
              <p class="text-xs font-semibold mb-5" style="color:var(--color-ink-muted); letter-spacing:0.1em; text-transform:uppercase;">Contact Info</p>
              <div class="flex flex-col gap-5">
                <div>
                  <p class="text-xs mb-1" style="color:var(--color-ink-dim);">メール</p>
                  <a href="mailto:contact@altshift.jp" class="text-sm font-semibold" style="color:var(--color-brand);">contact@altshift.jp</a>
                </div>
                <div>
                  <p class="text-xs mb-1" style="color:var(--color-ink-dim);">拠点</p>
                  <p class="text-sm" style="color:var(--color-ink);">福岡市（全国オンライン対応）</p>
                </div>
                <div>
                  <p class="text-xs mb-1" style="color:var(--color-ink-dim);">対応時間</p>
                  <p class="text-sm" style="color:var(--color-ink);">平日 10:00〜18:00</p>
                </div>
                <div>
                  <p class="text-xs mb-1" style="color:var(--color-ink-dim);">返信目安</p>
                  <p class="text-sm" style="color:var(--color-ink);">最短翌営業日</p>
                </div>
              </div>
            </div>

            <div class="t-card p-6" style="border-color:rgba(6,199,85,0.2); background:rgba(6,199,85,0.04);">
              <p class="text-xs font-semibold mb-3" style="color:#06C755; letter-spacing:0.1em; text-transform:uppercase;">LINE</p>
              <p class="body-sm mb-4">LINEでもご相談を受け付けています。</p>
              <a href="https://lin.ee/VOiIxYB" target="_blank" rel="noopener noreferrer" class="btn-line" style="width:100%; justify-content:center; font-size:14px; padding:12px 20px;">
                <svg width="16" height="16" viewBox="0 0 48 48" fill="white">
                  <path d="M24 4C12.95 4 4 11.86 4 21.5c0 5.5 2.87 10.4 7.36 13.6L9 40l6.5-2.8A22.4 22.4 0 0024 39c11.05 0 20-7.86 20-17.5S35.05 4 24 4z"/>
                </svg>
                LINEで相談する
              </a>
            </div>

            <!-- Social proof on contact page -->
            <div class="t-card p-6">
              <p class="text-xs font-semibold mb-4" style="color:var(--color-ink-muted); letter-spacing:0.1em; text-transform:uppercase;">実績</p>
              <div class="flex flex-col gap-3">
                <div class="flex items-center gap-3">
                  <div style="width:6px; height:6px; border-radius:50%; background:var(--color-primary); flex-shrink:0;"></div>
                  <p class="text-sm" style="color:var(--color-ink);">導入実績 4社</p>
                </div>
                <div class="flex items-center gap-3">
                  <div style="width:6px; height:6px; border-radius:50%; background:var(--color-primary); flex-shrink:0;"></div>
                  <p class="text-sm" style="color:var(--color-ink);">採用業務工数 50%削減</p>
                </div>
                <div class="flex items-center gap-3">
                  <div style="width:6px; height:6px; border-radius:50%; background:var(--color-primary); flex-shrink:0;"></div>
                  <p class="text-sm" style="color:var(--color-ink);">最短2週間で戦略策定</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement
  const successDiv = document.getElementById('form-success')!
  const errorDiv = document.getElementById('form-error')!
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement
  const btnText = document.getElementById('btn-text')!
  const btnLoading = document.getElementById('btn-loading')!
  const btnArrow = document.getElementById('btn-arrow')!

  // URLパラメータ ?type=subsidy-doc 対応
  const params = new URLSearchParams(window.location.search)
  const presetType = params.get('type')
  if (presetType) {
    const select = document.getElementById('inquiry-type') as HTMLSelectElement
    const option = select.querySelector(`option[value="${presetType}"]`)
    if (option) select.value = presetType
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    errorDiv.style.display = 'none'
    submitBtn.disabled = true
    btnText.style.display = 'none'
    btnLoading.style.display = 'inline'
    btnArrow.style.display = 'none'

    const formData = new FormData(form)
    const data = Object.fromEntries(formData.entries())

    // Skip if honeypot is filled
    if (data._gotcha) return

    try {
      const res = await fetch('https://formsubmit.co/ajax/contact@altshift.jp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({
          name: data.name,
          company: data.company || '未記入',
          email: data.email,
          tel: data.tel || '未記入',
          'inquiry-type': data['inquiry-type'],
          message: data.message,
          _subject: `【AltShift】${data.company || data.name}様からのお問い合わせ（${data['inquiry-type']}）`,
        }),
      })

      if (res.ok) {
        form.style.display = 'none'
        successDiv.style.display = 'block'
      } else {
        throw new Error('送信失敗')
      }
    } catch {
      errorDiv.style.display = 'block'
      submitBtn.disabled = false
      btnText.style.display = 'inline'
      btnLoading.style.display = 'none'
      btnArrow.style.display = 'inline'
    }
  })
</script>
