---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
---

<Layout title="お問い合わせ | AltShift" description="AltShiftへのお問い合わせ・無料相談・資料請求。">
  <Nav />
  <main>
    <section class="section-padding" style="background:var(--color-bg); padding-top:140px;">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="mb-14 reveal">
          <div class="accent-line mb-6"></div>
          <h1 class="heading-hero" style="font-size:clamp(28px,4vw,48px);">お問い合わせ</h1>
          <p class="body-lg mt-4">AI導入に関するご相談は無料です。お気軽にどうぞ。</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

          <!-- Form -->
          <div class="lg:col-span-3 reveal">
            <form name="contact" method="POST" action="#" class="flex flex-col gap-5">
              {[
                { id: 'name', label: 'お名前', type: 'text', required: true, placeholder: '山田 太郎' },
                { id: 'company', label: '会社名', type: 'text', required: false, placeholder: '株式会社〇〇' },
                { id: 'email', label: 'メールアドレス', type: 'email', required: true, placeholder: 'example@mail.com' },
                { id: 'tel', label: '電話番号', type: 'tel', required: false, placeholder: '090-0000-0000' },
              ].map(f => (
                <div>
                  <label style="display:block; font-size:12px; font-weight:500; color:var(--color-ink-muted); margin-bottom:6px;" for={f.id}>
                    {f.label} {f.required ? <span style="color:var(--color-neon);">*</span> : <span style="font-weight:300;">（任意）</span>}
                  </label>
                  <input type={f.type} id={f.id} name={f.id} required={f.required}
                         style="width:100%; border:1px solid var(--color-border-card); border-radius:8px; padding:12px 16px; font-size:14px; background:var(--color-bg-card); color:var(--color-ink); transition:all 0.2s;"
                         placeholder={f.placeholder} />
                </div>
              ))}

              <div>
                <label style="display:block; font-size:12px; font-weight:500; color:var(--color-ink-muted); margin-bottom:6px;" for="message">
                  お問い合わせ内容 <span style="color:var(--color-neon);">*</span>
                </label>
                <textarea id="message" name="message" required rows="5"
                          style="width:100%; border:1px solid var(--color-border-card); border-radius:8px; padding:12px 16px; font-size:14px; background:var(--color-bg-card); color:var(--color-ink); resize:none; transition:all 0.2s;"
                          placeholder="お気軽にご相談ください。"></textarea>
              </div>
              <div>
                <button type="submit" class="btn-neon" style="padding:14px 32px;">
                  送信する
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                  </svg>
                </button>
              </div>
            </form>
          </div>

          <!-- Sidebar -->
          <div class="lg:col-span-2 reveal flex flex-col gap-6">
            <div class="t-card p-6">
              <p class="text-xs font-semibold mb-5" style="color:var(--color-ink-muted); letter-spacing:0.1em; text-transform:uppercase;">Contact Info</p>
              <div class="flex flex-col gap-5">
                <div>
                  <p class="text-xs mb-1" style="color:var(--color-ink-dim);">メール</p>
                  <a href="mailto:contact@altshift.jp" class="text-sm font-semibold" style="color:var(--color-blue);">contact@altshift.jp</a>
                </div>
                <div>
                  <p class="text-xs mb-1" style="color:var(--color-ink-dim);">拠点</p>
                  <p class="text-sm" style="color:var(--color-ink);">福岡市</p>
                </div>
                <div>
                  <p class="text-xs mb-1" style="color:var(--color-ink-dim);">対応時間</p>
                  <p class="text-sm" style="color:var(--color-ink);">平日 10:00〜18:00</p>
                </div>
              </div>
            </div>

            <div class="t-card p-6" style="border-color:rgba(204,255,0,0.15); background:rgba(204,255,0,0.03);">
              <p class="text-xs font-semibold mb-3" style="color:var(--color-neon); letter-spacing:0.1em; text-transform:uppercase;">LINE</p>
              <p class="body-sm mb-4">LINEでもご相談を受け付けています。</p>
              <a href="https://lin.ee/VOiIxYB" target="_blank" rel="noopener noreferrer" class="btn-line" style="width:100%; justify-content:center; font-size:14px; padding:12px 20px;">
                <svg width="16" height="16" viewBox="0 0 48 48" fill="white">
                  <path d="M24 4C12.95 4 4 11.86 4 21.5c0 5.5 2.87 10.4 7.36 13.6L9 40l6.5-2.8A22.4 22.4 0 0024 39c11.05 0 20-7.86 20-17.5S35.05 4 24 4z"/>
                </svg>
                LINEで相談する
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
