---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import LineButton from '../components/LineButton.astro'

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'AltShift 福岡AIコンサルティング',
  description: '福岡市を拠点とする中小企業向けAIコンサルティング。AI導入戦略・システム開発・Web制作・LINE自動化を一貫支援。',
  url: 'https://altshift.jp/fukuoka-ai-consulting',
  address: { '@type': 'PostalAddress', addressLocality: '福岡市', addressRegion: '福岡県', addressCountry: 'JP' },
  geo: { '@type': 'GeoCoordinates', latitude: 33.5904, longitude: 130.4017 },
  areaServed: { '@type': 'City', name: '福岡市' },
  priceRange: '戦略診断30万円〜、月額顧問20万円〜、Embedded CAIO 50万円〜',
}
---

<Layout
  title="福岡のAIコンサルティング | 中小企業向けAI導入支援 | AltShift"
  description="福岡市を拠点とする中小企業向けAIコンサルティング。AI導入戦略・AIシステム開発・Web制作×SEO/GEO・LINE自動化を一貫支援。福岡の中小企業4社の導入実績。無料相談受付中。"
  schemaData={schemaData}
>
  <Nav />
  <main>
    <section class="section-padding" style="background:var(--color-bg); padding-top:140px;">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">

        <!-- Header -->
        <div class="mb-16 reveal">
          <div class="accent-line mb-6"></div>
          <h1 class="heading-hero" style="font-size:clamp(28px,4vw,48px);">
            福岡の中小企業向け<br/>AIコンサルティング
          </h1>
          <p class="body-lg mt-4" style="max-width:680px;">
            福岡市を拠点に、中小企業専門のAI導入支援を行っています。戦略策定からシステム開発・Web制作・LINE自動化まで一貫サポート。
          </p>
        </div>

        <!-- Why Fukuoka needs AI -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 mb-24 reveal">
          <div>
            <h2 class="heading-lg mb-6" style="line-height:1.4;">なぜ今、福岡の中小企業に<br/>AIが必要なのか</h2>
            <p class="body-md mb-4">
              福岡市は「スタートアップ都市」として国内外から注目を集め、IT企業やスタートアップの集積が進んでいます。一方で、市内の多くの中小企業はデジタル化・AI化が追いついていないのが現状です。
            </p>
            <p class="body-md mb-4">
              人手不足、採用難、業務効率の課題は、AIの導入で大きく改善できます。福岡の中小企業がAIを活用することで、大手企業との競争力格差を埋め、九州・全国市場での優位性を確立できます。
            </p>
            <p class="body-md">
              AltShiftは福岡を拠点に、地域の中小企業が「AIを経営の武器」にできるよう、戦略から実装・運用まで伴走します。
            </p>
          </div>
          <div>
            <div class="t-card p-8">
              <h3 class="heading-md mb-6">福岡の中小企業が抱える課題</h3>
              <ul class="flex flex-col gap-4">
                {[
                  '人手不足で採用・定着に苦戦している',
                  '業務が属人化し、効率化が進まない',
                  'Web集客やSNSの運用に手が回らない',
                  '「AIを使いたいが何から始めればいいか分からない」',
                  '東京のIT企業に頼むとコストが高すぎる',
                  'デジタルに詳しい社員がいない',
                ].map(item => (
                  <li class="flex items-start gap-3 body-sm">
                    <div style="width:6px; height:6px; border-radius:50%; background:var(--color-primary); flex-shrink:0; margin-top:8px;"></div>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <!-- AltShift's strengths for Fukuoka -->
        <div class="mb-24">
          <h2 class="heading-lg text-center mb-16 reveal">AltShiftが福岡の中小企業に選ばれる理由</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger">
            {[
              { title: '福岡拠点だから訪問対応可能', desc: '福岡市内・近郊であれば直接お伺いしてヒアリング・研修を実施。対面でのコミュニケーションを重視します。オンラインでの全国対応も可能です。' },
              { title: '中小企業専門の料金体系', desc: '30万円〜の戦略診断から月額顧問・Embedded CAIOまで、明確な3段階の料金体系。東京の大手コンサルファームの1/10以下のコストで、同等以上のAI導入支援を提供します。' },
              { title: '戦略から実装まで一貫対応', desc: '「提案書を渡して終わり」ではありません。AI戦略の策定からシステム開発、Web制作、運用改善まで、ワンストップで対応します。' },
              { title: 'AI未経験でも安心', desc: 'お客様の大半はAI導入が初めての企業様です。専門用語を使わず、経営者の言葉で分かりやすくご説明します。' },
              { title: '地域の実績がある', desc: '建設・リフォーム、飲食・バー、住宅・店舗リノベーション、コールセンター・採用支援など、福岡の中小企業への導入実績があります。' },
              { title: '最新AI技術を即座に反映', desc: 'Claude、GPTなど最新のAIモデルに常にキャッチアップ。お客様のシステムに最新技術を迅速に適用します。' },
            ].map(s => (
              <div class="reveal t-card p-6">
                <h3 class="heading-sm mb-3">{s.title}</h3>
                <p class="body-sm">{s.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Fukuoka case studies -->
        <div class="mb-24">
          <h2 class="heading-lg text-center mb-12 reveal">福岡の導入実績</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 stagger">
            {[
              { company: '建設・リフォーム', area: '福岡市', service: 'Web制作・SEO/GEO', result: 'AI検索・Googleマップ双方で上位露出', desc: 'AI時代の検索対応Webサイトを実装。SEO/GEO対策でGoogleとAI検索双方からの集客基盤を構築。' },
              { company: '飲食・バー', area: '福岡市', service: 'Web制作・LINE自動化', result: '営業時間外の問い合わせ対応を完全自動化', desc: 'デジタルメニューとLINE自動応答を導入。深夜営業の飲食店でも24時間自動で顧客対応。' },
              { company: '住宅・店舗リノベーション', area: '福岡市', service: 'GEO最適化・SEO・HP制作', result: 'Googleマップ上位表示・オーガニック流入増加', desc: 'Googleマップへの上位表示およびSEO対策を一貫支援。検索・地図双方からの集客基盤を構築。' },
              { company: 'コールセンター・採用支援', area: '福岡県', service: '業務自動化・HR-Tech', result: '採用業務工数50%削減・集計完全自動化', desc: 'コールセンター集計の完全自動化、求人応募者管理、面接日程の自動設定を実現。' },
            ].map(c => (
              <div class="reveal t-card p-6">
                <div class="flex items-center gap-3 mb-3">
                  <span class="tag">{c.service}</span>
                  <span class="text-xs" style="color:var(--color-ink-dim);">{c.area}</span>
                </div>
                <h3 class="heading-sm mb-2">{c.company}</h3>
                <p class="body-sm mb-3">{c.desc}</p>
                <div class="flex items-start gap-2">
                  <div style="width:6px; height:6px; border-radius:50%; background:var(--color-primary); flex-shrink:0; margin-top:6px;"></div>
                  <p class="text-xs font-semibold" style="color:var(--color-primary);">{c.result}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="text-center mt-8">
            <a href="/case" class="neon-link">すべての事例を見る <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
          </div>
        </div>

        <!-- Services overview -->
        <div class="mb-24">
          <h2 class="heading-lg text-center mb-12 reveal">福岡で提供するサービス</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 stagger">
            {[
              { num: '01', title: 'AI導入コンサルティング', desc: '経営課題の分析からAIロードマップ策定まで。最短2週間。', href: '/service/ai-consulting' },
              { num: '02', title: 'カスタムAIシステム開発', desc: '業務自動化・データ分析。12週間以内に本番稼働。', href: '/service/ai-development' },
              { num: '03', title: 'AI時代の集客基盤構築', desc: 'Google・AI検索に選ばれるWebサイト制作。', href: '/service/web-seo' },
              { num: '04', title: '顧客接点の自動化', desc: '24時間365日の自動応答で機会損失ゼロ。', href: '/service/line-automation' },
            ].map(s => (
              <a href={s.href} class="reveal t-card p-6 flex flex-col" style="text-decoration:none; min-height:220px;">
                <p class="service-num mb-3" style="font-size:32px;">{s.num}</p>
                <h3 class="heading-sm mb-2">{s.title}</h3>
                <p class="body-sm flex-1">{s.desc}</p>
                <span class="neon-link mt-4" style="font-size:13px;">詳しく見る →</span>
              </a>
            ))}
          </div>
        </div>

        <!-- CTA -->
        <div class="reveal t-card p-8" style="border-color:rgba(27,94,190,0.15); background:rgba(27,94,190,0.03);">
          <div class="text-center">
            <h2 class="heading-lg mb-4">福岡でAI導入をお考えですか？</h2>
            <p class="body-md mb-8" style="max-width:560px; margin:0 auto;">
              初回のご相談は無料です。福岡市内であれば訪問でのヒアリングも可能です。まずはお気軽にご連絡ください。
            </p>
            <div class="flex justify-center gap-4 flex-wrap">
              <a href="/contact" class="btn-primary">無料で相談する</a>
              <LineButton />
            </div>
          </div>
        </div>

      </div>
    </section>
  </main>
  <Footer />
</Layout>
