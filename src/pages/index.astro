            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== FAQ ========== -->
    <section class="section-padding" style="background:var(--color-bg);">
      <div class="max-w-3xl mx-auto">
        <div class="mb-12 text-center reveal">
          <h2 class="heading-lg">よくある質問</h2>
        </div>

        <div class="flex flex-col gap-3" id="faq-list">
          {faqItems.map((item, i) => (
            <div class="reveal faq-item">
              <button
                class="faq-btn w-full text-left px-6 py-5 flex items-center justify-between gap-4"
                aria-expanded="false"
                aria-controls={`faq-answer-${i}`}
              >
                <span style="font-weight:500; color:var(--color-ink);">{item.q}</span>
                <svg class="faq-icon flex-shrink-0 transition-transform duration-200" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--color-ink-muted);">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5" id={`faq-answer-${i}`}>
                <p class="body-sm">{item.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling as HTMLElement
      const icon = btn.querySelector('.faq-icon') as HTMLElement
      const isOpen = btn.getAttribute('aria-expanded') === 'true'
      document.querySelectorAll('.faq-btn').forEach(b => {
        b.setAttribute('aria-expanded', 'false')
        ;(b.nextElementSibling as HTMLElement).classList.add('hidden')
        ;(b.querySelector('.faq-icon') as HTMLElement).style.transform = 'rotate(0deg)'
      })
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true')
        answer.classList.remove('hidden')
        icon.style.transform = 'rotate(180deg)'
      }
    })
  })
</script>
