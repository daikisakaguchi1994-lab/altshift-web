---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

const faqItems = [
  { q: 'AltShiftはどんなサービスですか？', a: '中小企業向けにAI導入を戦略から実装・運用まで一貫支援しています。ツール導入で終わらせず、現場で使いこなせる状態まで伴走します。' },
  { q: '料金はいくらですか？', a: '月額3万円〜8万円の3プランをご用意しています（初期費用別途）。まずは無料ヒアリングで最適なプランをご提案します。' },
  { q: 'AIを使ったことがない会社でも大丈夫ですか？', a: 'はい。ゼロからの設計・設定・研修まで一貫サポート。むしろAI未経験の企業様こそ成果が出やすいパターンです。' },
  { q: 'どのくらいで成果が出ますか？', a: 'LINE自動化は翌月から、SEOは通常3〜6ヶ月。成果が出やすい施策から優先着手します。' },
  { q: '福岡以外でも対応できますか？', a: 'はい。オンラインで全国対応。福岡市内・近郊は訪問対応も可能です。' },
]

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
}
---

<Layout
  title="AltShift｜福岡の中小企業向けAIコンサルティング・AI導入支援"
  description="福岡発、中小企業専門のAIコンサルティング。AI導入戦略・システム開発・Web制作・LINE自動化を月額3万円〜で一貫支援。採用業務工数50%削減の実績あり。無料相談受付中。"
  schemaData={faqSchema}
>
  <Nav />
  <main>

    <!-- ========== HERO ========== -->
    <section class="relative overflow-hidden" style="min-height:100vh; display:flex; align-items:center;">

      <!-- Animated background -->
      <div class="hero-bg">
        <div class="orb orb-neon"></div>
        <div class="orb orb-blue"></div>
        <div class="orb orb-teal"></div>
        <div class="hero-grid"></div>
      </div>

      <!-- VIDEO SLOT: Uncomment to replace gradient with video
      <div class="hero-media-slot">
        <video autoplay muted loop playsinline poster="/images/hero-poster.jpg">
          <source src="/videos/hero-1080.mp4" type="video/mp4" />
        </video>
      </div>
      -->

      <!-- Content -->
      <div style="position:relative; z-index:10; max-width:1200px; margin:0 auto; padding:160px 48px 100px; width:100%;">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-end">

          <!-- Left: Heading -->
          <div>
            <div class="accent-line mb-8"></div>
            <h1 class="heading-hero">
              中小企業の<br/>
              AI導入を、<br/>
              まるごと。
            </h1>
          </div>

          <!-- Right: Description + CTAs -->
          <div style="padding-bottom:8px;">
            <p class="body-lg mb-3" style="max-width:440px;">
              戦略策定から実装・運用まで一貫支援。福岡発、中小企業専門のAIコンサルティング。
            </p>
            <p class="text-sm mb-8" style="color:var(--color-neon); font-weight:600;">月額3万円〜 / 最短2週間で戦略策定</p>
            <div class="flex flex-wrap gap-4">
              <a href="/contact" class="btn-neon" style="font-size:14px; padding:14px 28px;">
                無料で相談する
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
              <a href="/case" class="btn-outline" style="font-size:14px; padding:14px 28px;">
                導入事例を見る
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== NUMBERS (実績) ========== -->
    <section style="background:var(--color-bg); border-top:1px solid rgba(255,255,255,0.06); border-bottom:1px solid rgba(255,255,255,0.06);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center reveal stagger">
          <div>
            <p class="number-value" data-count="50" data-suffix="%">0%</p>
            <p class="number-label">採用業務工数削減</p>
          </div>
          <div>
            <p class="number-value" data-count="2" data-suffix="週間">0週間</p>
            <p class="number-label">最短戦略策定</p>
          </div>
          <div>
            <p class="number-value" data-count="4" data-suffix="社">0社</p>
            <p class="number-label">導入実績</p>
          </div>
          <div>
            <p class="number-value" data-count="365" data-suffix="日">0日</p>
            <p class="number-label">24時間自動応答</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== HERO VIDEO / IMAGE SECTION ========== -->
    <section class="relative overflow-hidden" style="background:var(--color-bg);">
      <!-- FULL-WIDTH MEDIA SLOT: Replace with hero video or image -->
      <div style="position:relative; width:100%; aspect-ratio:16/7; background:var(--color-bg-card); overflow:hidden;">
        <!-- Placeholder: gradient animation simulating AI visuals -->
        <div style="position:absolute; inset:0; background: linear-gradient(135deg, #031B27 0%, #0A2535 30%, #071F2B 60%, #031B27 100%); display:flex; align-items:center; justify-content:center;">
          <div style="width:280px; height:280px; border-radius:50%; background:radial-gradient(circle, rgba(216,255,0,0.2) 0%, rgba(216,255,0,0.05) 40%, transparent 70%); filter:blur(40px); animation: orbMove1 8s ease-in-out infinite alternate;"></div>
          <p style="position:absolute; font-family:'Inter',sans-serif; font-weight:800; font-size:clamp(28px,4vw,52px); color:rgba(255,255,255,0.9); letter-spacing:-0.02em; text-align:center; line-height:1.3;">
            Beyond the<br/>ordinary
          </p>
        </div>
        <!-- Replace above with: <video autoplay muted loop playsinline style="width:100%;height:100%;object-fit:cover;"><source src="/videos/hero-visual.mp4" type="video/mp4" /></video> -->
      </div>
    </section>

    <!-- ========== ABOUT ========== -->
    <section class="section-padding" style="background:var(--color-bg);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start reveal">

          <!-- Left: Statement -->
          <div>
            <h2 class="heading-lg" style="font-size:clamp(24px,3.5vw,36px); line-height:1.4;">
              私たちは、企業の課題を、<br/>
              実用化可能なAIへと<br/>
              迅速に変換します。
            </h2>
          </div>

          <!-- Right: Description + partners -->
          <div>
            <p class="body-md mb-8" style="max-width:480px;">
              AltShiftは、中小企業に特化したAIコンサルティング&エンジニアリング企業です。
              お客様の競争優位性の中心となるAIソリューションの設計、構築、運用を行っています。
            </p>
            <div class="flex items-center gap-3">
              <div style="width:8px; height:8px; border-radius:50%; background:var(--color-neon);"></div>
              <span style="font-size:14px; font-weight:500; color:var(--color-ink-sub);">中小企業専門 × AI特化 × 福岡発全国対応</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== CLIENT LOGOS ========== -->
    <section class="section-padding-sm" style="background:var(--color-bg);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center">
        <p class="body-md mb-10 reveal" style="color:var(--color-ink-muted);">
          当社のクライアントには以下のような企業が含まれます
        </p>
        <div class="flex items-center justify-center gap-12 flex-wrap reveal">
          <!-- CLIENT LOGO SLOTS: Replace with <img class="client-logo" src="..." alt="..." /> -->
          {['三栄リフォーム', "BAR Kar's", '株式会社伸明', '株式会社BEGINS'].map(name => (
            <span style="font-family:'Inter','Noto Sans JP',sans-serif; font-weight:700; font-size:16px; color:var(--color-ink); opacity:0.4; letter-spacing:0.02em;">
              {name}
            </span>
          ))}
        </div>
      </div>
    </section>

    <div class="section-divider max-w-7xl mx-auto"></div>

    <!-- ========== ALTSHIFT 3-LAYER METHOD ========== -->
    <section class="section-padding" style="background:var(--color-bg);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-16 reveal">
          <p class="section-label mb-4" style="text-transform:uppercase; letter-spacing:0.1em;">Our Methodology</p>
          <h2 class="heading-lg mb-4">AltShift 3-Layer メソッド</h2>
          <p class="body-md" style="max-width:600px; margin:0 auto;">中小企業の集客・業務を3つのレイヤーで最適化。段階的にAIを導入し、持続的な成長基盤を構築します。</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger">
          {[
            { layer: 'Layer 1', title: '見つけてもらう', sub: 'Web × SEO × GEO', desc: 'Google検索・AI検索・Googleマップで上位表示。お客様があなたの会社を「見つけられる」状態を作ります。', color: '#1456FB' },
            { layer: 'Layer 2', title: '逃さない', sub: 'LINE × チャットボット', desc: '24時間自動応答・予約管理・リマインド配信。問い合わせから来店・契約までの取りこぼしをゼロにします。', color: '#D8FF00' },
            { layer: 'Layer 3', title: '育てる', sub: 'AI分析 × 改善ループ', desc: 'データに基づいた月次改善。KPI追跡・A/Bテスト・コンテンツ更新で、成果を継続的に引き上げます。', color: '#FFFFFF' },
          ].map(l => (
            <div class="reveal t-card p-8 flex flex-col" style={`border-top:3px solid ${l.color};`}>
              <p class="text-xs font-semibold mb-2" style={`color:${l.color}; letter-spacing:0.1em; text-transform:uppercase;`}>{l.layer}</p>
              <h3 class="heading-md mb-1">{l.title}</h3>
              <p class="text-xs mb-4" style="color:var(--color-ink-dim);">{l.sub}</p>
              <p class="body-sm flex-1">{l.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="section-divider max-w-7xl mx-auto"></div>

    <!-- ========== SERVICES (01-04 Cards) ========== -->
    <section class="section-padding" style="background:var(--color-bg);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <h2 class="heading-lg text-center mb-16 reveal">当社のサービス</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 stagger">
          {[
            { num: '01', title: 'AI導入戦略', desc: '経営課題の分析、AI教育、ROIモデル、そして貴社の課題と目標に合致したAIロードマップを、最短2週間で提供します。', href: '/service/ai-consulting' },
            { num: '02', title: 'カスタムAIソリューション', desc: '競争優位性を高め、コストを削減し、新たなビジネスチャンスを創出するために構築されたAIシステム。通常12週間以内に本番稼働を実現します。', href: '/service/ai-development' },
            { num: '03', title: 'Web制作 × SEO/GEO', desc: 'Google・ChatGPT・Claudeに選ばれるWebサイト。AI時代の検索対応設計で、検索・地図双方からの集客基盤を構築します。', href: '/service/web-seo' },
            { num: '04', title: 'LINE自動化 × 業務効率化', desc: '24時間365日の自動応答で機会損失をゼロに。チャットボット構築・自動配信・顧客管理で組織全体の業務を効率化します。', href: '/service/line-automation' },
          ].map(s => (
            <a href={s.href} class="reveal t-card p-7 flex flex-col" style="min-height:280px; text-decoration:none;">
              <p class="service-num mb-4">{s.num}</p>
              <h3 class="heading-md mb-4">{s.title}</h3>
              <p class="body-sm flex-1">{s.desc}</p>
              <span class="neon-link mt-4" style="font-size:13px;">詳しく見る →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== TECHNOLOGY STACK ========== -->
    <section style="background:var(--color-bg-elevated); overflow:hidden;">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 section-padding text-center">
        <p class="section-label mb-4 reveal" style="text-transform:uppercase; letter-spacing:0.1em;">Technology Stack</p>
        <h2 class="heading-lg mb-6 reveal">使用テクノロジー</h2>
        <p class="body-md mb-12 reveal" style="max-width:600px; margin-left:auto; margin-right:auto;">
          世界最先端のAIモデルとクラウド基盤を駆使し、お客様の課題に最適なソリューションを構築します。
        </p>
      </div>
      <!-- Infinite scrolling marquee -->
      <div class="tech-marquee-wrapper reveal">
        <div class="tech-marquee">
          <div class="tech-marquee-track">
            {[
              { name: 'Claude', sub: 'Anthropic', icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none"><path d="M16.5 3.5L20.5 12L16.5 20.5H13L17 12L13 3.5H16.5ZM7.5 3.5L11.5 12L7.5 20.5H11L15 12L11 3.5H7.5Z" fill="currentColor" opacity="0.9"/></svg>` },
              { name: 'GPT-4o', sub: 'OpenAI', icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none"><path d="M22.282 9.821a5.985 5.985 0 00-.516-4.91 6.046 6.046 0 00-6.51-2.9A6.065 6.065 0 0011.698.414a6.018 6.018 0 00-5.755 4.206 5.993 5.993 0 00-4.008 2.907 6.042 6.042 0 00.749 7.088 5.985 5.985 0 00.516 4.911 6.046 6.046 0 006.51 2.9A6.065 6.065 0 0013.302 23.586a6.018 6.018 0 005.755-4.206 5.993 5.993 0 004.008-2.907 6.042 6.042 0 00-.749-7.088z" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>` },
              { name: 'Gemini', sub: 'Google', icon: `<svg viewBox="0 0 24 24" width="28" height="28"><path d="M12 2L8.5 8.5L2 12l6.5 3.5L12 22l3.5-6.5L22 12l-6.5-3.5L12 2z" fill="currentColor" opacity="0.85"/></svg>` },
              { name: 'Perplexity', sub: 'AI Search', icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M12 3v18M3 12h18M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1" opacity="0.6"/></svg>` },
              { name: 'LINE', sub: 'Messaging API', icon: `<svg viewBox="0 0 24 24" width="28" height="28"><path d="M12 2C6.48 2 2 5.82 2 10.5c0 2.93 1.95 5.5 4.86 7.04-.19.7-.68 2.6-.78 3-.13.52.19.51.4.37.17-.1 2.64-1.8 3.72-2.53.57.08 1.16.12 1.8.12 5.52 0 10-3.82 10-8.5S17.52 2 12 2z" fill="currentColor" opacity="0.85"/></svg>` },
              { name: 'Google Cloud', sub: 'Platform', icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none"><path d="M12 7.5L14.5 12H9.5L12 7.5z" fill="currentColor" opacity="0.5"/><path d="M12 3a9 9 0 100 18 9 9 0 000-18z" stroke="currentColor" stroke-width="1.5"/><path d="M12 3v4.5M12 16.5V21M3 12h4.5M16.5 12H21" stroke="currentColor" stroke-width="1" opacity="0.5"/></svg>` },
              { name: 'Whisper', sub: 'OpenAI', icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z" stroke="currentColor" stroke-width="1.5"/><path d="M19 10v2a7 7 0 01-14 0v-2" stroke="currentColor" stroke-width="1.5"/><line x1="12" y1="19" x2="12" y2="23" stroke="currentColor" stroke-width="1.5"/></svg>` },
              { name: 'Stable Diffusion', sub: 'Stability AI', icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none"><rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.5"/><circle cx="9" cy="9" r="2" fill="currentColor" opacity="0.6"/><path d="M3 16l5-5 4 4 3-3 6 6" stroke="currentColor" stroke-width="1.2"/></svg>` },
              { name: 'LangChain', sub: 'Framework', icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none"><circle cx="6" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/><circle cx="18" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M9 12h6" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="5" r="2.5" stroke="currentColor" stroke-width="1.3"/><circle cx="12" cy="19" r="2.5" stroke="currentColor" stroke-width="1.3"/><path d="M12 7.5v4.5M12 12v4.5" stroke="currentColor" stroke-width="1" opacity="0.5"/></svg>` },
              { name: 'Astro', sub: 'Web Framework', icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none"><path d="M8 21s-2-4-2-8 4-12 6-13c2 1 6 9 6 13s-2 8-2 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M12 14a2 2 0 100 4 2 2 0 000-4z" fill="currentColor" opacity="0.6"/></svg>` },
              { name: 'Vercel', sub: 'Deployment', icon: `<svg viewBox="0 0 24 24" width="28" height="28"><path d="M12 2L2 19.5h20L12 2z" fill="currentColor" opacity="0.85"/></svg>` },
              { name: 'n8n', sub: 'Automation', icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none"><rect x="2" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="16" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="9" y="3" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="9" y="15" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/><path d="M8 12h2M14 12h2M12 9v-0M12 15v0" stroke="currentColor" stroke-width="1.2"/></svg>` },
            ].map(t => (
              <div class="tech-item">
                <div class="tech-icon" set:html={t.icon} />
                <div>
                  <p class="tech-name">{t.name}</p>
                  <p class="tech-sub">{t.sub}</p>
                </div>
              </div>
            ))}
            {/* Duplicate for seamless loop */}
            {[
              { name: 'Claude', sub: 'Anthropic', icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none"><path d="M16.5 3.5L20.5 12L16.5 20.5H13L17 12L13 3.5H16.5ZM7.5 3.5L11.5 12L7.5 20.5H11L15 12L11 3.5H7.5Z" fill="currentColor" opacity="0.9"/></svg>` },
              { name: 'GPT-4o', sub: 'OpenAI', icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none"><path d="M22.282 9.821a5.985 5.985 0 00-.516-4.91 6.046 6.046 0 00-6.51-2.9A6.065 6.065 0 0011.698.414a6.018 6.018 0 00-5.755 4.206 5.993 5.993 0 00-4.008 2.907 6.042 6.042 0 00.749 7.088 5.985 5.985 0 00.516 4.911 6.046 6.046 0 006.51 2.9A6.065 6.065 0 0013.302 23.586a6.018 6.018 0 005.755-4.206 5.993 5.993 0 004.008-2.907 6.042 6.042 0 00-.749-7.088z" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>` },
              { name: 'Gemini', sub: 'Google', icon: `<svg viewBox="0 0 24 24" width="28" height="28"><path d="M12 2L8.5 8.5L2 12l6.5 3.5L12 22l3.5-6.5L22 12l-6.5-3.5L12 2z" fill="currentColor" opacity="0.85"/></svg>` },
              { name: 'Perplexity', sub: 'AI Search', icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M12 3v18M3 12h18M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1" opacity="0.6"/></svg>` },
              { name: 'LINE', sub: 'Messaging API', icon: `<svg viewBox="0 0 24 24" width="28" height="28"><path d="M12 2C6.48 2 2 5.82 2 10.5c0 2.93 1.95 5.5 4.86 7.04-.19.7-.68 2.6-.78 3-.13.52.19.51.4.37.17-.1 2.64-1.8 3.72-2.53.57.08 1.16.12 1.8.12 5.52 0 10-3.82 10-8.5S17.52 2 12 2z" fill="currentColor" opacity="0.85"/></svg>` },
              { name: 'Google Cloud', sub: 'Platform', icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none"><path d="M12 7.5L14.5 12H9.5L12 7.5z" fill="currentColor" opacity="0.5"/><path d="M12 3a9 9 0 100 18 9 9 0 000-18z" stroke="currentColor" stroke-width="1.5"/><path d="M12 3v4.5M12 16.5V21M3 12h4.5M16.5 12H21" stroke="currentColor" stroke-width="1" opacity="0.5"/></svg>` },
              { name: 'Whisper', sub: 'OpenAI', icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z" stroke="currentColor" stroke-width="1.5"/><path d="M19 10v2a7 7 0 01-14 0v-2" stroke="currentColor" stroke-width="1.5"/><line x1="12" y1="19" x2="12" y2="23" stroke="currentColor" stroke-width="1.5"/></svg>` },
