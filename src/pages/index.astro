---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

const gradLabel = 'font-family:\'Inter\',sans-serif; font-weight:700; font-size:12px; letter-spacing:0.2em; text-transform:uppercase; background:linear-gradient(135deg,#1B5EBE,#4A90D9); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;'
const gradDeco  = 'font-family:\'Inter\',sans-serif; font-weight:900; font-size:clamp(60px,10vw,120px); letter-spacing:-0.05em; opacity:0.04; background:linear-gradient(135deg,#1B5EBE,#4A90D9); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; line-height:1; pointer-events:none; user-select:none;'
---

<Layout>
  <Nav />
  <main>

    <!-- ========== HERO ========== -->
    <section id="hero" class="relative overflow-hidden" style="min-height:100vh; display:flex; align-items:center;">

      <!-- 背景画像 -->
      <div style="position:absolute; inset:0; z-index:0;">
        <img
          src="/images/hero_fukuoka.jpg"
          alt="福岡天神×AIネットワーク"
          style="width:100%; height:100%; object-fit:cover; object-position:center center; animation:kenBurns 2.5s ease forwards;"
        />
        <!-- 左→右グラデーションオーバーレイ -->
        <div style="position:absolute; inset:0; background:linear-gradient(to right, rgba(255,255,255,1.0) 0%, rgba(255,255,255,0.97) 25%, rgba(255,255,255,0.85) 40%, rgba(255,255,255,0.5) 55%, rgba(255,255,255,0.15) 70%, rgba(255,255,255,0.0) 100%);"></div>
        <!-- 上下フェード -->
        <div style="position:absolute; inset:0; background:linear-gradient(to bottom, rgba(255,255,255,0.3) 0%, rgba(255,255,255,0.0) 20%, rgba(255,255,255,0.0) 80%, rgba(255,255,255,0.4) 100%);"></div>
      </div>

      <!-- テキストコンテンツ -->
      <div style="position:relative; z-index:10; max-width:1100px; margin:0 auto; padding:120px 48px 80px; width:100%;">
        <div style="max-width:560px;">

          <!-- バッジ -->
          <div style="display:flex; gap:8px; margin-bottom:24px; flex-wrap:wrap;">
            {['福岡発', 'AI導入支援', '中小企業特化'].map(t => (
              <span style="border:1px solid #1B5EBE; color:#1B5EBE; font-size:12px; padding:4px 12px; border-radius:999px; letter-spacing:0.05em;">
                {t}
              </span>
            ))}
          </div>

          <!-- H1 -->
          <h1 style="font-family:'Inter','Noto Sans JP',sans-serif; font-weight:900; font-size:clamp(36px,5vw,64px); line-height:1.15; letter-spacing:-0.02em; color:#1A1A1A; margin-bottom:20px;">
            福岡の中小企業に、<br/>
            <span style="background:linear-gradient(135deg,#1B5EBE 0%,#4A90D9 60%,#C8A15A 100%); background-size:300% auto; -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; animation:shimmer 4s linear infinite;">AIという選択肢を。</span>
          </h1>

          <!-- サブコピー -->
          <p style="font-size:17px; color:#4A4A4A; line-height:1.8; margin-bottom:36px; font-weight:400;">
            福岡発。AIで、選ばれる会社をつくる。<br/>
            週1〜2回、企業に入り込んでAI化を伴走します。
          </p>

          <!-- CTAボタン -->
          <div style="display:flex; gap:16px; flex-wrap:wrap;">
            <a href="https://lin.ee/VOiIxYB" target="_blank" rel="noopener noreferrer"
               style="display:inline-flex; align-items:center; gap:8px; background:#06C755; color:white; font-weight:600; font-size:15px; padding:14px 28px; border-radius:6px; text-decoration:none; transition:opacity 0.2s;"
               onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
              💬 LINEで無料相談する
            </a>
            <a href="#service"
               style="display:inline-flex; align-items:center; gap:8px; background:transparent; color:#1A1A1A; font-weight:600; font-size:15px; padding:14px 28px; border-radius:6px; border:1.5px solid #1A1A1A; text-decoration:none; transition:all 0.2s;"
               onmouseover="this.style.borderColor='#1B5EBE';this.style.color='#1B5EBE'"
               onmouseout="this.style.borderColor='#1A1A1A';this.style.color='#1A1A1A'">
              事業内容を見る →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== 課題提起 ========== -->
    <section style="background:#F4F4F4; padding:96px 24px;">
      <div class="max-w-6xl mx-auto text-center">
        <h2 class="mb-14 reveal" style="font-size:clamp(28px,4vw,40px);">
          こんなお悩みはありませんか？
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {[
            { icon: 'M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3M12 17h.01', circle: true, text: 'AIを使いたいけど、何から始めればいいかわからない', delay: '0s' },
            { icon: 'M18 20v-10M12 20v-16M6 20v-6', circle: false, text: '集客・問い合わせが思うように増えない', delay: '0.15s' },
            { icon: 'M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0-6 0M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14', circle: false, text: 'ITが苦手なスタッフでも使える仕組みが欲しい', delay: '0.3s' },
          ].map(c => (
            <div class="reveal p-8 text-left bg-white"
                 style={`border-top:3px solid #1B5EBE; border-left:1px solid #E5E5E5; border-right:1px solid #E5E5E5; border-bottom:1px solid #E5E5E5; border-radius:8px; transition-delay:${c.delay};`}>
              <div class="w-12 h-12 flex items-center justify-center mb-5"
                   style="background:rgba(27,94,190,0.08); border-radius:8px;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1B5EBE" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  {c.circle && <circle cx="12" cy="12" r="10"/>}
                  <path d={c.icon}/>
                </svg>
              </div>
              <p style="font-weight:500; color:#1A1A1A; line-height:1.8; font-size:15px;">{c.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== SERVICE（Bento） ========== -->
    <section id="service" class="relative overflow-hidden" style="background:#FFFFFF; padding:96px 24px;">
      <p class="absolute top-0 left-4 select-none pointer-events-none leading-none" style={gradDeco}>SERVICE</p>

      <div class="relative max-w-6xl mx-auto">
        <div class="mb-12 reveal">
          <p style={gradLabel} class="mb-2">— 事業内容</p>
          <h2 style="font-size:clamp(28px,4vw,40px);">事業内容</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

          <div class="reveal md:col-span-2 p-8 border hover:shadow-lg transition-shadow"
               style="background:#FFFFFF; border-color:#E5E5E5; border-radius:8px;">
            <p style={gradLabel} class="mb-3">Main Service</p>
            <h3 style="font-size:22px; margin-bottom:12px;">外部CAIOサービス</h3>
            <p style="font-size:14px; color:#6B6B6B; line-height:1.9; font-weight:300; margin-bottom:20px;">
              週1〜2回、企業に入り込んでAI化を伴走。AI戦略の策定から実装まで、伴走型で支援します。
              世界的に広がるCAIO（最高AI責任者）の中小企業向けローカル版として機能します。
            </p>
            <div class="flex flex-wrap gap-2 mb-6">
              {['週1〜2回訪問', 'AI戦略策定', '実装まで対応', '伴走型支援'].map(t => (
                <span style="font-size:12px; font-weight:500; letter-spacing:0.05em; padding:5px 12px; border:1px solid #1B5EBE; color:#1B5EBE; background:rgba(27,94,190,0.06); border-radius:4px;">
                  {t}
                </span>
              ))}
            </div>
            <a href="/service"
               class="inline-flex items-center gap-2 text-sm text-white transition-opacity hover:opacity-90"
               style="background:#1B5EBE; font-weight:600; letter-spacing:0.05em; padding:10px 20px; border-radius:4px;">
              詳しく見る →
            </a>
          </div>

          <div class="reveal p-7 border hover:shadow-lg transition-shadow"
               style="background:#FFFFFF; border-color:#E5E5E5; border-radius:8px;">
            <div class="w-10 h-10 flex items-center justify-center mb-4"
                 style="background:rgba(27,94,190,0.08); border-radius:8px;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1B5EBE" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
            </div>
            <h3 style="font-size:17px; margin-bottom:8px;">AIシステム開発</h3>
            <p style="font-size:12px; color:#1B5EBE; margin-bottom:6px; font-weight:500;">Lumio</p>
            <p style="font-size:14px; color:#6B6B6B; line-height:1.8; font-weight:300;">
              リフォーム業向けAIシステム。見積もり自動化・顧客フォローアップを一括自動化。
            </p>
          </div>

          <div class="reveal p-7 border hover:shadow-lg transition-shadow"
               style="background:#FFFFFF; border-color:#E5E5E5; border-radius:8px;">
            <div class="w-10 h-10 flex items-center justify-center mb-4"
                 style="background:rgba(27,94,190,0.08); border-radius:8px;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1B5EBE" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
            </div>
            <h3 style="font-size:17px; margin-bottom:8px;">Web制作 × SEO/GEO</h3>
            <p style="font-size:14px; color:#6B6B6B; line-height:1.8; font-weight:300;">
              AI時代の検索対応サイト。ChatGPT・Claudeにも選ばれるコンテンツ設計。
            </p>
          </div>

          <div class="reveal md:col-span-2 p-7 border hover:shadow-lg transition-shadow flex flex-col md:flex-row items-start gap-6"
               style="background:#FFFFFF; border-color:#E5E5E5; border-radius:8px;">
            <div class="w-10 h-10 flex items-center justify-center flex-shrink-0"
                 style="background:rgba(27,94,190,0.08); border-radius:8px;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1B5EBE" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <div>
              <h3 style="font-size:17px; margin-bottom:8px;">LINE自動化</h3>
              <p style="font-size:14px; color:#6B6B6B; line-height:1.8; font-weight:300;">
                24時間365日の自動応答・フォローアップ。営業時間外の機会損失をゼロにします。チャットボット構築・自動配信・セグメント配信に対応。
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ========== CASE ========== -->
    <section class="relative overflow-hidden" style="background:#F4F4F4; padding:96px 24px;">
      <p class="absolute top-0 left-4 select-none pointer-events-none leading-none" style={gradDeco}>CASE</p>

      <div class="relative max-w-6xl mx-auto">
        <div class="mb-12 reveal">
          <p style={gradLabel} class="mb-2">— 導入実績</p>
          <h2 style="font-size:clamp(28px,4vw,40px);">導入実績</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {[
            { name: '三栄リフォーム', tags: ['Web制作','SEO/GEO','LINE自動化'], title: '三栄リフォーム × AltShift', desc: 'AI時代の検索対応Webサイトを実装。SEO/GEO対策でGoogleとAIに選ばれるコンテンツを構築。', url: 'https://sanei-reform.vercel.app' },
            { name: "BAR Kar's", tags: ['Web制作','LINE自動化','デジタルメニュー'], title: "BAR Kar's × AltShift", desc: '中洲のアフターバー。デジタルメニューとLINE自動応答を導入し、営業時間外の問い合わせを自動化。', url: null },
          ].map(c => (
            <div class="reveal overflow-hidden hover:shadow-md transition-shadow bg-white"
                 style="border-top:3px solid #1B5EBE; border-left:1px solid #E5E5E5; border-right:1px solid #E5E5E5; border-bottom:1px solid #E5E5E5; border-radius:8px;">
              <div class="h-48 flex items-center justify-center"
                   style="background:#F4F4F4; border-bottom:1px solid #E5E5E5;">
                <p style="font-size:13px; font-weight:600; color:#1B5EBE; letter-spacing:0.05em;">{c.name}</p>
              </div>
              <div class="p-6">
                <div class="flex flex-wrap gap-2 mb-3">
                  {c.tags.map(t => (
                    <span style="font-size:11px; font-weight:500; padding:4px 10px; border:1px solid rgba(27,94,190,0.2); color:#1B5EBE; background:rgba(27,94,190,0.06); border-radius:4px;">{t}</span>
                  ))}
                </div>
                <h3 style="font-size:15px; font-weight:700; margin-bottom:8px; color:#1A1A1A;">{c.title}</h3>
                <p style="font-size:14px; color:#6B6B6B; line-height:1.8; font-weight:300; margin-bottom:16px;">{c.desc}</p>
                {c.url
                  ? <a href={c.url} target="_blank" rel="noopener noreferrer" style="font-size:13px; font-weight:600; color:#1B5EBE; text-decoration:none;" class="hover:underline">サイトを見る →</a>
                  : <span style="font-size:12px; color:#6B6B6B;">※ URL準備中</span>
                }
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== 代表紹介 ========== -->
    <section style="background:#FFFFFF; padding:96px 0;">
      <div style="max-width:900px; margin:0 auto; padding:0 24px;">
        <div class="grid grid-cols-1 md:grid-cols-2 reveal" style="gap:64px; align-items:center;">

          <div style="border-radius:8px; height:400px; overflow:hidden;">
            <img
              src="/images/daiki_profile.jpg"
              alt="ディーチャー（坂口 大輝）AltShift代表"
              style="width:100%; height:100%; object-fit:cover; object-position:center top; border-radius:8px;"
            />
          </div>

          <div>
            <p style={gradLabel} class="mb-4">— 代表について</p>
            <div style="height:3px; background:#C8A15A; border-radius:2px; margin-bottom:24px; animation:lineGrow 0.8s ease forwards;"></div>
            <h2 style="font-size:32px; font-weight:800; color:#1A1A1A; margin-bottom:8px; letter-spacing:-0.03em;">ディーチャー</h2>
            <p style="color:#6B6B6B; font-size:14px; font-weight:300; margin-bottom:32px;">坂口 大輝 / AltShift 代表 / External CAIO</p>

            <div style="border-left:3px solid #C8A15A; padding-left:20px; margin-bottom:32px;">
              <p style="font-family:'Inter','Noto Sans JP',sans-serif; font-weight:900; font-size:22px; line-height:1.5; background:linear-gradient(135deg,#1B5EBE 0%,#4A90D9 70%,#C8A15A 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">
                AIで、福岡をアジアのリーダーへ。
              </p>
            </div>

            <p style="color:#1A1A1A; line-height:1.9; font-size:15px; margin-bottom:16px; font-weight:400;">
              AIという道具は、仕事を奪うのではなく、人に新しい役割を与える。
              企業に生まれた「余白」は、人材育成の時間となり、新事業の種となり、地域経済の活力へと変わっていく。
            </p>
            <p style="color:#1A1A1A; line-height:1.9; font-size:15px; margin-bottom:16px; font-weight:400;">
              一社一社の変革が積み重なったとき、福岡はアジアのAI先進都市になる。
              その確信を持って、最先端の知識と実装力で、福岡の企業の最前線に立ち続けます。
            </p>
            <p style="color:#1B5EBE; font-weight:700; font-size:15px; margin-bottom:32px;">
              ただ伴走するのではなく、一緒に未来をつくる。共に、進化し続けましょう。
            </p>
            <a href="/company" style="color:#1B5EBE; font-size:14px; font-weight:600; text-decoration:none; border-bottom:1px solid #C8A15A; padding-bottom:2px;">
              もっと詳しく →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== FAQ ========== -->
    <section style="background:#FFFFFF; padding:96px 24px;">
      <div class="max-w-3xl mx-auto">
        <div class="mb-12 text-center reveal">
          <p style={gradLabel} class="mb-2">— FAQ</p>
          <h2 style="font-size:clamp(28px,4vw,40px);">よくある質問</h2>
        </div>

        <div class="flex flex-col gap-3" id="faq-list">
          {[
            { q: 'AltShiftはどんなサービスですか？', a: '福岡を拠点に、リフォーム・建設業などの中小企業向けにAI導入支援を提供しています。外部CAIOとして週1〜2回企業に入り込み、AI戦略の策定から実装まで一貫してサポートします。' },
            { q: '料金はいくらですか？', a: '月額3万円〜8万円の3層パッケージ（初期費用別途）。まずはLINEでヒアリングし、最適なプランをご提案します。' },
            { q: '福岡以外でも対応できますか？', a: 'はい。オンライン対応可能で、全国対応しています。' },
            { q: 'どのくらいで成果が出ますか？', a: 'SEO効果は3〜6ヶ月、LINE自動化は導入翌月から問い合わせの変化が出始めるケースが多いです。' },
            { q: 'AIを使ったことがない会社でも導入できますか？', a: 'はい。AI未経験の企業向けに、設定から運用まで一貫してサポートします。' },
          ].map(item => (
            <div class="reveal faq-item border bg-white" style="border-color:#E5E5E5; border-radius:8px; overflow:hidden;">
              <button class="faq-btn w-full text-left px-6 py-5 flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors" aria-expanded="false">
                <span style="font-weight:500; color:#1A1A1A; font-size:15px;">{item.q}</span>
                <svg class="faq-icon flex-shrink-0 transition-transform duration-200" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1B5EBE" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p style="font-size:14px; color:#6B6B6B; line-height:1.9; font-weight:300;">{item.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== 最終CTA ========== -->
    <section class="text-white text-center" style="background:#1B5EBE; padding:96px 24px;">
      <div class="max-w-2xl mx-auto">
        <h2 class="mb-5 leading-snug reveal" style="font-size:clamp(28px,4vw,40px); letter-spacing:-0.03em;">
          まずは、LINEで気軽に<br />話しかけてください。
        </h2>
        <p class="mb-8 reveal" style="font-size:15px; color:rgba(255,255,255,0.75); font-weight:300; line-height:1.9;">
          返信は通常24時間以内。無料でご相談いただけます。
        </p>
        <div class="reveal">
          <a href="https://lin.ee/VOiIxYB"
             target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 text-white transition-opacity hover:opacity-90"
             style="background:#06C755; font-weight:600; font-size:16px; letter-spacing:0.05em; padding:16px 32px; border-radius:4px;">
            💬 LINEで無料相談する
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling as HTMLElement
      const icon = btn.querySelector('.faq-icon') as HTMLElement
      const isOpen = btn.getAttribute('aria-expanded') === 'true'
      document.querySelectorAll('.faq-btn').forEach(b => {
        b.setAttribute('aria-expanded', 'false')
        ;(b.nextElementSibling as HTMLElement).classList.add('hidden')
        ;(b.querySelector('.faq-icon') as HTMLElement).style.transform = 'rotate(0deg)'
      })
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true')
        answer.classList.remove('hidden')
        icon.style.transform = 'rotate(180deg)'
      }
    })
  })
</script>
