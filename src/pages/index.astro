---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import SubsidySection from '../components/SubsidySection.astro'
import LineButton from '../components/LineButton.astro'
import Footer from '../components/Footer.astro'
import DemoChat from '../components/DemoChat.tsx'

const faqItems = [
  { q: 'AltShiftはどんなサービスですか？', a: '中小企業向けにAI導入を戦略から実装・運用まで一貫支援しています。ツール導入で終わらせず、現場で使いこなせる状態まで伴走します。' },
  { q: '料金はいくらですか？', a: 'サービスにより異なります。Web制作・LINE自動化は月額3万円〜、AIコンサルティングは戦略診断30万円〜・月額顧問20万円〜、AI業務自動化は案件規模に応じてお見積もり。補助金を活用できる場合があります（採択は審査によります）。' },
  { q: 'AIを使ったことがない会社でも大丈夫ですか？', a: 'はい。ゼロからの設計・設定・研修まで一貫サポート。むしろAI未経験の企業様こそ成果が出やすいパターンです。' },
  { q: 'どのくらいで成果が出ますか？', a: 'LINE自動化は翌月から、SEOは通常3〜6ヶ月。成果が出やすい施策から優先着手します。' },
  { q: '福岡以外でも対応できますか？', a: 'はい。オンラインで全国対応。福岡市内・近郊は訪問対応も可能です。' },
]

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
}
---

<Layout
  title="AltShift｜福岡の中小企業向けAIコンサルティング・AI導入支援"
  description="福岡発、中小企業専門のAIコンサルティング。AI導入戦略・システム開発・Web制作・LINE自動化を一貫支援。採用業務工数50%削減の実績あり。無料相談受付中。"
  schemaData={faqSchema}
>
  <Nav />
  <main>

    <!-- ========== HERO ========== -->
    <section class="hero-gradient relative overflow-hidden" style="min-height:100vh; display:flex; align-items:center;">

      <!-- Dot grid overlay -->
      <div class="hero-dot-grid" style="position:absolute; inset:0; z-index:1;"></div>

      <!-- Content -->
      <div class="hero-content-wrapper" style="position:relative; z-index:10; max-width:1280px; margin:0 auto; padding:160px 24px 100px; width:100%;">
        <div class="grid grid-cols-12 gap-8 lg:gap-12 items-center">

          <!-- Left: 7カラム -->
          <div class="col-span-12 lg:col-span-7">
            <div class="accent-line mb-8"></div>
            <h1 class="heading-hero hero-title" style="line-height:1.08; color:#FFFFFF;">
              AIを、「使える人」ごと<br/>社内に。
            </h1>
            <p class="body-lg hero-subtitle mt-6 mb-4" style="max-width:520px; color:rgba(255,255,255,0.85);">
              「導入して終わり」にしない。現場に入り、3ヶ月でAIを回せる人材を育てる。
            </p>
            <p class="hero-subtitle mb-8" style="font-size:15px; max-width:520px; color:rgba(255,255,255,0.65);">
              診断2週間、稼働12週間。<a href="/simulator" style="color:rgba(255,255,255,0.75); text-decoration:underline; text-underline-offset:3px;">補助金を活用できる場合があります</a>。
            </p>
            <div class="flex flex-col items-center sm:items-start gap-3 hero-subtitle">
              <a href="/contact" class="btn-primary">
                無料で相談する
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
              <LineButton size="sm" />
              <p style="font-size:12px; color:rgba(255,255,255,0.45); margin-top:-2px;">無料・30分・オンライン対応</p>
              <a href="/case" class="btn-secondary-ghost" style="color:rgba(255,255,255,0.7);">
                導入事例を見る →
              </a>
            </div>
          </div>

          <!-- Right: 5カラム（数字グリッド）-->
          <div class="col-span-12 lg:col-span-5 flex items-center hero-subtitle">
            <!-- 実績数字グリッド 2x2 -->
            <div class="grid grid-cols-2 gap-3">
              <div style="background:rgba(255,255,255,0.1); backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,0.15); border-radius:12px; padding:20px;">
                <p style="font-family:'Inter',sans-serif; font-weight:800; font-size:clamp(28px,3vw,36px); color:#FFFFFF; line-height:1; margin-bottom:4px; font-variant-numeric:tabular-nums;">
                  50<span style="font-size:clamp(16px,2vw,20px); color:rgba(255,255,255,0.7);">%</span>
                </p>
                <p style="font-size:12px; color:rgba(255,255,255,0.6); line-height:1.4;">業務効率化（実績平均）</p>
              </div>
              <div style="background:rgba(255,255,255,0.1); backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,0.15); border-radius:12px; padding:20px;">
                <p style="font-family:'Inter',sans-serif; font-weight:800; font-size:clamp(28px,3vw,36px); color:#FFFFFF; line-height:1; margin-bottom:4px; font-variant-numeric:tabular-nums;">
                  2<span style="font-size:clamp(16px,2vw,20px); color:rgba(255,255,255,0.7);">週間</span>
                </p>
                <p style="font-size:12px; color:rgba(255,255,255,0.6); line-height:1.4;">戦略診断パック納期</p>
              </div>
              <div style="background:rgba(255,255,255,0.1); backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,0.15); border-radius:12px; padding:20px;">
                <p style="font-family:'Inter',sans-serif; font-weight:800; font-size:clamp(28px,3vw,36px); color:#FFFFFF; line-height:1; margin-bottom:4px; font-variant-numeric:tabular-nums;">
                  4<span style="font-size:clamp(16px,2vw,20px); color:rgba(255,255,255,0.7);">社</span>
                </p>
                <p style="font-size:12px; color:rgba(255,255,255,0.6); line-height:1.4;">導入実績</p>
              </div>
              <div style="background:rgba(255,255,255,0.1); backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,0.15); border-radius:12px; padding:20px;">
                <p style="font-family:'Inter',sans-serif; font-weight:800; font-size:clamp(28px,3vw,36px); color:#FFFFFF; line-height:1; margin-bottom:4px; font-variant-numeric:tabular-nums;">
                  3<span style="font-size:clamp(16px,2vw,20px); color:rgba(255,255,255,0.7);">ヶ月</span>
                </p>
                <p style="font-size:12px; color:rgba(255,255,255,0.6); line-height:1.4;">集中伴走</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Demo scroll link -->
        <div class="text-center mt-12 hero-subtitle" style="animation-delay:0.2s;">
          <a href="#demo-section" style="color:rgba(255,255,255,0.7); font-size:13px; text-decoration:none; display:inline-flex; align-items:center; gap:6px; transition:color 0.2s;">
            <span>→ デモを体験する</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transform:rotate(90deg);">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ========== HERO → CONSTELLATION BRIDGE ========== -->
    <div class="hero-bridge"></div>

    <!-- ========== CONSTELLATION (星座ビジュアル) ========== -->
    <section class="constellation" id="constellation">
      <div class="constellation-pin" id="constellation-pin">
        <canvas class="particle-canvas" id="constellation-particles"></canvas>
        <div class="stage" id="constellation-stage">

          <!-- Header -->
          <div class="constellation-header" id="constellation-header">
            <p class="label">Why AltShift</p>
            <h2>バラバラの業務が、<span style="white-space:nowrap">ひとつの仕組みになる。</span></h2>
          </div>

          <!-- SVG lines -->
          <svg class="line-layer" id="constellation-lines" xmlns="http://www.w3.org/2000/svg"></svg>

          <!-- Hub -->
          <div class="hub" id="constellation-hub">
            <div class="hub-outer">
              <div class="hub-bloom" id="constellation-bloom"></div>
              <div class="hub-ring-2"></div>
              <div class="hub-ring"></div>
              <div class="hub-core" id="constellation-core">
                <div class="hub-label">AI内製化<br/>パッケージ</div>
              </div>
            </div>
          </div>

          <!-- 主役（3枚） -->
          <div class="tile" data-tier="main" data-angle="300" data-dist="54" data-float-speed="5.0" data-float-amp="4">
            <div class="tile-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>
            <div class="tile-label">LINE 24時間自動対応</div>
            <div class="tile-sub">深夜でもAIが即応答</div>
          </div>
          <div class="tile" data-tier="main" data-angle="60" data-dist="56" data-float-speed="4.5" data-float-amp="5">
            <div class="tile-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
            <div class="tile-label">議事録・日報の自動作成</div>
            <div class="tile-sub">会議後すぐに共有可能</div>
          </div>
          <div class="tile" data-tier="main" data-angle="180" data-dist="52" data-float-speed="5.2" data-float-amp="4">
            <div class="tile-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="2" y="3" width="20" height="18" rx="2"/><line x1="8" y1="21" x2="8" y2="13"/><line x1="16" y1="21" x2="16" y2="9"/><path d="M6 9h4v4H6z"/></svg></div>
            <div class="tile-label">請求書・見積もりAI作成</div>
            <div class="tile-sub">入力ミスも工数も削減</div>
          </div>

          <!-- 脇役（5枚） -->
          <div class="tile" data-tier="sub" data-angle="335" data-dist="70" data-float-speed="4.8" data-float-amp="3">
            <div class="tile-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
            <div class="tile-label">問い合わせ自動返信</div>
          </div>
          <div class="tile" data-tier="sub" data-angle="75" data-dist="68" data-float-speed="5.4" data-float-amp="3">
            <div class="tile-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
            <div class="tile-label">顧客リスト自動整理</div>
          </div>
          <div class="tile" data-tier="sub" data-angle="115" data-dist="72" data-float-speed="4.6" data-float-amp="4">
            <div class="tile-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
            <div class="tile-label">予約管理自動化</div>
          </div>
          <div class="tile" data-tier="sub" data-angle="205" data-dist="67" data-float-speed="5.1" data-float-amp="3">
            <div class="tile-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"/></svg></div>
            <div class="tile-label">Googleカレンダー連携</div>
          </div>
          <div class="tile" data-tier="sub" data-angle="245" data-dist="66" data-float-speed="4.9" data-float-amp="3">
            <div class="tile-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 9h.01M12 9h.01M16 9h.01"/></svg></div>
            <div class="tile-label">Slack・Chatwork連携</div>
          </div>

          <!-- 背景群（7枚） -->
          <div class="tile" data-tier="bg" data-angle="5" data-dist="86" data-float-speed="5.8" data-float-amp="2">
            <div class="tile-label">RAG社内ナレッジ検索</div>
          </div>
          <div class="tile" data-tier="bg" data-angle="50" data-dist="88" data-float-speed="6.0" data-float-amp="2">
            <div class="tile-label">AIエージェント</div>
          </div>
          <div class="tile" data-tier="bg" data-angle="95" data-dist="85" data-float-speed="5.5" data-float-amp="2">
            <div class="tile-label">音声AI文字起こし</div>
          </div>
          <div class="tile" data-tier="bg" data-angle="165" data-dist="84" data-float-speed="6.2" data-float-amp="2">
            <div class="tile-label">経費精算AI</div>
          </div>
          <div class="tile" data-tier="bg" data-angle="195" data-dist="90" data-float-speed="5.7" data-float-amp="2">
            <div class="tile-label">データ分析・予測</div>
          </div>
          <div class="tile" data-tier="bg" data-angle="290" data-dist="83" data-float-speed="5.9" data-float-amp="2">
            <div class="tile-label">SEO/GEO対策</div>
          </div>
          <div class="tile" data-tier="bg" data-angle="320" data-dist="87" data-float-speed="6.1" data-float-amp="2">
            <div class="tile-label">Web制作</div>
          </div>

          <!-- Converge message -->
          <div class="converge-msg" id="constellation-msg">
            <h3>ひとつの仕組みに。</h3>
            <p>バラバラだった業務が、統合される。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== CONSTELLATION → WHAT WE DO BRIDGE ========== -->
    <div class="section-bridge"></div>

    <!-- ========== WHAT WE DO (サービス4枚) ========== -->
    <section class="btob-section" id="what-we-do">
      <div class="btob-inner">

        <div class="unified-section-header reveal">
          <span class="section-watermark" aria-hidden="true">WHAT WE DO</span>
          <div class="section-label-row">
            <span class="section-label-line"></span>
            <p class="section-label-text">私たちの役割</p>
          </div>
        </div>

        <h2 class="reveal reveal-d1">その<span class="accent">"ひとつの仕組み"</span>を、<br/>あなたの会社に。</h2>

        <p class="btob-subtitle reveal reveal-d2">バラバラだった業務も、属人化していた作業も、AIで一つに繋がる。<br/>AltShiftは現場に入って一緒に作り、<span class="subtitle-em">"使える人"ごと社内に残します。</span></p>

        <div class="teal-divider reveal reveal-d2"></div>

        <div class="unified-section-header service-section-header reveal reveal-d3">
          <span class="section-watermark" aria-hidden="true">SERVICE</span>
          <div class="section-label-row">
            <span class="section-label-line"></span>
            <p class="section-label-text">事業内容</p>
          </div>
          <p class="service-section-title">御社の状況に合わせて、4つの入り方から選べます。</p>
        </div>

        <div class="service-cards">

          <!-- カード①: 単発AI自動化（入口） -->
          <div class="service-card reveal reveal-d3">
            <p class="service-card-num">01</p>
            <h3>単発AI自動化</h3>
            <p class="service-card-desc">「まず一つだけ自動化したい」に応えます。LINE Botによる問い合わせ対応、見積もり作成、日報集計など、現場の特定業務をピンポイントで自動化。小規模ツールから本格システム開発まで対応します。</p>
            <div class="service-features-header">
              <span class="service-features-line"></span>
              <span class="service-features-label">サービス特徴</span>
            </div>
            <div class="service-feature-tags">
              <span class="service-feature-tag">月額5,000円〜</span>
              <span class="service-feature-tag">LINE Bot構築</span>
              <span class="service-feature-tag">単一業務から</span>
              <span class="service-feature-tag">短期間で導入</span>
              <span class="service-feature-tag">スモールスタート</span>
              <span class="service-feature-tag">効果を体感</span>
            </div>
            <div class="service-card-actions">
              <a href="https://lin.ee/ySjX76bl" target="_blank" rel="noopener noreferrer" class="service-card-cta">
                まずは試してみる
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
              <a href="/service/line-automation" class="service-card-cta-secondary">
                LINE自動化の事例を見る
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- カード②: AI内製化パッケージ（主力） -->
          <div class="service-card service-card--primary reveal reveal-d4">
            <span class="service-badge">主力サービス</span>
            <p class="service-card-num">02</p>
            <h3>AI内製化パッケージ</h3>
            <p class="service-card-desc">3ヶ月、現場で一緒にAIシステムを構築。運用できる人材を社内に残す、伴走型のAI導入です。</p>

            <div class="compare-grid">
              <div class="compare-card compare-card--old">
                <p class="compare-label">新規に1人を採用すると</p>
                <p class="compare-amount">約103<span class="unit">万円</span></p>
                <p class="compare-desc">採用コスト+教育で半年。<br/>退職すればゼロに戻る。</p>
              </div>
              <div class="compare-arrow">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </div>
              <div class="compare-card compare-card--new">
                <p class="compare-label">AI内製化パッケージなら</p>
                <p class="compare-amount">同じ投資<span class="unit">で</span></p>
                <p class="compare-desc"><strong>辞めない"仕組みと人材"</strong>が<br/>社内に残り続ける。</p>
              </div>
            </div>
            <p class="compare-caption">人を1人雇うのではなく、今いるチームをAI人材に変える。<br/>それがAltShiftの考え方です。</p>

            <div class="service-features-header">
              <span class="service-features-line"></span>
              <span class="service-features-label">サービス特徴</span>
            </div>
            <div class="service-feature-tags">
              <span class="service-feature-tag">3ヶ月伴走</span>
              <span class="service-feature-tag">現場常駐型</span>
              <span class="service-feature-tag">システム構築込み</span>
              <span class="service-feature-tag">人材育成込み</span>
              <span class="service-feature-tag">補助金活用可</span>
              <span class="service-feature-tag">運用定着まで</span>
            </div>
            <div class="service-card-actions">
              <a href="https://lin.ee/ySjX76bl" target="_blank" rel="noopener noreferrer" class="service-card-cta service-card-cta--primary">
                詳しく相談する
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
              <a href="#process" class="service-card-cta-secondary">
                3ヶ月の流れを見る
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
