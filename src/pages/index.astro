---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

const faqItems = [
  { q: 'AltShiftはどんなサービスですか？', a: '中小企業向けにAI導入を戦略から実装・運用まで一貫支援しています。ツール導入で終わらせず、現場で使いこなせる状態まで伴走します。' },
  { q: '料金はいくらですか？', a: '月額3万円〜8万円の3プランをご用意しています（初期費用別途）。まずは無料ヒアリングで最適なプランをご提案します。' },
  { q: 'AIを使ったことがない会社でも大丈夫ですか？', a: 'はい。ゼロからの設計・設定・研修まで一貫サポート。むしろAI未経験の企業様こそ成果が出やすいパターンです。' },
  { q: 'どのくらいで成果が出ますか？', a: 'LINE自動化は翌月から、SEOは通常3〜6ヶ月。成果が出やすい施策から優先着手します。' },
  { q: '福岡以外でも対応できますか？', a: 'はい。オンラインで全国対応。福岡市内・近郊は訪問対応も可能です。' },
]

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
}
---

<Layout
  title="AltShift｜福岡の中小企業向けAIコンサルティング・AI導入支援"
  description="福岡発、中小企業専門のAIコンサルティング。AI導入戦略・システム開発・Web制作・LINE自動化を月額3万円〜で一貫支援。採用業務工数50%削減の実績あり。無料相談受付中。"
  schemaData={faqSchema}
>
  <Nav />
  <main>

    <!-- ========== HERO ========== -->
    <section class="relative overflow-hidden" style="min-height:100vh; display:flex; align-items:center;">

      <!-- Animated background -->
      <div class="hero-bg">
        <div class="orb orb-neon"></div>
        <div class="orb orb-blue"></div>
        <div class="orb orb-teal"></div>
        <div class="hero-grid"></div>
      </div>

      <!-- VIDEO SLOT: Uncomment to replace gradient with video
      <div class="hero-media-slot">
        <video autoplay muted loop playsinline poster="/images/hero-poster.jpg">
          <source src="/videos/hero-1080.mp4" type="video/mp4" />
        </video>
      </div>
      -->

      <!-- Content -->
      <div style="position:relative; z-index:10; max-width:1200px; margin:0 auto; padding:160px 48px 100px; width:100%;">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-end">

          <!-- Left: Heading -->
          <div>
            <div class="accent-line mb-8"></div>
            <h1 class="heading-hero">
              中小企業の<br/>
              AI導入を、<br/>
              まるごと。
            </h1>
          </div>

          <!-- Right: Description + CTAs -->
          <div style="padding-bottom:8px;">
            <p class="body-lg mb-3" style="max-width:440px;">
              戦略策定から実装・運用まで一貫支援。福岡発、中小企業専門のAIコンサルティング。
            </p>
            <p class="text-sm mb-8" style="color:var(--color-neon); font-weight:600;">月額3万円〜 / 最短2週間で戦略策定</p>
            <div class="flex flex-wrap gap-4">
              <a href="/contact" class="btn-neon" style="font-size:14px; padding:14px 28px;">
                無料で相談する
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
              <a href="/case" class="btn-outline" style="font-size:14px; padding:14px 28px;">
                導入事例を見る
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== NUMBERS (実績) ========== -->
    <section style="background:var(--color-bg); border-top:1px solid rgba(255,255,255,0.06); border-bottom:1px solid rgba(255,255,255,0.06);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center reveal stagger">
          <div>
            <p class="number-value" data-count="50" data-suffix="%">0%</p>
            <p class="number-label">採用業務工数削減</p>
          </div>
          <div>
            <p class="number-value" data-count="2" data-suffix="週間">0週間</p>
            <p class="number-label">最短戦略策定</p>
          </div>
          <div>
            <p class="number-value" data-count="4" data-suffix="社">0社</p>
            <p class="number-label">導入実績</p>
          </div>
          <div>
            <p class="number-value" data-count="365" data-suffix="日">0日</p>
            <p class="number-label">24時間自動応答</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== HERO VIDEO / IMAGE SECTION ========== -->
    <section class="relative overflow-hidden" style="background:var(--color-bg);">
      <!-- FULL-WIDTH MEDIA SLOT: Replace with hero video or image -->
      <div style="position:relative; width:100%; aspect-ratio:16/7; background:var(--color-bg-card); overflow:hidden;">
        <!-- Placeholder: gradient animation simulating AI visuals -->
        <div style="position:absolute; inset:0; background: linear-gradient(135deg, #031B27 0%, #0A2535 30%, #071F2B 60%, #031B27 100%); display:flex; align-items:center; justify-content:center;">
          <div style="width:280px; height:280px; border-radius:50%; background:radial-gradient(circle, rgba(216,255,0,0.2) 0%, rgba(216,255,0,0.05) 40%, transparent 70%); filter:blur(40px); animation: orbMove1 8s ease-in-out infinite alternate;"></div>
          <p style="position:absolute; font-family:'Inter',sans-serif; font-weight:800; font-size:clamp(28px,4vw,52px); color:rgba(255,255,255,0.9); letter-spacing:-0.02em; text-align:center; line-height:1.3;">
            Beyond the<br/>ordinary
          </p>
        </div>
        <!-- Replace above with: <video autoplay muted loop playsinline style="width:100%;height:100%;object-fit:cover;"><source src="/videos/hero-visual.mp4" type="video/mp4" /></video> -->
      </div>
    </section>

    <!-- ========== ABOUT ========== -->
    <section class="section-padding" style="background:var(--color-bg);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start reveal">

          <!-- Left: Statement -->
          <div>
            <h2 class="heading-lg" style="font-size:clamp(24px,3.5vw,36px); line-height:1.4;">
              私たちは、企業の課題を、<br/>
              実用化可能なAIへと<br/>
              迅速に変換します。
            </h2>
          </div>

          <!-- Right: Description + partners -->
          <div>
            <p class="body-md mb-8" style="max-width:480px;">
              AltShiftは、中小企業に特化したAIコンサルティング&エンジニアリング企業です。
              お客様の競争優位性の中心となるAIソリューションの設計、構築、運用を行っています。
            </p>
            <div class="flex items-center gap-3">
              <div style="width:8px; height:8px; border-radius:50%; background:var(--color-neon);"></div>
              <span style="font-size:14px; font-weight:500; color:var(--color-ink-sub);">中小企業専門 × AI特化 × 福岡発全国対応</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== CLIENT LOGOS ========== -->
    <section class="section-padding-sm" style="background:var(--color-bg);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center">
        <p class="body-md mb-10 reveal" style="color:var(--color-ink-muted);">
          当社のクライアントには以下のような企業が含まれます
        </p>
        <div class="flex items-center justify-center gap-12 flex-wrap reveal">
          <!-- CLIENT LOGO SLOTS: Replace with <img class="client-logo" src="..." alt="..." /> -->
          {['三栄リフォーム', "BAR Kar's", '株式会社伸明', '株式会社BEGINS'].map(name => (
            <span style="font-family:'Inter','Noto Sans JP',sans-serif; font-weight:700; font-size:16px; color:var(--color-ink); opacity:0.4; letter-spacing:0.02em;">
              {name}
            </span>
          ))}
        </div>
      </div>
    </section>

    <div class="section-divider max-w-7xl mx-auto"></div>

    <!-- ========== SERVICES (01-04 Cards) ========== -->
    <section class="section-padding" style="background:var(--color-bg);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <h2 class="heading-lg text-center mb-16 reveal">当社のサービス</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 stagger">
          {[
            { num: '01', title: 'AI導入戦略', desc: '経営課題の分析、AI教育、ROIモデル、そして貴社の課題と目標に合致したAIロードマップを、最短2週間で提供します。' },
            { num: '02', title: 'カスタムAIソリューション', desc: '競争優位性を高め、コストを削減し、新たなビジネスチャンスを創出するために構築されたAIシステム。通常12週間以内に本番稼働を実現します。' },
            { num: '03', title: 'Web制作 × SEO/GEO', desc: 'Google・ChatGPT・Claudeに選ばれるWebサイト。AI時代の検索対応設計で、検索・地図双方からの集客基盤を構築します。' },
            { num: '04', title: 'LINE自動化 × 業務効率化', desc: '24時間365日の自動応答で機会損失をゼロに。チャットボット構築・自動配信・顧客管理で組織全体の業務を効率化します。' },
          ].map(s => (
            <div class="reveal t-card p-7 flex flex-col" style="min-height:280px;">
              <p class="service-num mb-4">{s.num}</p>
              <h3 class="heading-md mb-4">{s.title}</h3>
              <p class="body-sm flex-1">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== TECHNOLOGY STACK ========== -->
    <section style="background:var(--color-bg-elevated);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 section-padding text-center">
        <p class="section-label mb-4 reveal" style="text-transform:uppercase; letter-spacing:0.1em;">Technology Stack</p>
        <h2 class="heading-lg mb-6 reveal">使用テクノロジー</h2>
        <p class="body-md mb-12 reveal" style="max-width:600px; margin-left:auto; margin-right:auto;">
          世界最先端のAIモデルとフレームワークを活用し、お客様の課題に最適なソリューションを構築します。
        </p>
        <div class="flex items-center justify-center gap-10 flex-wrap reveal">
          {['Claude (Anthropic)', 'GPT (OpenAI)', 'LINE Messaging API', 'Next.js', 'Google Cloud'].map(tech => (
            <span style="font-family:'Inter',sans-serif; font-weight:700; font-size:15px; color:var(--color-ink); letter-spacing:-0.01em; opacity:0.7;">
              {tech}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== CTA BANNER (Background image slot) ========== -->
    <section class="relative overflow-hidden" style="min-height:400px; display:flex;">
      <!-- BACKGROUND IMAGE/VIDEO SLOT -->
      <div style="position:absolute; inset:0; background:var(--color-bg-card);">
        <!-- Placeholder: Replace with background image like Tomoro's walking woman photo -->
        <div style="position:absolute; inset:0; background:linear-gradient(135deg, rgba(3,27,39,0.95), rgba(10,37,53,0.9));"></div>
        <!-- Neon glow spot (like Tomoro's yellow circle on ground) -->
        <div style="position:absolute; bottom:0; left:50%; transform:translateX(-50%); width:300px; height:150px; background:radial-gradient(ellipse, rgba(204,255,0,0.15) 0%, transparent 70%); filter:blur(30px);"></div>
      </div>

      <div style="position:relative; z-index:10; max-width:1200px; margin:0 auto; padding:80px 48px; width:100%;">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          <div class="reveal">
            <h2 class="heading-lg mb-4">AIを競争優位性に変えよう。</h2>
            <a href="/contact" class="neon-link">
              お問い合わせ
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          </div>
          <div class="reveal">
            <h2 class="heading-lg mb-4">AIの最前線で仕事をする。</h2>
            <a href="/company" class="neon-link">
              AltShiftについて
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== CASE STUDIES ========== -->
    <section class="section-padding" style="background:var(--color-bg);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="flex items-center justify-between mb-12 reveal">
          <h2 class="heading-lg">導入事例</h2>
          <a href="/case" class="neon-link">
            すべて表示
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 stagger">
          {[
            { title: '三栄リフォーム × AltShift', tags: ['Web制作','SEO/GEO'], image: '/images/cases/sanei-reform.jpg', desc: 'AI時代の検索対応Webサイト。SEO/GEO対策でGoogleとAIに選ばれるコンテンツを構築。', url: 'https://sanei-reform.vercel.app' },
            { title: '株式会社BEGINS × AltShift', tags: ['業務自動化','HR-Tech'], image: '/images/cases/begins.jpg', desc: 'コールセンター集計の完全自動化。採用業務工数50%削減を実現。', url: null },
          ].map(c => (
            <div class="reveal t-card overflow-hidden">
              <!-- IMAGE SLOT -->
              <div class="media-slot" style="aspect-ratio:16/9; position:relative;">
                <img src={c.image} alt={c.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
                <!-- Neon glow overlay (Tomoro photo style) -->
                <div class="neon-glow-circle" style="bottom:20%; left:30%;"></div>
              </div>
              <div class="p-6">
                <div class="flex flex-wrap gap-2 mb-3">
                  {c.tags.map(t => <span class="tag">{t}</span>)}
                </div>
                <h3 class="heading-sm mb-2">{c.title}</h3>
                <p class="body-sm mb-4">{c.desc}</p>
                {c.url
                  ? <a href={c.url} target="_blank" rel="noopener noreferrer" class="blue-link">サイトを見る <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
                  : <span class="text-xs" style="color:var(--color-ink-dim);">Coming Soon</span>
                }
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== INSIGHTS (Cream background — Tomoro style) ========== -->
    <section class="section-padding footer-cream">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="flex items-center justify-between mb-12 reveal">
          <h2 style="font-weight:800; font-size:clamp(26px,3.5vw,40px); letter-spacing:-0.02em; color:#031B27;">インサイト</h2>
          <a href="#" class="neon-link" style="color:#031B27;">
            すべて表示
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger">
          {[
            { date: '2026年5月20日', title: 'AI導入で中小企業が得られる3つの競争優位性', image: null },
            { date: '2026年5月15日', title: 'SEO/GEO対策：AI検索時代に選ばれるWebサイトの条件', image: null },
            { date: '2026年5月10日', title: 'LINE自動化で売上を伸ばす：導入事例と成果レポート', image: null },
          ].map(a => (
            <div class="reveal">
              <!-- ARTICLE IMAGE SLOT -->
              <div style="aspect-ratio:4/3; border-radius:12px; overflow:hidden; background:#E8E2D6; margin-bottom:16px; position:relative;">
                {a.image
                  ? <img src={a.image} alt={a.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
                  : <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">
                      <!-- Neon circle placeholder (Tomoro article style) -->
                      <div style="width:120px;height:120px;border-radius:50%;background:rgba(204,255,0,0.4);filter:blur(20px);"></div>
                    </div>
                }
                <span class="tag" style="position:absolute; top:12px; left:12px;">記事</span>
              </div>
              <p style="font-size:13px; font-weight:600; color:var(--color-blue); margin-bottom:8px;">{a.date}</p>
              <h3 style="font-weight:700; font-size:17px; color:#031B27; line-height:1.5;">{a.title}</h3>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== FAQ ========== -->
    <section class="section-padding" style="background:var(--color-bg);">
      <div class="max-w-3xl mx-auto">
        <div class="mb-12 text-center reveal">
          <h2 class="heading-lg">よくある質問</h2>
        </div>

        <div class="flex flex-col gap-3" id="faq-list">
          {faqItems.map((item, i) => (
            <div class="reveal faq-item">
              <button
                class="faq-btn w-full text-left px-6 py-5 flex items-center justify-between gap-4"
                aria-expanded="false"
                aria-controls={`faq-answer-${i}`}
              >
                <span style="font-weight:500; color:var(--color-ink);">{item.q}</span>
                <svg class="faq-icon flex-shrink-0 transition-transform duration-200" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--color-ink-muted);">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5" id={`faq-answer-${i}`}>
                <p class="body-sm">{item.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling as HTMLElement
      const icon = btn.querySelector('.faq-icon') as HTMLElement
      const isOpen = btn.getAttribute('aria-expanded') === 'true'
      document.querySelectorAll('.faq-btn').forEach(b => {
        b.setAttribute('aria-expanded', 'false')
        ;(b.nextElementSibling as HTMLElement).classList.add('hidden')
        ;(b.querySelector('.faq-icon') as HTMLElement).style.transform = 'rotate(0deg)'
      })
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true')
        answer.classList.remove('hidden')
        icon.style.transform = 'rotate(180deg)'
      }
    })
  })
</script>
