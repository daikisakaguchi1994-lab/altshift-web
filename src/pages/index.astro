      const answer = btn.nextElementSibling as HTMLElement
      const icon = btn.querySelector('.faq-icon') as HTMLElement
      const isOpen = btn.getAttribute('aria-expanded') === 'true'
      document.querySelectorAll('.faq-btn').forEach(b => {
        b.setAttribute('aria-expanded', 'false')
        ;(b.nextElementSibling as HTMLElement).classList.add('hidden')
        ;(b.querySelector('.faq-icon') as HTMLElement).style.transform = 'rotate(0deg)'
      })
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true')
        answer.classList.remove('hidden')
        icon.style.transform = 'rotate(180deg)'
      }
    })
  })
</script>

<script>
(function() {
  'use strict';

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ─── Elements ───
  const section     = document.getElementById('constellation');
  const header      = document.getElementById('constellation-header');
  const hubCore     = document.getElementById('constellation-core');
  const hubBloom    = document.getElementById('constellation-bloom');
  const convergeMsg = document.getElementById('constellation-msg');
  const btobReveals = Array.from(document.querySelectorAll('.btob-section .reveal'));
  const lineSvg     = document.getElementById('constellation-lines');
  const canvas      = document.getElementById('constellation-particles') as HTMLCanvasElement;
  const ctx         = canvas.getContext('2d')!;

  const tiles = Array.from(document.querySelectorAll('.tile'));

  // ─── Tier timing ───
  const TIER_TIMING: Record<string, {moveStart:number;moveEnd:number;absorbStart:number;absorbEnd:number}> = {
    bg:   { moveStart: 0.00, moveEnd: 0.40, absorbStart: 0.40, absorbEnd: 0.55 },
    sub:  { moveStart: 0.02, moveEnd: 0.50, absorbStart: 0.50, absorbEnd: 0.65 },
    main: { moveStart: 0.05, moveEnd: 0.60, absorbStart: 0.60, absorbEnd: 0.78 },
  };

  // ─── Parse tile data ───
  const tileState = tiles.map(t => {
    const el = t as HTMLElement;
    const angle = parseFloat(el.dataset.angle!) * Math.PI / 180;
    const dist  = parseFloat(el.dataset.dist!) / 100;
    const speed = parseFloat(el.dataset.floatSpeed!);
    const amp   = parseFloat(el.dataset.floatAmp!);
    const tier  = el.dataset.tier!;
    const timing = TIER_TIMING[tier];
    const lineEl = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    lineEl.setAttribute('stroke', tier === 'main' ? 'rgba(14,158,150,0.3)' :
                                   tier === 'sub'  ? 'rgba(14,158,150,0.18)' :
                                                     'rgba(14,158,150,0.08)');
    lineEl.setAttribute('stroke-width', tier === 'main' ? '1.2' : tier === 'sub' ? '0.8' : '0.5');
    lineEl.setAttribute('stroke-dasharray', tier === 'bg' ? '3 5' : '5 4');
    lineSvg!.appendChild(lineEl);
    return { el, angle, dist, speed, amp, tier, timing, lineEl };
  });

  // ─── Particles ───
  let particles: {homeX:number;homeY:number;x:number;y:number;r:number;vx:number;vy:number;baseAlpha:number;tealness:number;pullDelay:number}[] = [];
  function initParticles() {
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
    particles = [];
    const count = Math.floor(canvas.width * canvas.height / 16000);
    for (let i = 0; i < count; i++) {
      const angle = Math.random() * Math.PI * 2;
      const dist = 0.3 + Math.random() * 0.7;
      particles.push({
        homeX: canvas.width / 2 + Math.cos(angle) * dist * canvas.width * 0.5,
        homeY: canvas.height / 2 + Math.sin(angle) * dist * canvas.height * 0.5,
        x: 0, y: 0,
        r: Math.random() * 1.6 + 0.5,
        vx: 0, vy: 0,
        baseAlpha: Math.random() * 0.18 + 0.06,
        tealness: Math.random() * 0.5,
        pullDelay: Math.random() * 0.15,
      });
    }
    particles.forEach(p => { p.x = p.homeX; p.y = p.homeY; });
  }
  initParticles();
  window.addEventListener('resize', initParticles);

  function drawParticles(progress: number) {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    const cx = canvas.width / 2, cy = canvas.height / 2;

    particles.forEach(p => {
      const dx = cx - p.x, dy = cy - p.y;
      const d = Math.sqrt(dx * dx + dy * dy) || 1;

      const pullRaw = Math.max(0, (progress - p.pullDelay) / (1 - p.pullDelay));
      const pull = pullRaw * pullRaw;

      const proximityBoost = Math.min(3, 200 / d);
      const force = pull * 0.025 * (1 + proximityBoost * pull);

      p.vx += (dx / d) * force;
      p.vy += (dy / d) * force;

      if (pull < 0.3) {
        p.vx += (Math.random() - 0.5) * 0.02 * (1 - pull * 3);
        p.vy += (Math.random() - 0.5) * 0.02 * (1 - pull * 3);
      }

      p.x += p.vx;
      p.y += p.vy;
      p.vx *= 0.96;
      p.vy *= 0.96;

      if (d < 30 && pull > 0.2) {
        const respawnAngle = Math.random() * Math.PI * 2;
        const respawnDist = 0.7 + Math.random() * 0.3;
        p.x = cx + Math.cos(respawnAngle) * respawnDist * canvas.width * 0.5;
        p.y = cy + Math.sin(respawnAngle) * respawnDist * canvas.height * 0.5;
        p.vx = 0; p.vy = 0;
      }

      const glowIntensity = Math.min(1, pull * 1.5);
      const alpha = p.baseAlpha + glowIntensity * 0.35;
      const tealMix = p.tealness + glowIntensity * 0.5;
      const r = Math.round(255 - tealMix * 241);
      const g = Math.round(255 - tealMix * 97);
      const b = Math.round(255 - tealMix * 105);

      if (d < 150 && pull > 0.15) {
        const glowR = p.r * (2 + glowIntensity * 2);
        const grad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, glowR);
        grad.addColorStop(0, `rgba(${r},${g},${b},${alpha * 0.8})`);
        grad.addColorStop(1, `rgba(14,158,150,0)`);
        ctx.beginPath();
        ctx.arc(p.x, p.y, glowR, 0, Math.PI * 2);
        ctx.fillStyle = grad;
        ctx.fill();
      }

      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${r},${g},${b},${Math.min(1, alpha)})`;
      ctx.fill();
    });
  }

  // ─── Easing ───
  function easeOutCubic(t: number) {
    return 1 - Math.pow(1 - t, 3);
  }
  function easeOutQuart(t: number) {
    return 1 - Math.pow(1 - t, 4);
  }

  // ─── Main update ───
  let currentProgress = 0;
  const now = () => performance.now() / 1000;

  function update(progress: number) {
    currentProgress = progress;
    const t = now();
    const vw = window.innerWidth;
    const vh = window.innerHeight;
    const cx = vw / 2, cy = vh / 2;

    // Header fade
    header!.style.opacity = String(Math.max(0, 1 - progress * 5));

    // All tiles converged?
    const allConverged = progress >= 0.80;

    // Tiles
    tileState.forEach((td, i) => {
      const { moveStart, moveEnd, absorbStart, absorbEnd } = td.timing;

      const rawMoveP = Math.max(0, Math.min(1, (progress - moveStart) / (moveEnd - moveStart)));
      const moveP = easeOutCubic(rawMoveP);

      const rawAbsorbP = Math.max(0, Math.min(1, (progress - absorbStart) / (absorbEnd - absorbStart)));
      const absorbP = easeOutQuart(rawAbsorbP);

      const isNarrow = vw < 768;
      const maxRX = isNarrow ? vw * 0.46 : Math.min(vw, vh) * 0.55;
      const maxRY = isNarrow ? vh * 0.30 : Math.min(vw, vh) * 0.55;
      const startX = Math.cos(td.angle) * td.dist * maxRX;
      const startY = Math.sin(td.angle) * td.dist * maxRY;
      let curX = startX * (1 - moveP);
      let curY = startY * (1 - moveP);

      if (!reduced && rawMoveP < 0.6) {
        const floatStrength = 1 - rawMoveP * 1.67;
        const phase = t * (2 * Math.PI / td.speed) + i * 1.3;
        curY += Math.sin(phase) * td.amp * floatStrength;
        curX += Math.cos(phase * 0.7) * td.amp * 0.35 * floatStrength;
      }

      const screenX = cx + curX - td.el.offsetWidth / 2;
      const screenY = cy + curY - td.el.offsetHeight / 2;

      const scale = 1 - absorbP * 0.6;
      const opacity = 1 - absorbP;
      td.el.style.transform = `translate(${screenX}px, ${screenY}px) scale(${Math.max(0.3, scale)})`;
      td.el.style.opacity = String(Math.max(0, opacity));

      // Line
      const lineStartP = moveStart + 0.05;
      const lineP = Math.max(0, Math.min(1, (progress - lineStartP) / (absorbEnd - lineStartP)));
      const tileCX = cx + curX, tileCY = cy + curY;
      td.lineEl.setAttribute('x1', String(tileCX));
      td.lineEl.setAttribute('y1', String(tileCY));
      td.lineEl.setAttribute('x2', String(cx));
      td.lineEl.setAttribute('y2', String(cy));
      const lineFade = lineP < 0.7 ? lineP / 0.7 : Math.max(0, 1 - (lineP - 0.7) / 0.3);
      td.lineEl.setAttribute('stroke-opacity', String(lineFade * (td.tier === 'main' ? 0.5 : td.tier === 'sub' ? 0.3 : 0.15)));
    });

    // Hub glow
    const glowP = Math.max(0, Math.min(1, (progress - 0.05) / 0.70));
    const glowSize = 20 + glowP * 35;
    const glowAlpha = 0.1 + glowP * 0.3;
    hubCore!.style.boxShadow = `0 0 ${glowSize}px rgba(14,158,150,${glowAlpha})`;
    hubBloom!.style.opacity = String(glowP * 0.6);

    // Hub pulse on full convergence
    if (allConverged) {
      const pulseRaw = Math.min(1, (progress - 0.80) / 0.15);
      const pulse = easeOutQuart(pulseRaw);
      hubCore!.style.transform = `scale(${1 + pulse * 0.15})`;
      hubCore!.style.boxShadow = `0 0 ${50 + pulse * 50}px rgba(14,158,150,${0.35 + pulse * 0.25}), 0 0 ${100 + pulse * 60}px rgba(14,158,150,${0.12 + pulse * 0.15})`;
      hubBloom!.style.opacity = String(0.5 + pulse * 0.5);
      hubBloom!.style.transform = `scale(${1 + pulse * 0.4})`;
    } else {
      hubCore!.style.transform = 'scale(1)';
      hubBloom!.style.transform = 'scale(1)';
    }

    // Converge message
    const msgP = Math.max(0, Math.min(1, (progress - 0.80) / 0.10));
    convergeMsg!.style.opacity = String(easeOutQuart(msgP));

    // Particles
    if (!reduced) drawParticles(progress);

    // BtoB reveals
    btobReveals.forEach(el => {
      const r = el.getBoundingClientRect();
      if (r.top < vh * 0.88) el.classList.add('visible');
    });
  }

  // ─── Scroll ───
  let ticking = false;
  function onScroll() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      const rect = section!.getBoundingClientRect();
      const scrollable = section!.offsetHeight - window.innerHeight;
      const scrolled = -rect.top;
      const progress = Math.max(0, Math.min(1, scrolled / scrollable));
      update(progress);
      ticking = false;
    });
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll);

  // ─── Render loop ───
  function loop() {
    if (!reduced) update(currentProgress);
    requestAnimationFrame(loop);
  }
  requestAnimationFrame(() => {
    update(0);
    if (!reduced) loop();
  });

})();
</script>
