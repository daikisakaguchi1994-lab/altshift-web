---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import SubsidySection from '../components/SubsidySection.astro'
import Footer from '../components/Footer.astro'
import DemoChat from '../components/DemoChat.tsx'

const faqItems = [
  { q: 'AltShiftはどんなサービスですか？', a: '中小企業向けにAI導入を戦略から実装・運用まで一貫支援しています。ツール導入で終わらせず、現場で使いこなせる状態まで伴走します。' },
  { q: '料金はいくらですか？', a: 'サービスにより異なります。Web制作・LINE自動化は月額3万円〜、AIコンサルティングは戦略診断30万円〜・月額顧問20万円〜、AI業務自動化は案件規模に応じてお見積もり。補助金を活用できる場合があります（採択は審査によります）。' },
  { q: 'AIを使ったことがない会社でも大丈夫ですか？', a: 'はい。ゼロからの設計・設定・研修まで一貫サポート。むしろAI未経験の企業様こそ成果が出やすいパターンです。' },
  { q: 'どのくらいで成果が出ますか？', a: 'LINE自動化は翌月から、SEOは通常3〜6ヶ月。成果が出やすい施策から優先着手します。' },
  { q: '福岡以外でも対応できますか？', a: 'はい。オンラインで全国対応。福岡市内・近郊は訪問対応も可能です。' },
]

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
}
---

<Layout
  title="AltShift｜福岡の中小企業向けAIコンサルティング・AI導入支援"
  description="福岡発、中小企業専門のAIコンサルティング。AI導入戦略・システム開発・Web制作・LINE自動化を一貫支援。採用業務工数50%削減の実績あり。無料相談受付中。"
  schemaData={faqSchema}
>
  <Nav />
  <main>

    <!-- ========== HERO ========== -->
    <section class="hero-gradient relative overflow-hidden" style="min-height:100vh; display:flex; align-items:center;">

      <!-- Dot grid overlay -->
      <div class="hero-dot-grid" style="position:absolute; inset:0; z-index:1;"></div>

      <!-- Content -->
      <div style="position:relative; z-index:10; max-width:1280px; margin:0 auto; padding:160px 24px 100px; width:100%;">
        <div class="grid grid-cols-12 gap-8 lg:gap-12 items-center">

          <!-- Left: 7カラム -->
          <div class="col-span-12 lg:col-span-7">
            <div class="accent-line mb-8"></div>
            <h1 class="heading-hero hero-title" style="line-height:1.08; color:#FFFFFF;">
              AIを、「使える人」ごと<br/>社内に。
            </h1>
            <p class="body-lg hero-subtitle mt-6 mb-4" style="max-width:520px; color:rgba(255,255,255,0.85);">
              「導入して終わり」にしない。現場に入り、3ヶ月でAIを回せる人材を育てる。
            </p>
            <p class="hero-subtitle mb-8" style="font-size:15px; max-width:520px; color:rgba(255,255,255,0.65);">
              診断2週間、稼働12週間。<a href="/simulator" style="color:rgba(255,255,255,0.75); text-decoration:underline; text-underline-offset:3px;">補助金を活用できる場合があります</a>。
            </p>
            <div class="flex flex-wrap gap-4 hero-subtitle">
              <a href="/contact" class="btn-primary">
                無料で相談する
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
              <a href="https://line.me/R/ti/p/@544thnig" target="_blank" rel="noopener noreferrer" class="btn-line">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
                LINEで無料相談する（30分）
              </a>
              <a href="/case" class="btn-secondary-ghost" style="color:rgba(255,255,255,0.85); border:1px solid rgba(255,255,255,0.5);">
                導入事例を見る
              </a>
            </div>
          </div>

          <!-- Right: 5カラム（数字グリッド）-->
          <div class="col-span-12 lg:col-span-5 flex items-center hero-subtitle">
            <!-- 実績数字グリッド 2x2 -->
            <div class="grid grid-cols-2 gap-3">
              <div style="background:rgba(255,255,255,0.1); backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,0.15); border-radius:12px; padding:20px;">
                <p style="font-family:'Inter',sans-serif; font-weight:800; font-size:clamp(28px,3vw,36px); color:#FFFFFF; line-height:1; margin-bottom:4px; font-variant-numeric:tabular-nums;">
                  50<span style="font-size:clamp(16px,2vw,20px); color:rgba(255,255,255,0.7);">%</span>
                </p>
                <p style="font-size:12px; color:rgba(255,255,255,0.6); line-height:1.4;">業務効率化（実績平均）</p>
              </div>
              <div style="background:rgba(255,255,255,0.1); backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,0.15); border-radius:12px; padding:20px;">
                <p style="font-family:'Inter',sans-serif; font-weight:800; font-size:clamp(28px,3vw,36px); color:#FFFFFF; line-height:1; margin-bottom:4px; font-variant-numeric:tabular-nums;">
                  2<span style="font-size:clamp(16px,2vw,20px); color:rgba(255,255,255,0.7);">週間</span>
                </p>
                <p style="font-size:12px; color:rgba(255,255,255,0.6); line-height:1.4;">戦略診断パック納期</p>
              </div>
              <div style="background:rgba(255,255,255,0.1); backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,0.15); border-radius:12px; padding:20px;">
                <p style="font-family:'Inter',sans-serif; font-weight:800; font-size:clamp(28px,3vw,36px); color:#FFFFFF; line-height:1; margin-bottom:4px; font-variant-numeric:tabular-nums;">
                  4<span style="font-size:clamp(16px,2vw,20px); color:rgba(255,255,255,0.7);">社</span>
                </p>
                <p style="font-size:12px; color:rgba(255,255,255,0.6); line-height:1.4;">導入実績</p>
              </div>
              <div style="background:rgba(255,255,255,0.1); backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,0.15); border-radius:12px; padding:20px;">
                <p style="font-family:'Inter',sans-serif; font-weight:800; font-size:clamp(28px,3vw,36px); color:#FFFFFF; line-height:1; margin-bottom:4px; font-variant-numeric:tabular-nums;">
                  3<span style="font-size:clamp(16px,2vw,20px); color:rgba(255,255,255,0.7);">ヶ月</span>
                </p>
                <p style="font-size:12px; color:rgba(255,255,255,0.6); line-height:1.4;">集中伴走</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Demo scroll link -->
        <div class="text-center mt-12 hero-subtitle" style="animation-delay:0.2s;">
          <a href="#demo-section" style="color:rgba(255,255,255,0.7); font-size:13px; text-decoration:none; display:inline-flex; align-items:center; gap:6px; transition:color 0.2s;">
            <span>→ デモを体験する</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transform:rotate(90deg);">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ========== PRODUCT INTRO (WHY ALTSHIFT) ========== -->
    <section id="why-altshift" class="section-padding" style="background:var(--color-bg-subtle);">
      <div class="max-w-4xl mx-auto px-6 lg:px-8">
        <div class="reveal">
          <p class="section-label mb-4" style="text-transform:uppercase; letter-spacing:0.1em; color:var(--color-accent);">Why AltShift</p>

          <h2 class="heading-lg mb-6" style="line-height:1.4;">
            「AIを導入する」だけでは、<br class="hidden md:block" />変わらない。
          </h2>

          <div class="body-md" style="line-height:1.9; color:var(--color-ink-sub);">
            <p class="mb-4">ツールを入れても、使いこなせる人がいなければ宝の持ち腐れ。</p>
            <p class="mb-4">外注に丸投げすれば、業者がいなくなった瞬間に止まる。</p>
            <p class="mb-4" style="font-weight:700; color:var(--color-ink);">
              AltShiftは、AIを"使える人"を社内に育てます。
            </p>
            <p class="mb-8">現場に入り、システムを一緒に作り、運用できる人材を残す。<br />
            これが「AI内製化パッケージ」です。</p>
          </div>

          <!-- 採用代替メッセージ（核） -->
          <div class="t-card p-8 mb-8" style="border-left:4px solid var(--color-cta); background:#FFFFFF;">
            <p class="heading-md mb-2" style="color:var(--color-ink);">
              「人を1人雇う」のではなく、「今いるチームをAI人材に変える」。
            </p>
            <p class="body-md" style="color:var(--color-ink-sub);">
              新しく1人採用するコストは平均約103万円。AI内製化パッケージは、それとほぼ同じ投資で、辞めない"仕組みと人材"が社内に残ります。
            </p>
          </div>

          <!-- 料金導線＋CTA -->
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/pricing" class="btn-secondary-ghost" style="font-size:15px; padding:14px 32px;">
              料金の考え方を見る →
            </a>
            <a href="https://calendly.com/daiki-sakaguchi1994/30min" target="_blank" rel="noopener noreferrer" class="btn-primary" style="font-size:15px; padding:14px 32px;">
              無料相談（30分）
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== 3-MONTH TRAINING PHASE ========== -->
    <section id="process" class="section-padding" style="background:var(--color-bg);">
      <div class="max-w-5xl mx-auto px-6 lg:px-8">
        <div class="reveal">
          <p class="section-label mb-4" style="text-transform:uppercase; letter-spacing:0.1em; color:var(--color-accent);">How We Work</p>
          <h2 class="heading-lg mb-4">3ヶ月で、AIを"使える会社"へ</h2>
          <p class="body-md mb-6" style="max-width:640px; color:var(--color-ink-sub);">
            ツールを入れて終わりにしない。3ヶ月、御社の担当者が自分でAIを動かせるようになるまで伴走します。
          </p>
        </div>

        <!-- Stepper (desktop) -->
        <div class="hidden md:flex items-center justify-center gap-3 mb-12 reveal" style="color:var(--color-ink-muted); font-size:13px; font-weight:600; letter-spacing:0.05em;">
          <span style="color:var(--color-brand);">STEP 01</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-ink-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          <span style="color:var(--color-brand);">STEP 02</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-ink-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          <span style="color:var(--color-accent);">STEP 03</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger">
          <!-- Phase 1 -->
          <div class="reveal t-card p-8 flex flex-col" style="border-top:3px solid var(--color-brand);">
            <span style="font-family:'Inter',sans-serif; font-weight:800; font-size:48px; line-height:1; opacity:0.15; color:var(--color-brand); margin-bottom:8px;">01</span>
            <span style="display:inline-block; background:var(--color-brand); color:#FFFFFF; font-size:12px; font-weight:700; padding:4px 12px; border-radius:20px; margin-bottom:12px; width:fit-content;">1ヶ月目</span>
            <h3 class="heading-md mb-3">基盤・着火</h3>
            <ul class="body-sm flex-1" style="color:var(--color-ink-sub); display:flex; flex-direction:column; gap:8px;">
              <li class="flex items-start gap-2">
                <span style="color:var(--color-brand); flex-shrink:0;">・</span>
                <span>業務の棚卸しとAI適用箇所の特定</span>
              </li>
              <li class="flex items-start gap-2">
                <span style="color:var(--color-brand); flex-shrink:0;">・</span>
                <span>担当者へのAI基礎研修</span>
              </li>
              <li class="flex items-start gap-2">
                <span style="color:var(--color-brand); flex-shrink:0;">・</span>
                <span>クイックウィンの設計</span>
              </li>
            </ul>
          </div>
          <!-- Phase 2 (highlighted) -->
          <div class="reveal t-card p-8 flex flex-col" style="border:2px solid var(--color-brand); border-top:3px solid var(--color-brand); background:rgba(27,94,190,0.03);">
            <span style="font-family:'Inter',sans-serif; font-weight:800; font-size:48px; line-height:1; opacity:0.15; color:var(--color-brand); margin-bottom:8px;">02</span>
            <span style="display:inline-block; background:var(--color-brand); color:#FFFFFF; font-size:12px; font-weight:700; padding:4px 12px; border-radius:20px; margin-bottom:12px; width:fit-content;">2ヶ月目</span>
            <h3 class="heading-md mb-3">実装・定着</h3>
            <ul class="body-sm flex-1" style="color:var(--color-ink-sub); display:flex; flex-direction:column; gap:8px;">
              <li class="flex items-start gap-2">
                <span style="color:var(--color-brand); flex-shrink:0;">・</span>
                <span>クイックウィン実装（即効果）</span>
              </li>
              <li class="flex items-start gap-2">
                <span style="color:var(--color-brand); flex-shrink:0;">・</span>
                <span>本命業務を担当者と二人三脚で自動化</span>
              </li>
              <li class="flex items-start gap-2">
                <span style="color:var(--color-brand); flex-shrink:0;">・</span>
                <span>動く状態まで一緒に作り上げる</span>
              </li>
            </ul>
          </div>
          <!-- Phase 3 -->
          <div class="reveal t-card p-8 flex flex-col" style="border-top:3px solid var(--color-accent);">
            <span style="font-family:'Inter',sans-serif; font-weight:800; font-size:48px; line-height:1; opacity:0.15; color:var(--color-accent); margin-bottom:8px;">03</span>
            <span style="display:inline-block; background:var(--color-accent); color:#FFFFFF; font-size:12px; font-weight:700; padding:4px 12px; border-radius:20px; margin-bottom:12px; width:fit-content;">3ヶ月目</span>
            <h3 class="heading-md mb-3">自走・仕込み</h3>
            <ul class="body-sm flex-1" style="color:var(--color-ink-sub); display:flex; flex-direction:column; gap:8px;">
              <li class="flex items-start gap-2">
                <span style="color:var(--color-accent); flex-shrink:0;">・</span>
                <span>担当者が単独で改修・運用できる状態へ</span>
              </li>
              <li class="flex items-start gap-2">
                <span style="color:var(--color-accent); flex-shrink:0;">・</span>
                <span>次のAI活用を社内で設計できるよう仕込む</span>
              </li>
              <li class="flex items-start gap-2">
                <span style="color:var(--color-accent); flex-shrink:0;">・</span>
                <span>AIが社内に"根付く"状態を作る</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== SCOPE (3-Layer downgraded) ========== -->
    <section style="background:var(--color-bg-subtle); padding:48px 0;">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-10 reveal">
          <p class="section-label mb-3" style="text-transform:uppercase; letter-spacing:0.1em; color:var(--color-ink-muted);">What We Build</p>
          <h3 class="heading-md mb-3" style="color:var(--color-ink);">集客・接客・継続の3領域に対応します</h3>
        </div>

        <div class="layer-grid stagger">
          {[
            { num: '01', layer: 'Layer 1', title: '見つけてもらう', sub: 'Web × SEO × GEO', desc: 'Google検索もAI検索（ChatGPT・Claude）も、Googleマップも。"探されたときに必ず見つかる"状態を作ります。', color: '#6BA3D6' },
            { num: '02', layer: 'Layer 2', title: '逃さない', sub: 'LINE × チャットボット', desc: '深夜の問い合わせにもAIが即応答。予約・リマインドまで自動で、"せっかくの見込み客"を取りこぼしません。', color: 'var(--color-brand)' },
            { num: '03', layer: 'Layer 3', title: '育てる', sub: 'AI分析 × 改善ループ', desc: '数字を見て、毎月手を打つ。KPI追跡と改善を回し続け、"入れて終わり"にしない成果の伸ばし方を。', color: 'var(--color-accent)' },
          ].map((l, i) => (
            <Fragment>
              {i > 0 && (
                <div class="layer-arrow" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-ink-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                  </svg>
                </div>
              )}
              <div class="reveal layer-card t-card p-8 flex flex-col" style={`border-top:3px solid ${l.color};`}>
                <span class="layer-num" style={`color:${l.color};`}>{l.num}</span>
                <p class="text-xs font-semibold mb-2" style={`color:${l.color}; letter-spacing:0.1em; text-transform:uppercase;`}>{l.layer}</p>
                <h3 class="heading-md mb-1">{l.title}</h3>
                <p class="text-xs mb-4" style="color:var(--color-ink-dim);">{l.sub}</p>
                <p class="body-sm flex-1">{l.desc}</p>
              </div>
            </Fragment>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== DEMO ========== -->
    <section id="demo-section" class="section-padding" style="background:var(--color-bg);">
      <div class="max-w-2xl mx-auto px-6">
        <div class="text-center mb-8 reveal">
          <p class="section-label mb-4" style="text-transform:uppercase; letter-spacing:0.1em; color:var(--color-primary);">Live Demo</p>
          <h2 class="heading-lg mb-2">AIを体験してみる</h2>
          <p class="body-md" style="color:var(--color-ink-sub);">
            このデモ自体が「御社に導入できるシステムの実物サンプル」です
          </p>
        </div>
        <DemoChat client:visible />
        <p class="text-center mt-6 reveal" style="font-size:14px; color:var(--color-ink-sub);">
          まず「うちはどれくらい損しているか」を数字にしてみる → <a href="https://calendly.com/daiki-sakaguchi1994/30min" target="_blank" rel="noopener noreferrer" style="color:var(--color-brand); text-decoration:underline; text-underline-offset:3px;">30分無料相談</a>
        </p>
      </div>
    </section>

    <!-- ========== ABOUT ========== -->
    <section class="section-padding" style="background:var(--color-bg);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start reveal">

          <!-- Left: Statement -->
          <div>
            <h2 class="heading-lg" style="font-size:clamp(24px,3.5vw,36px); line-height:1.4;">
              私たちは、企業の課題を、<br/>
              実用化可能なAIへと<br/>
              迅速に変換します。
