<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling as HTMLElement
      const icon = btn.querySelector('.faq-icon') as HTMLElement
      const isOpen = btn.getAttribute('aria-expanded') === 'true'
      document.querySelectorAll('.faq-btn').forEach(b => {
        b.setAttribute('aria-expanded', 'false')
        ;(b.nextElementSibling as HTMLElement).classList.add('hidden')
        ;(b.querySelector('.faq-icon') as HTMLElement).style.transform = 'rotate(0deg)'
      })
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true')
        answer.classList.remove('hidden')
        icon.style.transform = 'rotate(180deg)'
      }
    })
  })
</script>
