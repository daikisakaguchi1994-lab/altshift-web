---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

const articles = [
  { date: '2026/4/15', category: 'お知らせ', title: 'AltShift公式サイトをオープンしました', body: 'AIという道具を、中小企業の味方に。AltShiftの公式サイトが本日オープンいたしました。' },
  { date: '2026/4/10', category: 'サービス', title: '外部CAIOサービスの提供を開始しました', body: '週1〜2回の伴走型AI化支援サービスを正式に開始いたしました。' },
  { date: '2026/3/30', category: '実績',     title: '建設・リフォーム会社様のWeb制作・LINE自動化が完了しました', body: '福岡市内のリフォーム会社様のデジタル化を支援いたしました。' },
  { date: '2026/3/20', category: 'お知らせ', title: 'ディーチャーがAI活用セミナーに登壇しました', body: '代表のディーチャーが福岡市内のセミナーで中小企業のAI活用について講演いたしました。' },
  { date: '2026/3/10', category: '実績',     title: "バーのデジタルメニュー・LINE自動化が完了しました", body: '中洲のバー様のデジタル化を支援いたしました。' },
]
---

<Layout title="お知らせ | AltShift" description="AltShiftからのお知らせ・ニュース。">
  <Nav />
  <main>
    <section class="relative overflow-hidden section-padding" style="background:var(--color-bg);">
      <p class="absolute top-0 left-4 ghost-text" aria-hidden="true">NEWS</p>

      <div class="relative max-w-6xl mx-auto">
        <div class="mb-14 reveal">
          <p class="section-label mb-2">— お知らせ</p>
          <h1 class="heading-lg">NEWS</h1>
        </div>

        <div class="max-w-3xl flex flex-col">
          {articles.map(a => (
            <article class="reveal news-article py-7" style="border-bottom:1px solid var(--color-border);">
              <div class="flex flex-wrap items-center gap-3 mb-2">
                <time class="text-xs" style="color:var(--color-ink-muted); font-family:'Inter',sans-serif;">{a.date}</time>
                <span class="tag-sm">{a.category}</span>
              </div>
              <p class="heading-sm mb-2" style="font-size:15px;">{a.title}</p>
              <p class="body-sm">{a.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
