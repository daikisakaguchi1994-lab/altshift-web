---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

const services = [
  {
    num: '01',
    title: 'AI導入コンサルティング',
    desc: '経営課題の分析、AI教育、ROIモデル、そして貴社の課題と目標に合致したAIロードマップを最短2週間で提供します。',
    details: ['業務プロセスの分析・最適化', 'AI導入計画の策定', 'ROIモデルの構築', '経営層・スタッフ向けAI教育'],
    image: '/images/services/caio-service.jpg',
    href: '/service/ai-consulting',
  },
  {
    num: '02',
    title: 'カスタムAIシステム開発',
    desc: '競争優位性を高め、コストを削減し、新たなビジネスチャンスを創出するAIシステム。通常12週間以内に本番稼働を実現します。',
    details: ['カスタムAIモデルの構築', '既存システムとの統合', 'データ分析・可視化', '保守・運用サポート'],
    image: '/images/services/ai-system.jpg',
    href: '/service/ai-development',
  },
  {
    num: '03',
    title: 'AI時代の集客基盤構築',
    desc: 'Google・ChatGPT・Claudeに選ばれるWebサイト。AI時代の検索対応設計で集客基盤を構築します。',
    details: ['AI時代のSEO最適化', 'ローカルSEO（GEO対策）', 'レスポンシブWebデザイン', '継続的な改善・分析'],
    image: '/images/services/web-seo.jpg',
    href: '/service/web-seo',
  },
  {
    num: '04',
    title: '顧客接点の自動化',
    desc: '24時間365日の自動応答で機会損失をゼロに。チャットボット・自動配信・顧客管理に対応。',
    details: ['LINEチャットボット構築', '自動配信・セグメント配信', '顧客管理システム連携', '分析・最適化'],
    image: '/images/services/line-automation.jpg',
    href: '/service/line-automation',
  },
]
---

<Layout title="サービス一覧 | 福岡のAIコンサルティング AltShift" description="中小企業向けAI導入コンサルティング・AIシステム開発・Web制作×SEO/GEO・LINE自動化。最短2週間で戦略策定。福岡発、全国対応。">
  <Nav />
  <main>
    <section class="section-padding" style="background:var(--color-bg); padding-top:140px;">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="mb-16 reveal">
          <div class="accent-line mb-6"></div>
          <h1 class="heading-hero" style="font-size:clamp(28px,4vw,48px);">当社のサービス</h1>
        </div>

        <div class="flex flex-col gap-24">
          {services.map((s, i) => (
            <div class={`reveal grid grid-cols-1 lg:grid-cols-2 gap-12 items-center ${i % 2 !== 0 ? 'lg:[&>*:first-child]:order-2 lg:[&>*:last-child]:order-1' : ''}`}>
              <div>
                <p class="service-num mb-4">{s.num}</p>
                <h2 class="heading-lg mb-4">{s.title}</h2>
                <p class="body-md mb-8">{s.desc}</p>
                <ul class="flex flex-col gap-3 mb-8">
                  {s.details.map(item => (
                    <li class="flex items-center gap-3 text-sm" style="color:var(--color-ink);">
                      <div style="width:6px; height:6px; border-radius:50%; background:var(--color-primary); flex-shrink:0;"></div>
                      {item}
                    </li>
                  ))}
                </ul>
                <div class="flex gap-6">
                  <a href={s.href} class="neon-link">
                    詳しく見る
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                    </svg>
                  </a>
                  <a href="/contact" class="blue-link">
                    お問い合わせ
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                    </svg>
                  </a>
                </div>
              </div>
              <!-- IMAGE SLOT -->
              <div class="media-slot" style="aspect-ratio:4/3;">
                <img src={s.image} alt={s.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
