---
import Layout from '../../layouts/Layout.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import LineButton from '../../components/LineButton.astro'

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'AI活用研修',
  provider: { '@type': 'Organization', name: 'AltShift', url: 'https://altshift.jp' },
  areaServed: [{ '@type': 'City', name: '福岡市' }, { '@type': 'Country', name: '日本' }],
  description: '中小企業向けAI活用研修。御社の業務に合わせたカリキュラムで、社員が自分でAIを使いこなせるようになるまで伴走します。助成金活用で最大75%補助。',
  serviceType: 'AI活用研修',
}
---

<Layout
  title="AI活用研修 | 社員が自分でAIを使えるようになる | AltShift 福岡"
  description="中小企業向けAI活用研修。御社の業務に合わせたカリキュラムで、社員が明日からAIを使いこなせるように。ハンズオン形式・少人数〜全社対応。助成金で最大75%補助。福岡発、全国対応。"
  schemaData={schemaData}
>
  <Nav />
  <main>

    <!-- ① ヒーロー -->
    <section class="section-padding" style="background:var(--color-bg); padding-top:140px; padding-bottom:48px;">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="mb-0 reveal">
          <a href="/service" class="text-xs font-semibold mb-4 inline-block" style="color:var(--color-brand); letter-spacing:0.05em;">← サービス一覧</a>
          <p class="service-num mb-4">03</p>
          <h1 class="heading-hero" style="font-size:clamp(28px,4vw,48px);">"AIを使える人"を、<br/>社内に育てる</h1>
          <p class="body-lg mt-4" style="max-width:640px;">
            何から始めればいいか分からない——その状態から、御社のチームが自分でAIを動かせるようになるまで伴走します。
          </p>
          <div class="flex flex-wrap gap-4 mt-8">
            <a href="https://calendly.com/daiki-sakaguchi1994/30min" target="_blank" rel="noopener noreferrer" class="btn-primary" style="padding:14px 28px;">
              まずは相談する
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
            <a href="#steps" class="btn-secondary-ghost" style="padding:14px 28px;">研修の進め方を見る →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ② こんな状態ではありませんか -->
    <section class="section-padding" style="background:var(--color-bg-sub);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="reveal mb-12">
          <h2 class="heading-lg text-center mb-4">こんな状態ではありませんか</h2>
          <p class="body-md text-center" style="color:var(--color-ink-sub); max-width:560px; margin:0 auto;">AI導入でつまずく経営者の多くが、同じ壁にぶつかります。</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger">
          {[
            'AIが良いのは分かるが、何から手をつければいいか分からない',
            'ツールは導入したが、結局誰も使っていない',
            '社員に教えたいが、教えられる人が社内にいない',
          ].map(text => (
            <div class="reveal t-card p-6">
              <p class="body-md" style="color:var(--color-ink); font-style:italic; line-height:1.8;">"{text}"</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ③ この研修で、御社はこう変わる -->
    <section class="section-padding" style="background:var(--color-bg);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="reveal" style="max-width:720px;">
          <p class="body-md mb-8" style="color:var(--color-ink-sub); line-height:1.9;">
            これらに共通するのは、<strong style="color:#1A1A2E;">"教える人が社内にいない"</strong>こと。研修は、その状態を変える最短ルートです。
          </p>
          <h2 class="heading-lg mb-6">特定の誰かに依存しない、<br/>"AIを使えるチーム"へ</h2>
          <p class="body-md" style="color:var(--color-ink-sub); line-height:1.9;">
            一部の詳しい人だけが使う状態から、チーム全体が日常業務でAIを自然に使いこなす状態へ。属人化を防ぎ、社内にノウハウが残ります。
          </p>
        </div>
      </div>
    </section>

    <!-- ④ 研修の進め方（5ステップ） -->
    <section id="steps" class="section-padding" style="background:var(--color-bg-sub);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="reveal mb-12">
          <h2 class="heading-lg text-center mb-4">何から始めるか迷わない、5つのステップ</h2>
          <p class="body-md text-center" style="color:var(--color-ink-sub); max-width:560px; margin:0 auto;">御社の状況に合わせて設計しますが、標準的にはこの流れで進めます。</p>
        </div>
        <div class="flex flex-col gap-4 stagger" style="max-width:720px; margin:0 auto;">
          {[
            { num: '01', title: '業務の棚卸し', desc: 'どの業務にAIが効くかを、現場を見ながら一緒に洗い出します。' },
            { num: '02', title: '推進メンバーの選定', desc: '1名から全社まで、御社の体制に合わせてチームを編成。誰がAIを推進するかを決めます。' },
            { num: '03', title: '基礎講義＋ハンズオン', desc: '生成AIの基本から実務での使い方まで、実際に手を動かしながら習得します。' },
            { num: '04', title: '業務への適用', desc: '学んだAIを実際の業務で使い、改善サイクルを回します。' },
            { num: '05', title: '社内への定着', desc: '勉強会や活用事例の共有で、AIを使う文化を社内に根づかせます。' },
          ].map(step => (
            <div class="reveal flex items-start gap-5 p-5" style="background:var(--color-bg-card); border:1px solid var(--color-border-card); border-radius:12px;">
              <span style="font-family:'Inter',sans-serif; font-weight:800; font-size:28px; letter-spacing:-0.03em; color:#0E9E96; line-height:1; flex-shrink:0; min-width:40px;">{step.num}</span>
              <div>
                <p style="font-weight:700; font-size:15px; color:var(--color-ink); margin-bottom:4px;">{step.title}</p>
                <p class="body-sm" style="color:var(--color-ink-sub);">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ⑤ 研修の特徴 -->
    <section class="section-padding" style="background:var(--color-bg);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="reveal mb-12">
          <h2 class="heading-lg text-center mb-4">研修の特徴</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 stagger">
          {[
            { title: '明日から使える', desc: '一般論ではなく、御社の実務に直結した内容だけを扱います。研修翌日から業務で使えるスキルが身につきます。' },
            { title: '現場目線の伴走', desc: '研修して終わりではなく、実際の業務に定着するまで一緒に走ります。' },
            { title: '助成金で最大75%補助', desc: '人材開発支援助成金の対象になる場合があります。申請サポートも含めてご相談いただけます。' },
            { title: 'ハンズオン形式・少人数〜全社対応', desc: '座学だけでなく、実際にAIを触りながら学ぶ実践形式。1名の個別指導から全社一括研修まで柔軟に対応します。' },
          ].map(f => (
            <div class="reveal t-card p-6">
              <h3 class="heading-sm mb-3">{f.title}</h3>
              <p class="body-sm">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ⑥ 料金・形式 -->
    <section class="section-padding" style="background:var(--color-bg-sub);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="reveal" style="max-width:720px;">
          <h2 class="heading-lg mb-6">御社に合わせた、オーダーメイド設計</h2>
          <p class="body-md mb-6" style="color:var(--color-ink-sub); line-height:1.9;">
            研修内容・期間・人数は御社の目的に合わせて設計します。まずは現状をお聞かせください。
          </p>
          <div class="flex flex-col gap-3">
            <div class="flex items-center gap-3">
              <span style="width:6px; height:6px; border-radius:50%; background:#0E9E96; flex-shrink:0;"></span>
              <p class="body-sm" style="color:var(--color-ink);">対象人数：1名〜全社</p>
            </div>
            <div class="flex items-center gap-3">
              <span style="width:6px; height:6px; border-radius:50%; background:#0E9E96; flex-shrink:0;"></span>
              <p class="body-sm" style="color:var(--color-ink);">形式：オンライン・対面いずれも対応</p>
            </div>
            <div class="flex items-center gap-3">
              <span style="width:6px; height:6px; border-radius:50%; background:#0E9E96; flex-shrink:0;"></span>
              <p class="body-sm" style="color:var(--color-ink);">期間：半日〜数ヶ月の定着支援まで柔軟に設計</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ⑦ 助成金で実質負担を下げられる -->
    <section class="section-padding" style="background:var(--color-bg);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="reveal t-card p-8" style="max-width:720px;">
          <h2 class="heading-md mb-4">人材開発支援助成金で、最大75%の補助</h2>
          <p class="body-md" style="color:var(--color-ink-sub); line-height:1.9;">
            条件を満たせば、研修費用の実質負担は1/4程度まで下がる可能性があります。申請のサポートも含めてご相談いただけます。
          </p>
          <a href="/subsidy" class="inline-block mt-6" style="font-size:14px; font-weight:500; color:var(--color-brand);">補助金活用について詳しく見る →</a>
        </div>
      </div>
    </section>

    <!-- ⑧ 締め＋CTA -->
    <section class="section-padding" style="background:var(--color-bg-sub);">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="reveal t-card flex flex-col md:flex-row items-center justify-between gap-6 p-8">
          <div>
            <h3 class="heading-md mb-2">"何から始めるか"の答えは、<br class="hidden md:block"/>一度話せば見えてきます</h3>
            <p class="body-sm">御社の状況をお聞きすれば、最適な進め方をご提案できます。まずは気軽にご相談ください。</p>
          </div>
          <div class="flex gap-3 flex-shrink-0">
            <a href="https://calendly.com/daiki-sakaguchi1994/30min" target="_blank" rel="noopener noreferrer" class="btn-primary whitespace-nowrap">
              無料相談（30分）
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
            <LineButton class="whitespace-nowrap" />
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
